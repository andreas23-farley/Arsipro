<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>ARSIPRO</title>

<!-- FONT -->
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>

/* ===== GLOBAL ===== */
body {
  margin: 0;
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: #5c3904;
}

/* ===== HEADER ===== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 70px;
  position: sticky;

  position: sticky;
  top: 0;
  z-index: 1000;

  background: rgba(66, 38, 16, 0.8);
  backdrop-filter: blur(14px);

  border-bottom: 1px solid rgba(0,0,0,0.05);
}

/* ===== LOGO ===== */
.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
}

.logo img {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  object-fit: cover;

  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

/* ===== LOGO TEXT 2 BARIS ===== */
.logo span {
  display: flex;
  flex-direction: column;

  font-size: 15px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #f0f1f3;

  line-height: 1.2;
}

.nav {
  position: absolute;
  left: 51%;
  transform: translateX(-50%);

  display: flex;
  gap: 45px;
}

.nav a {
  text-decoration: none;
  font-size: 15px;
  font-weight: 500;
  color: #eef1f5;

  position: relative;
  transition: 0.3s;
}

.nav a:hover {
  color: #07090e;
}

.nav a::after {
  content: "";
  position: absolute;
  bottom: -6px;
  left: 50%;
  transform: translateX(-50%);
  width: 0%;
  height: 2px;
  background: #111827;
  transition: 0.3s;
}

.nav a:hover::after {
  width: 50%;
}

/* ===== BUTTON ===== */
.btn-login {
  padding: 10px 20px;
  border-radius: 999px;

  font-size: 13px;
  font-weight: 600;

  text-decoration: none;
  color: white;
  background: #111827;

  transition: 0.3s;
}

.btn-login:hover {
  background: #000;
  transform: translateY(-2px);
}

/* ===== MOBILE ===== */
.menu-toggle {
  display: none;
  font-size: 24px;
  cursor: pointer;
}

/* MOBILE MENU */
.mobile-menu {
  display: none;
  flex-direction: column;
  gap: 18px;

  position: absolute;
  top: 75px;
  right: 20px;
  width: 220px;

  padding: 20px;
  border-radius: 14px;

  background: white;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}

.mobile-menu a {
  text-decoration: none;
  color: #374151;
  font-weight: 500;
}

.mobile-menu .btn-login {
  text-align: center;
}

.mobile-menu.show {
  display: flex;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {

  .header {
    padding: 15px 25px;
  }

  .nav,
  .btn-login {
    display: none;
  }

  .menu-toggle {
    display: block;
  }

  .logo span {
    font-size: 13px;
  }
}

</style>
</head>

<body>

<header class="header">

  <div class="logo">
    <img src="public/LOGO.jpg" alt="logo">
    <span>
      INSTITUT
      SHANTI BHUANA
    </span>
  </div>

  <nav class="nav">
    <a href="/">Beranda</a>
    <a href="/panduan">Panduan</a>
    <a href="/contact">Kontak</a>
  </nav>

  <a href="/login" class="btn-login">Login</a>

  <div class="menu-toggle" id="menuToggle">☰</div>
</header>

<!-- MOBILE -->
<div class="mobile-menu" id="mobileMenu">
  <a href="/">Beranda</a>
  <a href="/panduan">Panduan</a>
  <a href="/tentang">Tentang</a>
  <a href="/contact">Kontak</a>
  <a href="/login" class="btn-login">Masuk</a>
</div>

<script>
const toggle = document.getElementById("menuToggle");
const menu = document.getElementById("mobileMenu");

if (toggle && menu) {
  toggle.addEventListener("click", () => {
    menu.classList.toggle("show");
  });

  document.addEventListener("click", function(e) {
    if (e.target instanceof Node && !toggle.contains(e.target) && !menu.contains(e.target)) {
      menu.classList.remove("show");
    }
  });
}
</script>

</body>
</html>