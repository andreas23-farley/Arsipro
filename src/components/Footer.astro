  </div>

  <!-- BOTTOM BAR -->
  <div class="footer-bottom">
    <div class="bottom-inner">
      <p>© 2026 <strong>ARSIPRO</strong> — Institut Shanti Bhuana. All rights reserved.</p>
      <div class="bottom-pills">
        <span class="pill">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Keamanan Data
        </span>
        <span class="pill">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Verified System
        </span>
        <span class="pill">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          v1.0.0
        </span>
      </div>
    </div>
  </div>

</footer>

<style>

.footer {
  background: linear-gradient(180deg, #38210e 0%, #36210d 100%);
  color: #f3f4f5;
  font-family: 'Plus Jakarta Sans', sans-serif;
  position: relative;
  overflow: hidden;
}

/* Dekorasi glow di belakang */
.footer::before {
  content: '';
  position: absolute;
  top: -120px; left: -100px;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(79,70,229,0.10), transparent 65%);
  pointer-events: none;
}
.footer::after {
  content: '';
  position: absolute;
  bottom: 0; right: -80px;
  width: 320px; height: 320px;
  background: radial-gradient(circle, rgba(6,182,212,0.08), transparent 65%);
  pointer-events: none;
}

/* Garis gradien atas */
.footer-topbar {
  height: 2px;
  background: linear-gradient(90deg, transparent, #4f46e5 30%, #06b6d4 70%, transparent);
  opacity: 0.6;
}

/* Grid utama */
.footer-container {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1.3fr;
  gap: 48px;
  max-width: 1200px;
  margin: 0 auto;
  padding: 52px 40px 44px;
  position: relative;
  z-index: 1;
}

/* ── BRAND ── */
.brand-logo {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.logo-ring {
  position: relative;
  width: 46px; height: 46px;
  flex-shrink: 0;
}
.logo-ring img {
  width: 44px; height: 44px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid rgba(255,255,255,0.12);
  position: relative; z-index: 1;
}
.logo-ring::before {
  content: '';
  position: absolute; inset: -3px;
  border-radius: 50%;
  border: 1.5px solid transparent;
  background: linear-gradient(135deg,#4f46e5,#06b6d4) border-box;
  -webkit-mask: linear-gradient(white,white) padding-box, linear-gradient(white,white);
  -webkit-mask-composite: destination-out;
  mask-composite: exclude;
  animation: spinRing 8s linear infinite;
}
@keyframes spinRing { to { transform:rotate(360deg); } }

.brand-name {
  font-size: 18px;
  font-weight: 800;
  color: white;
  letter-spacing: -0.3px;
  line-height: 1.2;
}
.brand-tag {
  font-size: 11px;
  color: rgba(248, 242, 242, 0.35);
  font-weight: 500;
}

.brand-desc {
  font-size: 13.5px;
  color: #f1f7f7;
  line-height: 1.8;
  margin-bottom: 20px;
  max-width: 280px;
}

/* Socials */
.socials { display:flex; gap:8px; }
.social-btn {
  width: 36px; height: 36px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  color: #f2f3f5;
  text-decoration: none;
  transition: all 0.25s;
}
.social-btn:hover { transform: translateY(-3px); color: white; }
.social-btn:nth-child(1):hover { background:#2563eb; border-color:#2563eb; }
.social-btn.social-ig:hover    { background:#E1306C; border-color:#E1306C; }
.social-btn.social-yt:hover    { background:#FF0000; border-color:#FF0000; }

/* ── KOLOM ── */
.footer-col {}

.col-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  font-weight: 700;
  color: white;
  margin-bottom: 18px;
  letter-spacing: 0.2px;
}
.col-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.col-dot--indigo { background: #4f46e5; box-shadow: 0 0 6px #4f46e5; }
.col-dot--cyan   { background: #06b6d4; box-shadow: 0 0 6px #06b6d4; }
.col-dot--green  { background: #10b981; box-shadow: 0 0 6px #10b981; }

.col-links { display:flex; flex-direction:column; gap:2px; }
.col-links a {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 0;
  text-decoration: none;
  color: #f9fbfd;
  font-size: 13.5px;
  font-weight: 500;
  transition: all 0.2s;
  border-radius: 6px;
}
.col-links a:hover {
  color: white;
  gap: 10px;
  padding-left: 4px;
}
.col-links a svg { flex-shrink:0; opacity:0.5; transition:opacity 0.2s; }
.col-links a:hover svg { opacity:1; }

/* ── KONTAK ── */
.contact-list { display:flex; flex-direction:column; gap:12px; }
.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 13.5px;
  color: #f9fbfd;
  line-height: 1.6;
}
.contact-icon {
  width: 28px; height: 28px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  color: #eeeff1;
  margin-top: 1px;
}

/* Badge status */
.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: rgba(16,185,129,0.10);
  border: 1px solid rgba(16,185,129,0.2);
  color: #6ee7b7;
  font-size: 12px;
  font-weight: 600;
  padding: 6px 12px;
  border-radius: 999px;
  margin-top: 4px;
  width: fit-content;
}
.status-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #10b981;
  box-shadow: 0 0 6px #10b981;
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%,100% { opacity:1; transform:scale(1); }
  50%      { opacity:0.5; transform:scale(0.8); }
}

/* ── BOTTOM BAR ── */
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.06);
  position: relative; z-index:1;
}
.bottom-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 16px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}
.bottom-inner p {
  font-size: 13px;
  color: #dadcdd;
}
.bottom-inner strong { color: #d5d5d6; }

.bottom-pills {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.06);
  color: #e2e2e2;
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 999px;
  letter-spacing: 0.3px;
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .footer-container { grid-template-columns: repeat(2,1fr); gap: 36px; }
}

@media (max-width: 640px) {
  .footer-container { grid-template-columns: 1fr; gap: 30px; padding: 40px 24px 36px; }
  .brand-desc { max-width: 100%; }
  .bottom-inner { flex-direction: column; align-items: flex-start; padding: 16px 24px; }
}

</style>