---
const role = "Dosen";
const currentPath = Astro.url.pathname;
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Surat Masuk Dosen</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
</head>

<body>

<button class="menu-toggle" onclick="toggleSidebar()">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <line x1="3" y1="12" x2="21" y2="12"/>
    <line x1="3" y1="6" x2="21" y2="6"/>
    <line x1="3" y1="18" x2="21" y2="18"/>
  </svg>
</button>

<aside class="sidebar" id="sidebar">
  <div class="logo">
    <img src="/LOGO.jpg" class="logo-img"/>
    <h2>ARSIPRO</h2>
    <span>Sistem Arsip Digital</span>
  </div>

  <nav>
    <a href="/dosen/dashboard" class={currentPath === "/dosen/dashboard" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Dashboard
    </a>
    <a href="/dosen/surat" class={currentPath === "/dosen/surat" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22 6 12 13 2 6"/>
      </svg>
      Surat Masuk
    </a>
    <a href="/dosen/permintaan" class={currentPath === "/dosen/permintaan" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
      Request Surat
    </a>
    <a href="/dosen/template" class={currentPath === "/dosen/template" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
      Template Surat
    </a>
    <a href="/dosen/arsip" class={currentPath === "/dosen/arsip" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="21 8 21 21 3 21 3 8"/>
        <rect x="1" y="3" width="22" height="5"/>
        <line x1="10" y1="12" x2="14" y2="12"/>
      </svg>
      Arsip
    </a>
    <a href="/dosen/profil" class={currentPath === "/dosen/profil" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      Profil
    </a>
  </nav>

  <div class="logout">
    <a href="/login" onclick="localStorage.clear()">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Logout
    </a>
  </div>
</aside>

<div class="main">

  <header class="navbar">
    <div>
      <div style="font-size:13px;color:#64748b;font-weight:500;">DASHBOARD</div>
      <div style="font-size:17px;font-weight:700;color:#0f172a;">Panel Dosen</div>
    </div>
    <div style="display:flex;align-items:center;gap:12px;">
      <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#4f46e5,#06b6d4);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:14px;" id="avatarInit">D</div>
      <div>
        <div id="namaUser" style="font-size:14px;font-weight:600;color:#0f172a;">{role}</div>
        <div style="font-size:11px;color:#64748b;">Dosen</div>
      </div>
    </div>
  </header>

  <main class="content">

    <!-- HEADER -->
    <div style="margin-bottom:24px;">
      <h1 style="font-size:26px;font-weight:700;background:linear-gradient(135deg,#4f46e5,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0 0 4px;">Surat Masuk</h1>
      <p style="color:#6b7280;font-size:14px;margin:0;">Surat yang dikirimkan dari admin kepada Anda.</p>
    </div>

    <!-- STATS -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px;">

      <div style="background:white;border-radius:16px;padding:16px 18px;display:flex;align-items:center;gap:12px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #4f46e5;">
        <div style="width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,#ede9fe,#ddd6fe);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <div>
          <div id="statTotal" style="font-size:22px;font-weight:700;color:#111827;">0</div>
          <div style="font-size:12px;color:#6b7280;">Total Surat</div>
        </div>
      </div>

      <div style="background:white;border-radius:16px;padding:16px 18px;display:flex;align-items:center;gap:12px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #06b6d4;">
        <div style="width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,#cffafe,#a5f3fc);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0891b2" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <div>
          <div id="statBulanIni" style="font-size:22px;font-weight:700;color:#111827;">0</div>
          <div style="font-size:12px;color:#6b7280;">Bulan Ini</div>
        </div>
      </div>

      <div style="background:white;border-radius:16px;padding:16px 18px;display:flex;align-items:center;gap:12px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #10b981;">
        <div style="width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,#d1fae5,#a7f3d0);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
            <line x1="7" y1="7" x2="7.01" y2="7"/>
          </svg>
        </div>
        <div>
          <div id="statKategori" style="font-size:22px;font-weight:700;color:#111827;">0</div>
          <div style="font-size:12px;color:#6b7280;">Kategori</div>
        </div>
      </div>

    </div>

    <!-- TOOLBAR -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:12px;">

      <div style="display:flex;gap:8px;flex-wrap:wrap;" id="tabKategori">
        <button onclick="filterSurat('all')" id="tab-all" class="tab-btn"
          style="padding:8px 16px;border-radius:999px;border:1.5px solid #4f46e5;background:linear-gradient(135deg,#4f46e5,#06b6d4);color:white;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;">
          Semua
        </button>
      </div>

      <div style="position:relative;">
        <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);display:flex;align-items:center;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </span>
        <input type="text" id="searchInput" placeholder="Cari judul surat..."
          style="padding:9px 12px 9px 36px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:13px;font-family:inherit;width:220px;"
          onfocus="this.style.borderColor='#4f46e5';"
          onblur="this.style.borderColor='#e5e7eb';">
      </div>

    </div>

    <!-- CARD GRID -->
    <div id="cardGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:18px;">
      <p style="color:#9ca3af;">Loading...</p>
    </div>

  </main>

  <footer style="text-align:center;padding:16px;font-size:13px;color:#94a3b8;border-top:1px solid #f1f5f9;">
    © 2026 ARSIPRO — Sistem Manajemen Arsip Surat
  </footer>

</div>

<!-- Modal Detail -->
<div id="modalDetail" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);backdrop-filter:blur(4px);align-items:center;justify-content:center;z-index:9999;padding:20px;">
  <div style="background:white;border-radius:22px;padding:28px;max-width:500px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,0.2);max-height:85vh;overflow-y:auto;">

    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #f3f4f6;">
      <div>
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.6px;color:#9ca3af;margin-bottom:4px;">Detail Surat</div>
        <div id="modalJudul" style="font-size:17px;font-weight:700;color:#111827;line-height:1.4;"></div>
      </div>
      <button onclick="closeModal()"
        style="border:none;background:#f3f4f6;color:#6b7280;border-radius:8px;padding:6px 12px;cursor:pointer;font-size:13px;font-weight:600;font-family:inherit;flex-shrink:0;margin-left:12px;display:flex;align-items:center;gap:4px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
        Tutup
      </button>
    </div>

    <div id="modalBody" style="display:flex;flex-direction:column;gap:0;"></div>

    <div style="margin-top:22px;padding-top:16px;border-top:1px solid #f3f4f6;">
      <button id="modalDownloadBtn"
        style="width:100%;padding:12px;border:none;border-radius:10px;background:linear-gradient(135deg,#4f46e5,#06b6d4);color:white;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:8px;"
        onmouseover="this.style.transform='translateY(-1px)';"
        onmouseout="this.style.transform='none';">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download File Surat
      </button>
    </div>

  </div>
</div>

<script is:inline>
const BASE_URL = "http://100.85.49.78:3000";
const token = localStorage.getItem("token");
if (!token) window.location.href = "/login";

const userData = JSON.parse(localStorage.getItem("user") || "{}");
if (userData.nama) {
  document.getElementById("namaUser").textContent = userData.nama;
  document.getElementById("avatarInit").textContent = userData.nama[0]?.toUpperCase() || "D";
}

let semuaSurat = [];
let filterAktif = "all";

const kategoriStyle = {
  "Surat Tugas":       { bg:"#ede9fe", color:"#4f46e5" },
  "Surat Undangan":    { bg:"#e0f2fe", color:"#0369a1" },
  "Surat Rekomendasi": { bg:"#d1fae5", color:"#065f46" },
  "Surat Keterangan":  { bg:"#fce7f3", color:"#9d174d" },
};

// SVG strings untuk dipakai di innerHTML
const SVG = {
  download: `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
  eye:      `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
  inbox:    `<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>`,
  user:     `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  file:     `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`,
};

function getKS(k) {
  return kategoriStyle[k] || { bg:"#f3f4f6", color:"#374151" };
}

async function loadSuratMasuk() {
  try {
    const res  = await fetch(`${BASE_URL}/api/surat-dosen/masuk`, { headers: { "Authorization": `Bearer ${token}` } });
    const data = await res.json();
    semuaSurat = data;

    const now = new Date();
    const bulanIni  = data.filter(s => {
      const d = new Date(s.created_at);
      return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
    });
    const kategoriSet = [...new Set(data.map(s => s.kategori).filter(Boolean))];

    document.getElementById("statTotal").textContent    = data.length;
    document.getElementById("statBulanIni").textContent = bulanIni.length;
    document.getElementById("statKategori").textContent = kategoriSet.length;

    const tabContainer = document.getElementById("tabKategori");
    kategoriSet.forEach(k => {
      const btn = document.createElement("button");
      btn.id = `tab-${k}`;
      btn.textContent = k;
      btn.className = "tab-btn";
      btn.onclick = () => filterSurat(k);
      btn.style.cssText = "padding:8px 16px;border-radius:999px;border:1.5px solid #e5e7eb;background:white;color:#6b7280;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;";
      btn.onmouseover = () => { if (filterAktif !== k) { btn.style.borderColor="#4f46e5"; btn.style.color="#4f46e5"; } };
      btn.onmouseout  = () => { if (filterAktif !== k) { btn.style.borderColor="#e5e7eb"; btn.style.color="#6b7280"; } };
      tabContainer.appendChild(btn);
    });

    renderCards(data);
  } catch(e) { console.error(e); }
}

window.filterSurat = function(kategori) {
  filterAktif = kategori;
  document.querySelectorAll(".tab-btn").forEach(btn => {
    btn.style.cssText = "padding:8px 16px;border-radius:999px;border:1.5px solid #e5e7eb;background:white;color:#6b7280;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;";
  });
  const ab = document.getElementById(`tab-${kategori}`);
  if (ab) ab.style.cssText = "padding:8px 16px;border-radius:999px;border:1.5px solid #4f46e5;background:linear-gradient(135deg,#4f46e5,#06b6d4);color:white;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;";
  applyFilter();
};

document.getElementById("searchInput").addEventListener("input", applyFilter);

function applyFilter() {
  const q = document.getElementById("searchInput").value.toLowerCase();
  let filtered = semuaSurat;
  if (filterAktif !== "all") filtered = filtered.filter(s => s.kategori === filterAktif);
  if (q) filtered = filtered.filter(s => s.judul_surat?.toLowerCase().includes(q) || s.deskripsi?.toLowerCase().includes(q));
  renderCards(filtered);
}

function renderCards(data) {
  const grid = document.getElementById("cardGrid");

  if (!data || data.length === 0) {
    grid.innerHTML = `
      <div style="grid-column:1/-1;text-align:center;padding:60px 20px;">
        <div style="display:flex;justify-content:center;margin-bottom:16px;">${SVG.inbox}</div>
        <div style="font-size:15px;font-weight:600;color:#374151;margin-bottom:4px;">Belum ada surat masuk</div>
        <div style="font-size:13px;color:#9ca3af;">Surat dari admin akan muncul di sini</div>
      </div>`;
    return;
  }

  grid.innerHTML = data.map(s => {
    const ks  = getKS(s.kategori);
    const tgl = new Date(s.created_at).toLocaleDateString("id-ID",{day:"2-digit",month:"short",year:"numeric"});
    const sid = s.id_surat || s.id;
    return `
      <div style="background:white;border-radius:18px;padding:22px;box-shadow:0 4px 20px rgba(0,0,0,0.07);border:1.5px solid #f3f4f6;display:flex;flex-direction:column;gap:10px;transition:all 0.2s;"
        onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 30px rgba(79,70,229,0.12)';this.style.borderColor='#c7d2fe';"
        onmouseout="this.style.transform='none';this.style.boxShadow='0 4px 20px rgba(0,0,0,0.07)';this.style.borderColor='#f3f4f6';">

        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;">
          <span style="background:${ks.bg};color:${ks.color};padding:4px 12px;border-radius:20px;font-size:11px;font-weight:700;white-space:nowrap;">${s.kategori || 'Umum'}</span>
          <span style="font-size:11px;color:#9ca3af;white-space:nowrap;">${tgl}</span>
        </div>

        <div style="font-size:15px;font-weight:700;color:#111827;line-height:1.4;">${s.judul_surat}</div>

        <div style="font-size:13px;color:#6b7280;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${s.deskripsi || 'Tidak ada deskripsi.'}</div>

        <div style="display:flex;align-items:center;gap:8px;padding-top:6px;margin-top:auto;">
          <div style="width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#4f46e5,#06b6d4);display:flex;align-items:center;justify-content:center;flex-shrink:0;">${SVG.user}</div>
          <span style="font-size:12px;color:#6b7280;">Dikirim oleh <strong style="color:#374151;">Admin</strong></span>
        </div>

        <div style="display:flex;gap:8px;margin-top:4px;">
          <button onclick="lihatDetail(${sid})"
            style="flex:1;padding:9px;border:1.5px solid #e5e7eb;border-radius:10px;background:white;color:#374151;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:5px;"
            onmouseover="this.style.borderColor='#4f46e5';this.style.color='#4f46e5';"
            onmouseout="this.style.borderColor='#e5e7eb';this.style.color='#374151';">
            ${SVG.eye} Detail
          </button>
          <button onclick="window.open('${BASE_URL}/uploads/${s.file_surat}','_blank')"
            style="flex:1;padding:9px;border:none;border-radius:10px;background:linear-gradient(135deg,#4f46e5,#06b6d4);color:white;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:5px;"
            onmouseover="this.style.transform='translateY(-1px)';"
            onmouseout="this.style.transform='none';">
            ${SVG.download} Unduh
          </button>
        </div>

      </div>`;
  }).join("");
}

window.lihatDetail = function(id) {
  const s = semuaSurat.find(x => (x.id_surat || x.id) === id);
  if (!s) return;

  const ks = getKS(s.kategori);
  document.getElementById("modalJudul").textContent = s.judul_surat;

  const rows = [
    ["Kategori",  `<span style="background:${ks.bg};color:${ks.color};padding:4px 12px;border-radius:20px;font-size:12px;font-weight:700;">${s.kategori || '-'}</span>`],
    ["Dikirim",   "Admin"],
    ["Tanggal",   new Date(s.created_at).toLocaleDateString("id-ID",{day:"2-digit",month:"long",year:"numeric"})],
    ["Deskripsi", s.deskripsi || "Tidak ada deskripsi."],
  ];

  document.getElementById("modalBody").innerHTML = rows.map(([lbl, val]) => `
    <div style="display:flex;flex-direction:column;gap:4px;padding:12px 0;border-bottom:1px solid #f3f4f6;">
      <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.6px;color:#9ca3af;">${lbl}</span>
      <span style="font-size:14px;color:#1e293b;line-height:1.6;">${val}</span>
    </div>
  `).join("");

  document.getElementById("modalDownloadBtn").onclick = () => window.open(`${BASE_URL}/uploads/${s.file_surat}`, "_blank");
  document.getElementById("modalDetail").style.display = "flex";
};

window.closeModal = function() {
  document.getElementById("modalDetail").style.display = "none";
};

document.getElementById("modalDetail").addEventListener("click", e => {
  if (e.target === document.getElementById("modalDetail")) closeModal();
});

function toggleSidebar() {
  document.getElementById("sidebar").classList.toggle("active");
}

loadSuratMasuk();
</script>

</body>
</html>

