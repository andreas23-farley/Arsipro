---
const role = "Dosen";
const currentPath = Astro.url.pathname;
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Template Surat Dosen</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
</head>

<body>

<button class="menu-toggle" onclick="toggleSidebar()">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <line x1="3" y1="12" x2="21" y2="12"/>
    <line x1="3" y1="6" x2="21" y2="6"/>
    <line x1="3" y1="18" x2="21" y2="18"/>
  </svg>
</button>

<aside class="sidebar" id="sidebar">
  <div class="logo">
    <img src="/LOGO.jpg" class="logo-img"/>
    <h2>ARSIPRO</h2>
    <span>Sistem Arsip Digital</span>
  </div>

  <nav>
    <a href="/dosen/dashboard" class={currentPath === "/dosen/dashboard" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Dashboard
    </a>
    <a href="/dosen/surat" class={currentPath === "/dosen/surat" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22 6 12 13 2 6"/>
      </svg>
      Surat Masuk
    </a>
    <a href="/dosen/permintaan" class={currentPath === "/dosen/permintaan" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
      Request Surat
    </a>
    <a href="/dosen/template" class={currentPath === "/dosen/template" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
      Template Surat
    </a>
    <a href="/dosen/arsip" class={currentPath === "/dosen/arsip" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="21 8 21 21 3 21 3 8"/>
        <rect x="1" y="3" width="22" height="5"/>
        <line x1="10" y1="12" x2="14" y2="12"/>
      </svg>
      Arsip
    </a>
    <a href="/dosen/profil" class={currentPath === "/dosen/profil" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      Profil
    </a>
  </nav>

  <div class="logout">
    <a href="/login" onclick="localStorage.clear()">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Logout
    </a>
  </div>
</aside>

<div class="main">

  <!-- NAVBAR -->
  <header class="navbar">
    <div>
      <div style="font-size:13px;color:#64748b;font-weight:500;">DASHBOARD</div>
      <div style="font-size:17px;font-weight:700;color:#0f172a;">Panel Dosen</div>
    </div>
    <div style="display:flex;align-items:center;gap:12px;">
      <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#4f46e5,#06b6d4);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:14px;" id="avatarInit">D</div>
      <div>
        <div id="namaUser" style="font-size:14px;font-weight:600;color:#0f172a;">{role}</div>
        <div style="font-size:11px;color:#64748b;">Dosen</div>
      </div>
    </div>
  </header>

  <main class="content">

    <!-- HEADER -->
    <div style="margin-bottom:24px;">
      <h1 style="font-size:26px;font-weight:700;background:linear-gradient(135deg,#4f46e5,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0 0 4px;">Template Surat</h1>
      <p style="color:#6b7280;font-size:14px;margin:0;">Pilih template surat resmi, lihat preview, lalu unduh file Word (.docx).</p>
    </div>

    <!-- TEMPLATE CARDS -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:18px;margin-bottom:28px;">

      <!-- Surat Tugas -->
      <div class="tmpl-card" onclick="showTemplate('tugas')" id="card-tugas"
        style="background:white;border-radius:18px;padding:22px;box-shadow:0 4px 20px rgba(0,0,0,0.07);border:2px solid #f3f4f6;cursor:pointer;transition:all 0.2s;display:flex;flex-direction:column;gap:12px;">
        <div style="width:46px;height:46px;border-radius:14px;background:linear-gradient(135deg,#ede9fe,#ddd6fe);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
        </div>
        <div>
          <div style="font-size:15px;font-weight:700;color:#111827;margin-bottom:5px;">Surat Tugas</div>
          <div style="font-size:13px;color:#6b7280;line-height:1.5;">Template surat tugas untuk menghadiri kegiatan akademik, seminar, atau workshop.</div>
        </div>
        <div style="display:flex;gap:8px;margin-top:auto;">
          <button class="btn-preview" onclick="event.stopPropagation();showTemplate('tugas')"
            style="flex:1;padding:8px;border:1.5px solid #e5e7eb;border-radius:9px;background:white;color:#374151;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:5px;"
            onmouseover="this.style.borderColor='#4f46e5';this.style.color='#4f46e5';"
            onmouseout="this.style.borderColor='#e5e7eb';this.style.color='#374151';">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Preview
          </button>
          <a href="/templates/template-surat-tugas.docx" download
            style="flex:1;padding:8px;border:none;border-radius:9px;background:linear-gradient(135deg,#4f46e5,#06b6d4);color:white;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:5px;text-decoration:none;"
            onclick="event.stopPropagation();"
            onmouseover="this.style.transform='translateY(-1px)';"
            onmouseout="this.style.transform='none';">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Unduh .docx
          </a>
        </div>
      </div>

      <!-- Surat Undangan -->
      <div class="tmpl-card" onclick="showTemplate('undangan')" id="card-undangan"
        style="background:white;border-radius:18px;padding:22px;box-shadow:0 4px 20px rgba(0,0,0,0.07);border:2px solid #f3f4f6;cursor:pointer;transition:all 0.2s;display:flex;flex-direction:column;gap:12px;">
        <div style="width:46px;height:46px;border-radius:14px;background:linear-gradient(135deg,#e0f2fe,#bae6fd);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0369a1" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <div>
          <div style="font-size:15px;font-weight:700;color:#111827;margin-bottom:5px;">Surat Undangan</div>
          <div style="font-size:13px;color:#6b7280;line-height:1.5;">Template surat undangan rapat, kegiatan kampus, atau koordinasi akademik.</div>
        </div>
        <div style="display:flex;gap:8px;margin-top:auto;">
          <button class="btn-preview" onclick="event.stopPropagation();showTemplate('undangan')"
            style="flex:1;padding:8px;border:1.5px solid #e5e7eb;border-radius:9px;background:white;color:#374151;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:5px;"
            onmouseover="this.style.borderColor='#0369a1';this.style.color='#0369a1';"
            onmouseout="this.style.borderColor='#e5e7eb';this.style.color='#374151';">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Preview
          </button>
          <a href="/templates/template-surat-undangan.docx" download
            style="flex:1;padding:8px;border:none;border-radius:9px;background:linear-gradient(135deg,#0369a1,#06b6d4);color:white;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:5px;text-decoration:none;"
            onclick="event.stopPropagation();"
            onmouseover="this.style.transform='translateY(-1px)';"
            onmouseout="this.style.transform='none';">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Unduh .docx
          </a>
        </div>
      </div>

      <!-- Surat Rekomendasi -->
      <div class="tmpl-card" onclick="showTemplate('rekomendasi')" id="card-rekomendasi"
        style="background:white;border-radius:18px;padding:22px;box-shadow:0 4px 20px rgba(0,0,0,0.07);border:2px solid #f3f4f6;cursor:pointer;transition:all 0.2s;display:flex;flex-direction:column;gap:12px;">
        <div style="width:46px;height:46px;border-radius:14px;background:linear-gradient(135deg,#d1fae5,#a7f3d0);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2">
            <path d="M9 11l3 3L22 4"/>
            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
          </svg>
        </div>
        <div>
          <div style="font-size:15px;font-weight:700;color:#111827;margin-bottom:5px;">Surat Rekomendasi</div>
          <div style="font-size:13px;color:#6b7280;line-height:1.5;">Template surat rekomendasi untuk mahasiswa, kegiatan akademik, atau beasiswa.</div>
        </div>
        <div style="display:flex;gap:8px;margin-top:auto;">
          <button class="btn-preview" onclick="event.stopPropagation();showTemplate('rekomendasi')"
            style="flex:1;padding:8px;border:1.5px solid #e5e7eb;border-radius:9px;background:white;color:#374151;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:5px;"
            onmouseover="this.style.borderColor='#059669';this.style.color='#059669';"
            onmouseout="this.style.borderColor='#e5e7eb';this.style.color='#374151';">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Preview
          </button>
          <a href="/templates/template-surat-rekomendasi.docx" download
            style="flex:1;padding:8px;border:none;border-radius:9px;background:linear-gradient(135deg,#059669,#10b981);color:white;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:5px;text-decoration:none;"
            onclick="event.stopPropagation();"
            onmouseover="this.style.transform='translateY(-1px)';"
            onmouseout="this.style.transform='none';">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Unduh .docx
          </a>
        </div>
      </div>

      <!-- Surat Keterangan -->
      <div class="tmpl-card" onclick="showTemplate('keterangan')" id="card-keterangan"
        style="background:white;border-radius:18px;padding:22px;box-shadow:0 4px 20px rgba(0,0,0,0.07);border:2px solid #f3f4f6;cursor:pointer;transition:all 0.2s;display:flex;flex-direction:column;gap:12px;">
        <div style="width:46px;height:46px;border-radius:14px;background:linear-gradient(135deg,#fce7f3,#fbcfe8);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#be185d" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <div>
          <div style="font-size:15px;font-weight:700;color:#111827;margin-bottom:5px;">Surat Keterangan</div>
          <div style="font-size:13px;color:#6b7280;line-height:1.5;">Template surat keterangan resmi untuk mahasiswa atau kebutuhan administrasi.</div>
        </div>
        <div style="display:flex;gap:8px;margin-top:auto;">
          <button class="btn-preview" onclick="event.stopPropagation();showTemplate('keterangan')"
            style="flex:1;padding:8px;border:1.5px solid #e5e7eb;border-radius:9px;background:white;color:#374151;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:5px;"
            onmouseover="this.style.borderColor='#be185d';this.style.color='#be185d';"
            onmouseout="this.style.borderColor='#e5e7eb';this.style.color='#374151';">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Preview
          </button>
          <a href="/templates/template-surat-keterangan.docx" download
            style="flex:1;padding:8px;border:none;border-radius:9px;background:linear-gradient(135deg,#be185d,#ec4899);color:white;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:5px;text-decoration:none;"
            onclick="event.stopPropagation();"
            onmouseover="this.style.transform='translateY(-1px)';"
            onmouseout="this.style.transform='none';">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Unduh .docx
          </a>
        </div>
      </div>

    </div>

    <!-- PREVIEW PANEL -->
    <div id="previewPanel" style="display:none;background:white;border-radius:18px;padding:28px;box-shadow:0 8px 25px rgba(0,0,0,0.07);">

      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #f3f4f6;flex-wrap:wrap;gap:12px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div id="previewIcon" style="width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;"></div>
          <div>
            <div id="previewTitle" style="font-size:15px;font-weight:700;color:#111827;"></div>
            <div style="font-size:12px;color:#9ca3af;margin-top:1px;">Preview teks template</div>
          </div>
        </div>
        <div style="display:flex;gap:8px;align-items:center;">
          <a id="downloadBtn" href="#" download
            style="padding:9px 18px;border:none;border-radius:10px;background:linear-gradient(135deg,#4f46e5,#06b6d4);color:white;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:6px;text-decoration:none;"
            onmouseover="this.style.transform='translateY(-1px)';"
            onmouseout="this.style.transform='none';">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Unduh File .docx
          </a>
          <button onclick="document.getElementById('previewPanel').style.display='none'"
            style="padding:9px 14px;border:1.5px solid #e5e7eb;border-radius:10px;background:white;color:#6b7280;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:5px;"
            onmouseover="this.style.background='#f9fafb';"
            onmouseout="this.style.background='white';">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
            Tutup
          </button>
        </div>
      </div>

      <!-- Kertas surat -->
      <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:32px 36px;font-family:'Times New Roman',serif;">
        <div id="previewContent" style="white-space:pre-line;line-height:1.9;font-size:14px;color:#1e293b;"></div>
      </div>

    </div>

    <!-- EMPTY HINT (saat belum pilih) -->
    <div id="emptyHint" style="background:white;border-radius:18px;padding:48px 28px;box-shadow:0 8px 25px rgba(0,0,0,0.07);text-align:center;">
      <div style="display:flex;justify-content:center;margin-bottom:16px;">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <line x1="10" y1="9" x2="8" y2="9"/>
        </svg>
      </div>
      <div style="font-size:16px;font-weight:600;color:#374151;margin-bottom:6px;">Pilih template untuk melihat preview</div>
      <div style="font-size:13px;color:#9ca3af;">Klik salah satu kartu template di atas, lalu unduh file Word (.docx)</div>
    </div>

  </main>

  <footer style="text-align:center;padding:16px;font-size:13px;color:#94a3b8;border-top:1px solid #f1f5f9;">
    © 2026 ARSIPRO — Sistem Manajemen Arsip Surat
  </footer>

</div>

<script is:inline>
const userData = JSON.parse(localStorage.getItem("user") || "{}");
if (userData.nama) {
  document.getElementById("namaUser").textContent = userData.nama;
  document.getElementById("avatarInit").textContent = userData.nama[0]?.toUpperCase() || "D";
}

const templates = {
  tugas: {
    title: "Surat Tugas",
    file: "/templates/template-surat-tugas.docx",
    iconBg: "linear-gradient(135deg,#ede9fe,#ddd6fe)",
    iconColor: "#4f46e5",
    content: `INSTITUT SHANTI BHUANA
Jl. Bukit Karmel No. 1, Bengkayang, Kalimantan Barat
______________________________________________________

SURAT TUGAS
Nomor: 001/ST/ISB/2026

Yang bertanda tangan di bawah ini:

Nama        :  ......................................................................
Jabatan     :  Kepala Program Studi

Dengan ini memberikan tugas kepada:

Nama        :  ......................................................................
Jabatan     :  Dosen
Unit Kerja  :  Institut Shanti Bhuana

Untuk menghadiri / melaksanakan kegiatan:

Nama Kegiatan :  .................................................................
Hari/Tanggal  :  .................................................................
Tempat        :  .................................................................

Demikian surat tugas ini dibuat untuk dilaksanakan sebagaimana mestinya.

