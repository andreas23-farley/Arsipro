let activeCard = null;

window.showTemplate = function(type) {
  const t = templates[type];
  if (!t) return;

  // Reset semua card border
  ["tugas","undangan","rekomendasi","keterangan"].forEach(k => {
    const c = document.getElementById(`card-${k}`);
    if (c) { c.style.borderColor = "#f3f4f6"; c.style.transform = "none"; }
  });

  // Aktifkan card yang dipilih
  const card = document.getElementById(`card-${type}`);
  if (card) { card.style.borderColor = t.iconColor; card.style.transform = "translateY(-3px)"; }

  // Isi preview
  document.getElementById("previewTitle").textContent = t.title;
  document.getElementById("previewContent").textContent = t.content;
  document.getElementById("downloadBtn").href = t.file;
  document.getElementById("downloadBtn").setAttribute("download", `${t.title}.docx`);

  // Icon preview
  document.getElementById("previewIcon").style.background = t.iconBg;
  document.getElementById("previewIcon").innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="${t.iconColor}" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`;

  document.getElementById("emptyHint").style.display = "none";
  document.getElementById("previewPanel").style.display = "block";
  document.getElementById("previewPanel").scrollIntoView({ behavior: "smooth", block: "start" });
};

