---
const role = Astro.props.role || "Mahasiswa";
const currentPath = Astro.url.pathname;
const API_URL = import.meta.env.PUBLIC_API_URL;
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard Mahasiswa</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
</head>

<body>

<button class="menu-toggle" onclick="toggleSidebar()">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <line x1="3" y1="12" x2="21" y2="12"/>
    <line x1="3" y1="6" x2="21" y2="6"/>
    <line x1="3" y1="18" x2="21" y2="18"/>
  </svg>
</button>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<aside class="sidebar" id="sidebar">
  <div class="logo">
    <img src="/LOGO.jpg" class="logo-img" alt="Logo"/>
    <h2>ARSIPRO</h2>
    <span>Sistem Arsip Digital</span>
  </div>

  <nav>
    <a href="/mahasiswa/dashboard" class={currentPath === "/mahasiswa/dashboard" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Dashboard
    </a>
    <a href="/mahasiswa/surat" class={currentPath === "/mahasiswa/surat" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22 6 12 13 2 6"/>
      </svg>
      Surat Masuk
    </a>
    <a href="/mahasiswa/permintaan" class={currentPath === "/mahasiswa/permintaan" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
      Request Surat
    </a>
    <a href="/mahasiswa/template" class={currentPath === "/mahasiswa/template" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
      Template Surat
    </a>
    <a href="/mahasiswa/profil" class={currentPath === "/mahasiswa/profil" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      Profil
    </a>
  </nav>

  <div class="logout">
    <a href="/login" onclick="localStorage.clear()">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Logout
    </a>
  </div>
</aside>

<div class="main">

  <!-- NAVBAR -->
  <header class="navbar">
    <div>
      <div class="navbar-eyebrow">DASHBOARD</div>
      <div class="navbar-title">Panel Mahasiswa</div>
    </div>
    <div class="navbar-user">
      <div class="avatar" id="avatarInit">M</div>
      <div class="navbar-user-text">
        <div id="namaUser" class="navbar-user-name">Mahasiswa</div>
        <div class="navbar-user-role">Mahasiswa</div>
      </div>
    </div>
  </header>

  <main class="content">

    <!-- WELCOME BANNER -->
    <div class="welcome-banner">
      <div class="welcome-blob welcome-blob--1"></div>
      <div class="welcome-blob welcome-blob--2"></div>

      <div class="welcome-inner">
        <div>
          <div class="welcome-eyebrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            Dashboard Mahasiswa
          </div>
          <h2 class="welcome-title">Selamat Datang, <span id="welcomeName">Mahasiswa</span></h2>
          <p class="welcome-sub">Deum Amare Et Amatum Facere — Salam Amare</p>
        </div>
        <div class="welcome-account">
          <div class="welcome-account-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <div>
            <div class="welcome-account-label">Akun Aktif</div>
            <div id="welcomeName2" class="welcome-account-name">Mahasiswa</div>
          </div>
        </div>
      </div>
    </div>

    <!-- STAT CARDS -->
    <div class="stat-grid">

      <div class="stat-card stat-card--indigo">
        <div class="stat-card-icon stat-card-icon--indigo">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <div>
          <div id="statSuratMasuk" class="stat-card-value">0</div>
          <div class="stat-card-label">Surat Masuk</div>
        </div>
      </div>

      <div class="stat-card stat-card--cyan">
        <div class="stat-card-icon stat-card-icon--cyan">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0891b2" stroke-width="2">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </div>
        <div>
          <div id="statRequest" class="stat-card-value">0</div>
          <div class="stat-card-label">Request Surat</div>
        </div>
      </div>

      <div class="stat-card stat-card--green">
        <div class="stat-card-icon stat-card-icon--green">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <div>
          <div id="statDisetujui" class="stat-card-value">0</div>
          <div class="stat-card-label">Request Disetujui</div>
        </div>
      </div>

    </div>

    <!-- MENU FITUR -->
    <div class="menu-panel">

      <div class="menu-panel-header">
        <div class="menu-panel-icon">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
        </div>
        <div>
          <div class="menu-panel-title">Menu Fitur</div>
          <div class="menu-panel-sub">Akses cepat ke semua fitur</div>
        </div>
      </div>

      <div class="menu-grid">

        <a href="/mahasiswa/surat" class="menu-item menu-item--indigo">
          <div class="menu-item-icon menu-item-icon--indigo">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <div class="menu-item-title">Surat Masuk</div>
            <div class="menu-item-desc">Lihat surat dari admin</div>
          </div>
        </a>

        <a href="/mahasiswa/permintaan" class="menu-item menu-item--cyan">
          <div class="menu-item-icon menu-item-icon--cyan">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0891b2" stroke-width="2">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </div>
          <div>
            <div class="menu-item-title">Request Surat</div>
            <div class="menu-item-desc">Ajukan surat ke admin</div>
          </div>
        </a>

        <a href="/mahasiswa/template" class="menu-item menu-item--green">
          <div class="menu-item-icon menu-item-icon--green">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
          <div>
            <div class="menu-item-title">Template Surat</div>
            <div class="menu-item-desc">Unduh template resmi</div>
          </div>
        </a>

        <a href="/mahasiswa/profil" class="menu-item menu-item--amber">
          <div class="menu-item-icon menu-item-icon--amber">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <div>
            <div class="menu-item-title">Profil Saya</div>
            <div class="menu-item-desc">Lihat data akun</div>
          </div>
        </a>

        <a href="/mahasiswa/permintaan" class="menu-item menu-item--pink">
          <div class="menu-item-icon menu-item-icon--pink">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#db2777" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <div class="menu-item-title">Status Request</div>
            <div class="menu-item-desc">Cek status pengajuan</div>
          </div>
        </a>

        <a href="/login" onclick="localStorage.clear()" class="menu-item menu-item--danger">
          <div class="menu-item-icon menu-item-icon--danger">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/>
              <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
          </div>
          <div>
            <div class="menu-item-title menu-item-title--danger">Logout</div>
            <div class="menu-item-desc menu-item-desc--danger">Keluar dari akun</div>
          </div>
        </a>

      </div>

    </div>

  </main>

  <footer class="footer">
    © 2026 ARSIPRO — Sistem Manajemen Arsip Surat
  </footer>

</div>
<script is:inline define:vars={{ API_URL }}>
  window.__API_URL__ = API_URL;
</script>
<script is:inline>
const BASE_URL = window.__API_URL__;
const token = localStorage.getItem("token");
if (!token) window.location.href = "/login";

const userData = JSON.parse(localStorage.getItem("user") || "{}");
if (userData.nama) {
  const initial = userData.nama[0]?.toUpperCase() || "M";
  document.getElementById("namaUser").textContent    = userData.nama;
  document.getElementById("avatarInit").textContent  = initial;
  document.getElementById("welcomeName").textContent  = userData.nama;
  document.getElementById("welcomeName2").textContent = userData.nama;
}

async function loadStats() {
  try {
    const [resSurat, resRequest] = await Promise.all([
      fetch(`${BASE_URL}/api/surat-dosen/masuk`,                 { headers: { Authorization: `Bearer ${token}` } }),
      fetch(`${BASE_URL}/api/request-surat/${userData.id_user}`, { headers: { Authorization: `Bearer ${token}` } }),
    ]);

    const [dataSurat, dataRequest] = await Promise.all([
      resSurat.json(), resRequest.json()
    ]);

    const suratList   = Array.isArray(dataSurat)   ? dataSurat   : (dataSurat.data   || []);
    const requestList = Array.isArray(dataRequest)  ? dataRequest : (dataRequest.data || []);
    const disetujui   = requestList.filter(r => r.status === "disetujui");

    document.getElementById("statSuratMasuk").textContent = suratList.length;
    document.getElementById("statRequest").textContent    = requestList.length;
    document.getElementById("statDisetujui").textContent  = disetujui.length;
  } catch(e) { console.error(e); }
}

function toggleSidebar() {
  document.getElementById("sidebar").classList.toggle("active");
  document.getElementById("sidebarOverlay").classList.toggle("active");
}

loadStats();
</script>

</body>
</html>

<style>
* { margin:0; padding:0; box-sizing:border-box; font-family:'Plus Jakarta Sans', sans-serif; }
body { display:flex; background:#f1f5f9; min-height:100vh; }

/* ── MOBILE TOGGLE ── */
.menu-toggle {
  display:none; position:fixed; top:15px; left:15px; z-index:1002;
  background:#1e293b; color:white; border:none; padding:10px 12px; border-radius:8px; cursor:pointer;
}
.sidebar-overlay {
  display:none; position:fixed; inset:0; background:rgba(15,23,42,0.5);
  z-index:99; opacity:0; pointer-events:none; transition:opacity .2s;
}
.sidebar-overlay.active { opacity:1; pointer-events:auto; }

/* ── SIDEBAR ── */
.sidebar {
  width:250px; height:100vh; background:linear-gradient(180deg,#0f172a,#1e293b);
  color:white; padding:20px 15px; display:flex; flex-direction:column;
  position:fixed; top:0; left:0; transition:.3s; z-index:100; overflow-y:auto;
}
.logo { text-align:center; margin-bottom:28px; }
.logo-img { width:68px; height:68px; border-radius:50%; object-fit:cover; border:3px solid rgba(16,185,129,0.4); }
.logo h2 { font-size:18px; font-weight:800; letter-spacing:1px; margin-top:10px; }
.logo span { font-size:11px; color:#64748b; }
.sidebar nav { display:flex; flex-direction:column; gap:4px; flex:1; }
.sidebar nav a {
  display:flex; align-items:center; gap:10px; padding:11px 13px;
  color:#94a3b8; text-decoration:none; border-radius:10px; font-size:14px; font-weight:500; transition:all .2s;
}
.sidebar nav a.active, .sidebar nav a:hover {
  background:linear-gradient(135deg,#10b981,#06b6d4); color:white; transform:translateX(2px);
}
.logout { margin-top:auto; padding-top:12px; }
.logout a {
  display:flex; align-items:center; gap:10px;
  background:rgba(127,29,29,0.5); border:1px solid #7f1d1d;
  padding:11px 13px; border-radius:10px; color:#fca5a5; text-decoration:none; font-size:14px; font-weight:500; transition:.2s;
}
.logout a:hover { background:#7f1d1d; }

/* ── MAIN ── */
.main { margin-left:250px; width:calc(100% - 250px); display:flex; flex-direction:column; min-height:100vh; }
.navbar {
  background:white; padding:16px 28px; display:flex; justify-content:space-between; align-items:center;
  box-shadow:0 2px 10px rgba(0,0,0,.06); position:sticky; top:0; z-index:50;
}
.navbar-eyebrow { font-size:13px; color:#64748b; font-weight:500; }
.navbar-title { font-size:17px; font-weight:700; color:#0f172a; }
.navbar-user { display:flex; align-items:center; gap:12px; }
.avatar {
  width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,#10b981,#06b6d4);
  display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; flex-shrink:0;
}
.navbar-user-name { font-size:14px; font-weight:600; color:#0f172a; }
.navbar-user-role { font-size:11px; color:#64748b; }

.content { padding:28px; flex:1; }

/* ── WELCOME BANNER ── */
.welcome-banner {
  background:linear-gradient(135deg,#10b981,#06b6d4); border-radius:20px;
  padding:28px 32px; margin-bottom:24px; position:relative; overflow:hidden;
}
.welcome-blob { position:absolute; border-radius:50%; background:rgba(255,255,255,0.08); }
.welcome-blob--1 { top:-30px; right:-30px; width:140px; height:140px; }
.welcome-blob--2 { bottom:-40px; right:60px; width:100px; height:100px; background:rgba(255,255,255,0.05); }
.welcome-inner { position:relative; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px; }
.welcome-eyebrow { font-size:13px; color:rgba(255,255,255,0.75); font-weight:500; margin-bottom:6px; display:flex; align-items:center; gap:6px; }
.welcome-title { font-size:22px; font-weight:800; color:white; margin-bottom:6px; }
.welcome-sub { font-size:13px; color:rgba(255,255,255,0.8); }
.welcome-account {
  display:flex; align-items:center; gap:10px; background:rgba(255,255,255,0.15);
  padding:12px 16px; border-radius:14px; backdrop-filter:blur(6px);
}
.welcome-account-icon {
  width:40px; height:40px; border-radius:50%; background:rgba(255,255,255,0.25);
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.welcome-account-label { font-size:12px; color:rgba(255,255,255,0.7); }
.welcome-account-name { font-size:14px; font-weight:700; color:white; }

/* ── STAT CARDS ── */
.stat-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px; }
.stat-card {
  background:white; border-radius:18px; padding:20px; box-shadow:0 4px 20px rgba(0,0,0,0.07);
  border-left:4px solid transparent; display:flex; align-items:center; gap:14px; transition:all 0.2s;
}
.stat-card:hover { transform:translateY(-3px); }
.stat-card--indigo { border-left-color:#4f46e5; }
.stat-card--indigo:hover { box-shadow:0 8px 25px rgba(79,70,229,0.15); }
.stat-card--cyan { border-left-color:#06b6d4; }
.stat-card--cyan:hover { box-shadow:0 8px 25px rgba(6,182,212,0.15); }
.stat-card--green { border-left-color:#10b981; }
.stat-card--green:hover { box-shadow:0 8px 25px rgba(16,185,129,0.15); }
.stat-card-icon {
  width:48px; height:48px; border-radius:14px; display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.stat-card-icon--indigo { background:linear-gradient(135deg,#ede9fe,#ddd6fe); }
.stat-card-icon--cyan { background:linear-gradient(135deg,#cffafe,#a5f3fc); }
.stat-card-icon--green { background:linear-gradient(135deg,#d1fae5,#a7f3d0); }
.stat-card-value { font-size:28px; font-weight:800; color:#111827; line-height:1; }
.stat-card-label { font-size:13px; color:#6b7280; margin-top:2px; }

/* ── MENU FITUR ── */
.menu-panel { background:white; border-radius:18px; padding:24px; box-shadow:0 8px 25px rgba(0,0,0,0.07); }
.menu-panel-header {
  display:flex; align-items:center; gap:12px; margin-bottom:20px; padding-bottom:16px; border-bottom:1px solid #f3f4f6;
}
.menu-panel-icon {
  width:36px; height:36px; border-radius:10px; background:linear-gradient(135deg,#10b981,#06b6d4);
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.menu-panel-title { font-size:15px; font-weight:700; color:#111827; }
.menu-panel-sub { font-size:12px; color:#9ca3af; margin-top:1px; }

.menu-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
.menu-item {
  display:flex; align-items:center; gap:14px; padding:18px; background:#f8fafc;
  border-radius:14px; text-decoration:none; border:1.5px solid #f3f4f6; transition:all 0.2s;
}
.menu-item:hover { transform:translateY(-3px); }
.menu-item-icon { width:42px; height:42px; border-radius:12px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.menu-item-title { font-size:14px; font-weight:700; color:#111827; }
.menu-item-desc { font-size:12px; color:#6b7280; margin-top:2px; }

.menu-item--indigo:hover { border-color:#c7d2fe; box-shadow:0 8px 20px rgba(79,70,229,0.12); }
.menu-item-icon--indigo { background:linear-gradient(135deg,#ede9fe,#ddd6fe); }
.menu-item--cyan:hover { border-color:#a5f3fc; box-shadow:0 8px 20px rgba(6,182,212,0.12); }
.menu-item-icon--cyan { background:linear-gradient(135deg,#cffafe,#a5f3fc); }
.menu-item--green:hover { border-color:#a7f3d0; box-shadow:0 8px 20px rgba(16,185,129,0.12); }
.menu-item-icon--green { background:linear-gradient(135deg,#d1fae5,#a7f3d0); }
.menu-item--amber:hover { border-color:#fde68a; box-shadow:0 8px 20px rgba(245,158,11,0.12); }
