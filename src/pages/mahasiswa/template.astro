    file: "/templates/template-surat-pengantar-skripsi.docx",
    iconBg: "linear-gradient(135deg,#ede9fe,#ddd6fe)",
    iconColor: "#4f46e5",
    iconPath: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
