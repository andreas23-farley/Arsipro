window.showTemplate = function(type) {
  const t = templates[type];
  if (!t) return;

  ["magang","skripsi","aktif","beasiswa"].forEach(k => {
    const c = document.getElementById(`card-${k}`);
    if (c) { c.style.borderColor = "#f3f4f6"; c.style.transform = "none"; }
  });

  const card = document.getElementById(`card-${type}`);
  if (card) { card.style.borderColor = t.iconColor; card.style.transform = "translateY(-3px)"; }

  document.getElementById("previewTitle").textContent = t.title;
  document.getElementById("previewContent").textContent = t.content;
  document.getElementById("downloadBtn").href = t.file;
  document.getElementById("downloadBtn").setAttribute("download", `${t.title}.docx`);
  document.getElementById("previewIcon").style.background = t.iconBg;
  document.getElementById("previewIcon").innerHTML = t.iconPath;

  document.getElementById("emptyHint").style.display = "none";
  document.getElementById("previewPanel").classList.add("preview-panel--open");
  document.getElementById("previewPanel").scrollIntoView({ behavior:"smooth", block:"start" });
};

function toggleSidebar() {
  document.getElementById("sidebar").classList.toggle("active");
  document.getElementById("sidebarOverlay").classList.toggle("active");
}
</script>

</body>
</html>

<style>
* { margin:0; padding:0; box-sizing:border-box; font-family:'Plus Jakarta Sans', sans-serif; }
body { display:flex; background:#f1f5f9; min-height:100vh; }

/* ── MOBILE TOGGLE ── */
.menu-toggle {
  display:none; position:fixed; top:15px; left:15px; z-index:1002;
  background:#1e293b; color:white; border:none; padding:10px 12px; border-radius:8px; cursor:pointer;
}
.sidebar-overlay {
  display:none; position:fixed; inset:0; background:rgba(15,23,42,0.5);
  z-index:99; opacity:0; pointer-events:none; transition:opacity .2s;
}
.sidebar-overlay.active { opacity:1; pointer-events:auto; }

/* ── SIDEBAR ── */
.sidebar {
  width:250px; height:100vh; background:linear-gradient(180deg,#0f172a,#1e293b);
  color:white; padding:20px 15px; display:flex; flex-direction:column;
  position:fixed; top:0; left:0; transition:.3s; z-index:100; overflow-y:auto;
}
.logo { text-align:center; margin-bottom:28px; }
.logo-img { width:68px; height:68px; border-radius:50%; object-fit:cover; border:3px solid rgba(16,185,129,0.4); }
.logo h2 { font-size:18px; font-weight:800; letter-spacing:1px; margin-top:10px; }
.logo span { font-size:11px; color:#64748b; }
