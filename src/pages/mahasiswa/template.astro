---
const role = "Mahasiswa";
const currentPath = Astro.url.pathname;
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Template Surat Mahasiswa</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
</head>

<body>

<button class="menu-toggle" onclick="toggleSidebar()">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <line x1="3" y1="12" x2="21" y2="12"/>
    <line x1="3" y1="6" x2="21" y2="6"/>
    <line x1="3" y1="18" x2="21" y2="18"/>
  </svg>
</button>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<aside class="sidebar" id="sidebar">
  <div class="logo">
    <img src="/LOGO.jpg" class="logo-img"/>
    <h2>ARSIPRO</h2>
    <span>Sistem Arsip Digital</span>
  </div>

  <nav>
    <a href="/mahasiswa/dashboard" class={currentPath === "/mahasiswa/dashboard" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Dashboard
    </a>
    <a href="/mahasiswa/surat" class={currentPath === "/mahasiswa/surat" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22 6 12 13 2 6"/>
      </svg>
      Surat Masuk
    </a>
    <a href="/mahasiswa/permintaan" class={currentPath === "/mahasiswa/permintaan" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
      Request Surat
    </a>
    <a href="/mahasiswa/template" class={currentPath === "/mahasiswa/template" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
      Template Surat
    </a>
    <a href="/mahasiswa/profil" class={currentPath === "/mahasiswa/profil" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      Profil
    </a>
  </nav>

  <div class="logout">
    <a href="/login" onclick="localStorage.clear()">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Logout
    </a>
  </div>
</aside>

<div class="main">

  <!-- NAVBAR -->
  <header class="navbar">
    <div>
      <div class="navbar-eyebrow">DASHBOARD</div>
      <div class="navbar-title">Panel Mahasiswa</div>
    </div>
    <div class="navbar-user">
      <div class="avatar" id="avatarInit">M</div>
      <div>
        <div id="namaUser" class="navbar-user-name">{role}</div>
        <div class="navbar-user-role">Mahasiswa</div>
      </div>
    </div>
  </header>

  <main class="content">

    <!-- HEADER -->
    <div class="page-header">
      <h1>Template Surat</h1>
      <p>Pilih template surat akademik, lihat preview, lalu unduh file Word (.docx).</p>
    </div>

    <!-- TEMPLATE CARDS -->
    <div class="tmpl-grid">

      <!-- Pengantar Magang -->
      <div class="tmpl-card" onclick="showTemplate('magang')" id="card-magang">
        <div class="tmpl-icon" style="background:linear-gradient(135deg,#d1fae5,#a7f3d0);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          </svg>
        </div>
        <div>
          <div class="tmpl-title">Pengantar Magang</div>
          <div class="tmpl-desc">Template surat pengantar untuk mahasiswa yang akan melaksanakan magang atau PKL.</div>
        </div>
        <div class="tmpl-actions">
          <button class="btn-prev" onclick="event.stopPropagation();showTemplate('magang')">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Preview
          </button>
          <a href="/templates/template-surat-pengantar-magang.docx" download class="btn-dl" style="background:linear-gradient(135deg,#10b981,#06b6d4);" onclick="event.stopPropagation();">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Unduh .docx
          </a>
        </div>
      </div>

      <!-- Pengantar Skripsi -->
      <div class="tmpl-card" onclick="showTemplate('skripsi')" id="card-skripsi">
        <div class="tmpl-icon" style="background:linear-gradient(135deg,#ede9fe,#ddd6fe);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <div>
          <div class="tmpl-title">Pengantar Skripsi</div>
          <div class="tmpl-desc">Template surat pengantar penelitian atau pengajuan skripsi mahasiswa.</div>
        </div>
        <div class="tmpl-actions">
          <button class="btn-prev" onclick="event.stopPropagation();showTemplate('skripsi')">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Preview
          </button>
          <a href="/templates/template-surat-pengantar-skripsi.docx" download class="btn-dl" style="background:linear-gradient(135deg,#4f46e5,#06b6d4);" onclick="event.stopPropagation();">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Unduh .docx
          </a>
        </div>
      </div>

      <!-- Mahasiswa Aktif -->
      <div class="tmpl-card" onclick="showTemplate('aktif')" id="card-aktif">
        <div class="tmpl-icon" style="background:linear-gradient(135deg,#e0f2fe,#bae6fd);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0369a1" stroke-width="2">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
            <path d="M6 12v5c3 3 9 3 12 0v-5"/>
          </svg>
        </div>
        <div>
          <div class="tmpl-title">Mahasiswa Aktif</div>
          <div class="tmpl-desc">Template surat keterangan mahasiswa masih aktif kuliah di kampus.</div>
        </div>
        <div class="tmpl-actions">
          <button class="btn-prev" onclick="event.stopPropagation();showTemplate('aktif')">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Preview
          </button>
          <a href="/templates/template-surat-keterangan-aktif.docx" download class="btn-dl" style="background:linear-gradient(135deg,#0369a1,#06b6d4);" onclick="event.stopPropagation();">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Unduh .docx
          </a>
        </div>
      </div>

      <!-- Beasiswa -->
      <div class="tmpl-card" onclick="showTemplate('beasiswa')" id="card-beasiswa">
        <div class="tmpl-icon" style="background:linear-gradient(135deg,#fef9c3,#fde68a);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
            <circle cx="12" cy="8" r="6"/>
            <path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
          </svg>
        </div>
        <div>
          <div class="tmpl-title">Pengajuan Beasiswa</div>
          <div class="tmpl-desc">Template surat permohonan beasiswa untuk kebutuhan pendidikan mahasiswa.</div>
        </div>
        <div class="tmpl-actions">
          <button class="btn-prev" onclick="event.stopPropagation();showTemplate('beasiswa')">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Preview
          </button>
          <a href="/templates/template-surat-pengajuan-beasiswa.docx" download class="btn-dl" style="background:linear-gradient(135deg,#d97706,#f59e0b);" onclick="event.stopPropagation();">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Unduh .docx
          </a>
        </div>
      </div>

    </div>

    <!-- PREVIEW PANEL -->
    <div id="previewPanel" class="preview-panel">

      <div class="preview-header">
        <div class="preview-header-left">
          <div id="previewIcon" class="preview-icon"></div>
          <div>
            <div id="previewTitle" class="preview-title"></div>
            <div class="preview-sub">Preview teks template</div>
          </div>
        </div>
        <div class="preview-header-actions">
          <a id="downloadBtn" href="#" download class="preview-download-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Unduh File .docx
          </a>
          <button onclick="document.getElementById('previewPanel').classList.remove('preview-panel--open')" class="preview-close-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
            Tutup
          </button>
        </div>
      </div>

      <div class="preview-doc">
        <div id="previewContent" class="preview-doc-content"></div>
      </div>

    </div>

    <!-- EMPTY HINT -->
    <div id="emptyHint" class="empty-hint">
      <div style="display:flex;justify-content:center;margin-bottom:16px;">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <line x1="10" y1="9" x2="8" y2="9"/>
        </svg>
      </div>
      <div style="font-size:16px;font-weight:600;color:#374151;margin-bottom:6px;">Pilih template untuk melihat preview</div>
      <div style="font-size:13px;color:#9ca3af;">Klik salah satu kartu template di atas, lalu unduh file Word (.docx)</div>
    </div>

  </main>

  <footer class="footer">
    © 2026 ARSIPRO — Sistem Manajemen Arsip Surat
  </footer>

</div>

<script is:inline>
const userData = JSON.parse(localStorage.getItem("user") || "{}");
if (userData.nama) {
  document.getElementById("namaUser").textContent   = userData.nama;
  document.getElementById("avatarInit").textContent = userData.nama[0]?.toUpperCase() || "M";
}

const templates = {
  magang: {
    title: "Surat Pengantar Magang / PKL",
    file: "/templates/template-surat-pengantar-magang.docx",
    iconBg: "linear-gradient(135deg,#d1fae5,#a7f3d0)",
    iconColor: "#059669",
    iconPath: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
    content: `INSTITUT SHANTI BHUANA
