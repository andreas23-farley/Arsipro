    iconColor: "#d97706",
    iconPath: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>`,
    content: `INSTITUT SHANTI BHUANA
Jl. Bukit Karmel No. 1, Bengkayang, Kalimantan Barat
