---
const currentPath = Astro.url.pathname;
const API_URL = import.meta.env.PUBLIC_API_URL;
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profil Mahasiswa</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
</head>

<body>

<button class="menu-toggle" onclick="toggleSidebar()">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <line x1="3" y1="12" x2="21" y2="12"/>
    <line x1="3" y1="6" x2="21" y2="6"/>
    <line x1="3" y1="18" x2="21" y2="18"/>
  </svg>
</button>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<aside class="sidebar" id="sidebar">
  <div class="logo">
    <img src="/LOGO.jpg" class="logo-img"/>
    <h2>ARSIPRO</h2>
    <span>Sistem Arsip Digital</span>
  </div>

  <nav>
    <a href="/mahasiswa/dashboard" class={currentPath === "/mahasiswa/dashboard" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Dashboard
    </a>
    <a href="/mahasiswa/surat" class={currentPath === "/mahasiswa/surat" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22,6 12,13 2,6"/>
      </svg>
      Surat Masuk
    </a>
    <a href="/mahasiswa/permintaan" class={currentPath === "/mahasiswa/permintaan" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
      Request Surat
    </a>
    <a href="/mahasiswa/template" class={currentPath === "/mahasiswa/template" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
      Template Surat
    </a>
    <a href="/mahasiswa/profil" class={currentPath === "/mahasiswa/profil" ? "active" : ""}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      Profil
    </a>
  </nav>

  <div class="logout">
    <a href="/login" onclick="localStorage.clear()">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Logout
    </a>
  </div>
</aside>

<div class="main">

  <!-- NAVBAR -->
  <header class="navbar">
    <div>
      <div class="navbar-eyebrow">DASHBOARD</div>
      <div class="navbar-title">Panel Mahasiswa</div>
    </div>
    <div class="navbar-user">
      <div class="avatar" id="avatarInit">M</div>
      <div>
        <div id="namaUser" class="navbar-user-name">Mahasiswa</div>
        <div class="navbar-user-role">Mahasiswa</div>
      </div>
    </div>
  </header>

  <main class="content">

    <!-- HEADER -->
    <div class="page-header">
      <div>
        <h1>Profil Saya</h1>
        <p>Informasi akun dan data mahasiswa Anda.</p>
      </div>
      <button id="btnEditProfil" onclick="openEditModal()" class="btn-edit-profil">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
        Edit Profil
      </button>
    </div>

    <div class="profile-grid">

      <!-- PROFIL CARD KIRI -->
      <div class="profile-card">

        <div class="profile-avatar-wrap">
          <div id="avatarCircle" class="profile-avatar-circle">M</div>
          <img id="fotoProfile" src="" alt="" class="profile-avatar-img">
          <div class="profile-avatar-badge"></div>
        </div>

        <div class="profile-name" id="profileNama">—</div>
        <div class="profile-prodi" id="profileProdi">Mahasiswa</div>
        <div class="profile-institusi">Institut Shanti Bhuana</div>

        <div class="profile-divider"></div>

        <div class="profile-status-badge">
          <span class="status-dot"></span>
          Aktif
        </div>

        <div class="profile-mini-list">

          <div class="profile-mini-item">
            <div class="profile-mini-icon profile-mini-icon--green">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <div class="profile-mini-text">
              <div class="profile-mini-label">Role</div>
              <div id="profileRole" class="profile-mini-value">Mahasiswa</div>
            </div>
          </div>

          <div class="profile-mini-item">
            <div class="profile-mini-icon profile-mini-icon--cyan">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0891b2" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="profile-mini-text profile-mini-text--truncate">
              <div class="profile-mini-label">Email</div>
              <div id="profileEmail" class="profile-mini-value profile-mini-value--truncate">—</div>
            </div>
          </div>

        </div>

      </div>

      <!-- KANAN -->
      <div class="profile-right-col">

        <!-- Info Detail -->
        <div class="panel-card">

          <div class="panel-header">
            <div class="panel-header-icon panel-header-icon--green">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <div>
              <div class="panel-title">Informasi Akun</div>
              <div class="panel-sub">Data profil Anda di sistem Arsipro</div>
            </div>
          </div>

          <div class="info-grid">

            <div class="info-item">
              <div class="info-label">Nama Lengkap</div>
              <div id="detail_nama" class="info-value">—</div>
            </div>

            <div class="info-item">
              <div class="info-label">Email</div>
              <div id="detail_email" class="info-value info-value--truncate">—</div>
            </div>

            <div class="info-item">
              <div class="info-label">Program Studi</div>
              <div id="detail_jabatan" class="info-value">—</div>
            </div>

            <div class="info-item">
              <div class="info-label">NIM</div>
              <div id="detail_nomor_id" class="info-value">—</div>
            </div>

            <div class="info-item">
              <div class="info-label">Institusi</div>
              <div class="info-value">Institut Shanti Bhuana</div>
            </div>

            <div class="info-item">
              <div class="info-label">Status Akun</div>
              <div class="info-status-badge">
                <span class="status-dot"></span>
                Aktif
              </div>
            </div>

          </div>

        </div>

        <!-- Akses Cepat -->
        <div class="panel-card">

          <div class="panel-header">
            <div class="panel-header-icon panel-header-icon--indigo">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                <polyline points="9 11 12 14 22 4"/>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
              </svg>
            </div>
            <div>
              <div class="panel-title">Akses Cepat</div>
              <div class="panel-sub">Navigasi ke fitur utama</div>
            </div>
          </div>

          <div class="quick-grid">

            <a href="/mahasiswa/surat" class="quick-item quick-item--green">
              <div class="quick-item-icon quick-item-icon--green">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <span>Surat Masuk</span>
            </a>

            <a href="/mahasiswa/permintaan" class="quick-item quick-item--cyan">
              <div class="quick-item-icon quick-item-icon--cyan">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0891b2" stroke-width="2">
                  <line x1="22" y1="2" x2="11" y2="13"/>
                  <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
              </div>
              <span>Request Surat</span>
            </a>

            <a href="/mahasiswa/template" class="quick-item quick-item--indigo">
              <div class="quick-item-icon quick-item-icon--indigo">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
              </div>
              <span>Template</span>
            </a>

          </div>

        </div>

        <!-- Logout Card -->
        <div class="panel-card logout-card">
          <div>
            <div class="logout-card-title">Keluar dari Akun</div>
            <div class="logout-card-sub">Anda akan diarahkan kembali ke halaman login</div>
          </div>
          <a href="/login" onclick="localStorage.clear()" class="logout-card-btn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/>
              <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Logout
          </a>
        </div>

      </div>

    </div>

  </main>

  <footer class="footer">
    © 2026 ARSIPRO — Sistem Manajemen Arsip Surat
  </footer>

</div>

<!-- MODAL EDIT PROFIL -->
<div id="editModalOverlay" class="modal-overlay">
  <div class="modal-box">

    <div class="modal-header">
      <div>
        <div style="font-size:17px;font-weight:800;color:#111827;">Edit Profil</div>
        <div style="font-size:12px;color:#9ca3af;margin-top:2px;">Perbarui informasi akun Anda</div>
      </div>
      <button class="modal-close" onclick="closeEditModal()" type="button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <form id="formEditProfil" class="modal-body">

      <!-- Upload Foto -->
      <div class="form-photo-row">
        <div style="position:relative;width:80px;height:80px;flex-shrink:0;">
          <div id="editAvatarCircle"
            style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#10b981,#06b6d4);display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:800;color:white;">
            M
          </div>
          <img id="editFotoPreview" src="" alt=""
            style="display:none;width:80px;height:80px;border-radius:50%;object-fit:cover;position:absolute;top:0;left:0;">
        </div>
        <div>
          <label for="inputFoto" class="btn-upload-foto">Ganti Foto</label>
          <input type="file" id="inputFoto" name="foto" accept="image/*" style="display:none;" onchange="previewFoto(event)">
          <div style="font-size:11px;color:#9ca3af;margin-top:6px;">JPG/PNG, maks 2MB</div>
        </div>
      </div>

      <div class="form-group">
        <label for="inputNama">Nama Lengkap</label>
        <input type="text" id="inputNama" name="nama" required placeholder="Masukkan nama lengkap">
      </div>

      <div class="form-group">
        <label for="inputEmail">Email</label>
        <input type="email" id="inputEmail" name="email" disabled>
        <div style="font-size:11px;color:#9ca3af;margin-top:4px;">Email tidak dapat diubah</div>
      </div>

      <div class="form-group">
        <label for="inputJabatan">Program Studi</label>
        <input type="text" id="inputJabatan" name="jabatan" required placeholder="Cth: Teknik Informatika">
      </div>

      <div id="editSuccess" style="display:none;background:#f0fdf4;color:#166534;font-size:12px;font-weight:600;padding:10px 14px;border-radius:10px;border:1px solid #bbf7d0;">
        ✅ Profil berhasil diperbarui!
      </div>

      <div id="editError" class="form-error" style="display:none;"></div>

    </form>

    <div class="modal-footer">
      <button type="button" class="btn-cancel" onclick="closeEditModal()">Batal</button>
      <button type="button" id="btnSimpanProfil" class="btn-save" onclick="submitEditProfil()">Simpan Perubahan</button>
    </div>

  </div>
</div>

<script is:inline define:vars={{ API_URL }}>
  window.__API_URL__ = API_URL;
</script>

<script is:inline>
const API_BASE = window.__API_URL__;

const token = localStorage.getItem("token");
if (!token) window.location.href = "/login";

let userData = JSON.parse(localStorage.getItem("user") || "{}");

function renderProfil() {
  if (!userData.nama) return;
  const initial = userData.nama[0]?.toUpperCase() || "M";

  document.getElementById("namaUser").textContent     = userData.nama;
  document.getElementById("avatarInit").textContent   = initial;
  document.getElementById("avatarCircle").textContent = initial;

  document.getElementById("profileNama").textContent  = userData.nama;
  document.getElementById("profileProdi").textContent = userData.jabatan || "Mahasiswa";
  document.getElementById("profileRole").textContent  = userData.role    || "Mahasiswa";
  document.getElementById("profileEmail").textContent = userData.email   || "—";

  document.getElementById("detail_nama").textContent     = userData.nama;
  document.getElementById("detail_email").textContent    = userData.email    || "—";
  document.getElementById("detail_jabatan").textContent  = userData.jabatan  || "—";
  document.getElementById("detail_nomor_id").textContent = userData.nomor_id || "—";

  // Tampilkan foto jika ada
  const fotoEl      = document.getElementById("fotoProfile");
  const avatarCircle = document.getElementById("avatarCircle");
  if (userData.foto) {
    fotoEl.src = `${API_BASE}/uploads/${userData.foto}`;
    fotoEl.style.display    = "block";
    avatarCircle.style.display = "none";
  } else {
    fotoEl.style.display       = "none";
    avatarCircle.style.display = "flex";
  }
}
renderProfil();

function toggleSidebar() {
  document.getElementById("sidebar").classList.toggle("active");
  document.getElementById("sidebarOverlay").classList.toggle("active");
}

// ===== EDIT PROFIL MODAL =====
function openEditModal() {
  document.getElementById("inputNama").value    = userData.nama    || "";
  document.getElementById("inputEmail").value   = userData.email   || "";
  document.getElementById("inputJabatan").value = userData.jabatan || "";

  const editFoto   = document.getElementById("editFotoPreview");
  const editCircle = document.getElementById("editAvatarCircle");
  if (userData.foto) {
    editFoto.src           = `${API_BASE}/uploads/${userData.foto}`;
    editFoto.style.display = "block";
    editCircle.style.display = "none";
  } else {
    editFoto.style.display   = "none";
    editCircle.style.display = "flex";
    editCircle.textContent   = (userData.nama?.[0] || "M").toUpperCase();
  }

  document.getElementById("inputFoto").value        = "";
  document.getElementById("editError").style.display   = "none";
  document.getElementById("editSuccess").style.display = "none";
  document.getElementById("editModalOverlay").classList.add("active");
}

function closeEditModal() {
  document.getElementById("editModalOverlay").classList.remove("active");
}

function previewFoto(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function (e) {
    const editFoto = document.getElementById("editFotoPreview");
    editFoto.src           = e.target.result;
    editFoto.style.display = "block";
    document.getElementById("editAvatarCircle").style.display = "none";
  };
  reader.readAsDataURL(file);
}

async function submitEditProfil() {
  const nama       = document.getElementById("inputNama").value.trim();
  const jabatan    = document.getElementById("inputJabatan").value.trim();
  const fotoInput  = document.getElementById("inputFoto");
  const errorBox   = document.getElementById("editError");
  const successBox = document.getElementById("editSuccess");
  const btn        = document.getElementById("btnSimpanProfil");

  errorBox.style.display   = "none";
  successBox.style.display = "none";

  if (!nama || !jabatan) {
    errorBox.textContent   = "Nama dan program studi wajib diisi.";
    errorBox.style.display = "block";
    return;
  }

  btn.disabled    = true;
  btn.textContent = "Menyimpan...";

  try {
    // Kirim semua data (termasuk foto jika ada) ke satu endpoint
    const formData = new FormData();
    formData.append("nama", nama);
    formData.append("jabatan", jabatan);
    if (fotoInput.files[0]) {
      formData.append("foto", fotoInput.files[0]);
    }

    const res = await fetch(`${API_BASE}/api/mahasiswa/profil/update`, {
      method: "PUT",
      headers: {
        // ✅ JANGAN set Content-Type manual saat pakai FormData
        "Authorization": `Bearer ${token}`
      },
      body: formData
    });

    // Baca response sebagai text dulu untuk debug jika gagal parse JSON
    const rawText = await res.text();
    let result;
    try {
      result = JSON.parse(rawText);
    } catch {
      throw new Error(`Server error ${res.status}: Response bukan JSON. Cek endpoint backend.`);
    }

    if (!res.ok) {
      throw new Error(result.message || "Gagal menyimpan perubahan.");
    }

    // ✅ Backend updateProfilMahasiswa mengembalikan { message, user: {...} }
    userData = { ...userData, ...result.user };
    localStorage.setItem("user", JSON.stringify(userData));

    renderProfil();

    successBox.style.display = "block";
    setTimeout(() => closeEditModal(), 1500);

  } catch (err) {
    errorBox.textContent   = err.message || "Terjadi kesalahan saat menyimpan.";
    errorBox.style.display = "block";
  } finally {
    btn.disabled    = false;
    btn.textContent = "Simpan Perubahan";
  }
}
</script>

</body>
</html>

<style>
* { margin:0; padding:0; box-sizing:border-box; font-family:'Plus Jakarta Sans', sans-serif; }
body { display:flex; background:#f1f5f9; min-height:100vh; }

/* ── MOBILE TOGGLE ── */
.menu-toggle {
  display:none; position:fixed; top:15px; left:15px; z-index:1002;
  background:#1e293b; color:white; border:none; padding:10px 12px; border-radius:8px; cursor:pointer;
}
.sidebar-overlay {
  display:none; position:fixed; inset:0; background:rgba(15,23,42,0.5);
  z-index:99; opacity:0; pointer-events:none; transition:opacity .2s;
}
.sidebar-overlay.active { opacity:1; pointer-events:auto; }

/* ── SIDEBAR ── */
.sidebar {
  width:250px; height:100vh; background:linear-gradient(180deg,#0f172a,#1e293b);
  color:white; padding:20px 15px; display:flex; flex-direction:column;
  position:fixed; top:0; left:0; transition:.3s; z-index:100; overflow-y:auto;
}
.logo { text-align:center; margin-bottom:28px; }
.logo-img { width:68px; height:68px; border-radius:50%; object-fit:cover; border:3px solid rgba(16,185,129,0.4); }
.logo h2 { font-size:18px; font-weight:800; letter-spacing:1px; margin-top:10px; }
.logo span { font-size:11px; color:#64748b; }
.sidebar nav { display:flex; flex-direction:column; gap:4px; flex:1; }
.sidebar nav a {
  display:flex; align-items:center; gap:10px; padding:11px 13px;
  color:#94a3b8; text-decoration:none; border-radius:10px; font-size:14px; font-weight:500; transition:all .2s;
}
.sidebar nav a.active, .sidebar nav a:hover {
  background:linear-gradient(135deg,#10b981,#06b6d4); color:white; transform:translateX(2px);
}
.logout { margin-top:auto; padding-top:12px; }
.logout a {
  display:flex; align-items:center; gap:10px;
  background:rgba(127,29,29,0.5); border:1px solid #7f1d1d;
  padding:11px 13px; border-radius:10px; color:#fca5a5; text-decoration:none; font-size:14px; font-weight:500; transition:.2s;
}
.logout a:hover { background:#7f1d1d; }

/* ── MAIN / NAVBAR ── */
.main { margin-left:250px; width:calc(100% - 250px); display:flex; flex-direction:column; min-height:100vh; }
.navbar {
  background:white; padding:16px 28px; display:flex; justify-content:space-between; align-items:center;
