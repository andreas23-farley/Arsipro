---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout>

  <!-- Title tab -->
  <title>Dashboard Trash Surat Arsip</title>
<div style="display:flex;flex-direction:column;gap:22px;padding:4px 0;">

  <!-- HEADER -->
  <div>
    <h1 style="font-size:26px;font-weight:700;background:linear-gradient(135deg,#8b5cf6,#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0 0 4px;">Trash Arsip</h1>
    <p style="color:#6b7280;font-size:14px;margin:0;line-height:1.6;">File yang dihapus tersimpan di sini. Bisa direstore atau dihapus permanen.</p>
  </div>

  <!-- TAB NAVIGASI -->
  <div style="display:flex;gap:8px;flex-wrap:wrap;">
    <a href="/admin/trash-surat-masuk"
      style="padding:9px 18px;border-radius:999px;background:white;color:#6b7280;font-size:13px;font-weight:600;text-decoration:none;border:1.5px solid #e5e7eb;display:inline-flex;align-items:center;gap:7px;"
      onmouseover="this.style.borderColor='#8b5cf6';this.style.color='#8b5cf6';"
      onmouseout="this.style.borderColor='#e5e7eb';this.style.color='#6b7280';">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6 6l.86-.86a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      Surat Masuk
    </a>
    <a href="/admin/trash-surat-keluar"
      style="padding:9px 18px;border-radius:999px;background:white;color:#6b7280;font-size:13px;font-weight:600;text-decoration:none;border:1.5px solid #e5e7eb;display:inline-flex;align-items:center;gap:7px;"
      onmouseover="this.style.borderColor='#8b5cf6';this.style.color='#8b5cf6';"
      onmouseout="this.style.borderColor='#e5e7eb';this.style.color='#6b7280';">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
      Surat Keluar
    </a>
    <a href="/admin/trash-surat-arsip"
      style="padding:9px 18px;border-radius:999px;background:linear-gradient(135deg,#8b5cf6,#f59e0b);color:white;font-size:13px;font-weight:700;text-decoration:none;border:none;display:inline-flex;align-items:center;gap:7px;">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
      </svg>
      Arsip
    </a>
  </div>

  <!-- STATS -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;max-width:540px;">

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #8b5cf6;">
      <div style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;flex-shrink:0;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
          <path d="M10 11v6"/><path d="M14 11v6"/>
          <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
        </svg>
      </div>
      <div>
        <div id="statTotal" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Di Trash</div>
      </div>
    </div>

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #7c3aed;">
      <div style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;flex-shrink:0;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
      </div>
      <div>
        <div id="statKeputusan" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Keputusan</div>
      </div>
    </div>

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #ef4444;">
      <div style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;flex-shrink:0;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
      </div>
      <div>
        <div id="statPenting" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Penting</div>
      </div>
    </div>

  </div>

  <!-- FILTER -->
  <div style="background:white;padding:16px 20px;border-radius:18px;box-shadow:0 8px 25px rgba(0,0,0,0.07);display:flex;gap:12px;align-items:center;flex-wrap:wrap;">

    <div style="flex:2;min-width:180px;position:relative;display:inline-flex;align-items:center;">
      <span style="position:absolute;left:12px;pointer-events:none;display:flex;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </span>
      <input type="text" id="searchInput" placeholder="Cari nama surat..."
        style="width:100%;padding:9px 12px 9px 34px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:13px;font-family:inherit;box-sizing:border-box;"
        onfocus="this.style.borderColor='#8b5cf6';"
        onblur="this.style.borderColor='#e5e7eb';">
    </div>

    <select id="filterKategori"
      style="padding:9px 12px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:13px;font-family:inherit;background:white;"
      onfocus="this.style.borderColor='#8b5cf6';"
      onblur="this.style.borderColor='#e5e7eb';">
      <option value="">Semua Kategori</option>
      <option value="Keputusan">Keputusan</option>
      <option value="Undangan">Undangan</option>
      <option value="Penting">Penting</option>
    </select>

    <button id="btnHapusSemua"
      style="padding:9px 18px;border:none;border-radius:10px;background:#fee2e2;color:#dc2626;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;white-space:nowrap;display:inline-flex;align-items:center;gap:7px;"
      onmouseover="this.style.background='#dc2626';this.style.color='white';"
      onmouseout="this.style.background='#fee2e2';this.style.color='#dc2626';">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="3 6 5 6 21 6"/>
        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
        <path d="M10 11v6"/><path d="M14 11v6"/>
        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
      </svg>
      Hapus Semua Permanen
    </button>

  </div>

  <!-- TABLE -->
  <div style="background:white;padding:20px 24px;border-radius:18px;box-shadow:0 8px 25px rgba(0,0,0,0.07);">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px;">
      <h3 style="font-size:16px;font-weight:700;color:#111827;margin:0;">Arsip (Terhapus)</h3>
      <span id="jumlahTampil" style="font-size:12px;color:#9ca3af;">Menampilkan 0 data</span>
    </div>
    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;min-width:620px;">
        <thead>
          <tr style="background:#f9fafb;">
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">No</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Nama Surat</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Kategori</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Tahun</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;white-space:nowrap;">Dihapus</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Aksi</th>
          </tr>
        </thead>
        <tbody id="tableTrash">
          <tr><td colspan="6" style="text-align:center;padding:40px;color:#9ca3af;">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- Modal Hapus Permanen -->
<div id="modalHapus" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);backdrop-filter:blur(4px);align-items:center;justify-content:center;z-index:9999;">
  <div style="background:white;border-radius:22px;padding:36px 30px;max-width:400px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.2);">
    <div style="display:flex;justify-content:center;margin-bottom:16px;">
      <div style="width:64px;height:64px;border-radius:50%;background:#fef3c7;display:flex;align-items:center;justify-content:center;">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
      </div>
    </div>
    <h3 id="modalTitle" style="font-size:20px;font-weight:700;color:#111827;margin:0 0 8px;">Hapus Permanen?</h3>
    <p id="modalDesc" style="font-size:14px;color:#6b7280;margin:0 0 26px;line-height:1.6;">Data ini akan dihapus permanen dan tidak bisa dikembalikan.</p>
    <div style="display:flex;gap:12px;justify-content:center;">
      <button id="btnBatal"
        style="padding:11px 24px;border:1px solid #e5e7eb;border-radius:12px;background:white;color:#374151;cursor:pointer;font-size:14px;font-weight:600;font-family:inherit;"
        onmouseover="this.style.background='#f9fafb';"
        onmouseout="this.style.background='white';">Batal</button>
      <button id="btnKonfirm"
        style="padding:11px 24px;border:none;border-radius:12px;background:#dc2626;color:white;cursor:pointer;font-size:14px;font-weight:700;font-family:inherit;display:inline-flex;align-items:center;gap:8px;"
        onmouseover="this.style.background='#b91c1c';"
        onmouseout="this.style.background='#dc2626';">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
          <path d="M10 11v6"/><path d="M14 11v6"/>
          <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
        </svg>
        Ya, Hapus Permanen
      </button>
    </div>
  </div>
</div>

<script is:inline>
const BASE_URL = window.__API_URL__;
const token = localStorage.getItem("token");
if (!token) window.location.href = "/login";

let allData = [];
let pendingAction = null;

const KS = {
  Keputusan: { bg:"#ede9fe", color:"#6d28d9" },
  Undangan:  { bg:"#e0f2fe", color:"#0369a1" },
  Penting:   { bg:"#fee2e2", color:"#991b1b" },
};

// SVG strings for use inside innerHTML
const svgRestore = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg>`;
const svgTrash   = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>`;

async function loadTrash() {
  try {
    const res  = await fetch(`${BASE_URL}/api/arsip/trash`, { headers: { Authorization: `Bearer ${token}` } });
    allData = await res.json();
    document.getElementById("statTotal").textContent     = allData.length;
    document.getElementById("statKeputusan").textContent = allData.filter(a => a.kategori === "Keputusan").length;
    document.getElementById("statPenting").textContent   = allData.filter(a => a.kategori === "Penting").length;
    applyFilter();
  } catch(e) { console.error(e); }
}

function applyFilter() {
  const q  = document.getElementById("searchInput").value.toLowerCase();
  const kt = document.getElementById("filterKategori").value;
  const filtered = allData.filter(d =>
    (!q  || d.nama_surat?.toLowerCase().includes(q)) &&
    (!kt || d.kategori === kt)
  );
  renderTable(filtered);
}

function renderTable(data) {
  document.getElementById("jumlahTampil").textContent = `Menampilkan ${data.length} data`;
  const tbody = document.getElementById("tableTrash");
  if (!data || data.length === 0) {
    tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:40px;color:#9ca3af;">Trash arsip kosong</td></tr>`;
    return;
  }
  tbody.innerHTML = data.map((d, i) => {
    const s = KS[d.kategori] || { bg:"#f3f4f6", color:"#374151" };
    return `<tr>
      <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;color:#6b7280;">${i + 1}</td>
      <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;font-weight:600;color:#111827;">${d.nama_surat}</td>
      <td style="padding:13px 14px;border-bottom:1px solid #f3f4f6;">
        <span style="background:${s.bg};color:${s.color};padding:3px 10px;border-radius:20px;font-size:12px;font-weight:700;">${d.kategori}</span>
      </td>
      <td style="padding:13px 14px;font-size:13px;border-bottom:1px solid #f3f4f6;color:#6b7280;">${d.tahun || '-'}</td>
      <td style="padding:13px 14px;font-size:13px;border-bottom:1px solid #f3f4f6;color:#6b7280;white-space:nowrap;">${new Date(d.deleted_at).toLocaleDateString("id-ID",{day:"2-digit",month:"short",year:"numeric"})}</td>
      <td style="padding:13px 14px;border-bottom:1px solid #f3f4f6;">
        <div style="display:flex;gap:6px;">
          <button onclick="restore(${d.id_arsip})"
            style="border:none;border-radius:8px;padding:6px 12px;background:#dcfce7;color:#166534;cursor:pointer;font-size:12px;font-weight:700;font-family:inherit;display:inline-flex;align-items:center;gap:5px;"
            onmouseover="this.style.background='#16a34a';this.style.color='white';"
            onmouseout="this.style.background='#dcfce7';this.style.color='#166534';">
            ${svgRestore} Restore
          </button>
          <button onclick="hapusPermanent(${d.id_arsip})"
            style="border:none;border-radius:8px;padding:6px 12px;background:#fee2e2;color:#dc2626;cursor:pointer;font-size:12px;font-weight:700;font-family:inherit;display:inline-flex;align-items:center;gap:5px;"
            onmouseover="this.style.background='#dc2626';this.style.color='white';"
            onmouseout="this.style.background='#fee2e2';this.style.color='#dc2626';">
            ${svgTrash} Hapus
          </button>
        </div>
      </td>
    </tr>`;
  }).join("");
}

window.restore = async function(id) {
  try {
    const res = await fetch(`${BASE_URL}/api/arsip/restore/${id}`, {
      method: "PUT", headers: { Authorization: `Bearer ${token}` }
    });
    if (res.ok) loadTrash();
    else alert("Gagal restore");
  } catch { alert("Server error"); }
};

window.hapusPermanent = function(id) {
  pendingAction = { type:"single", id };
  document.getElementById("modalTitle").textContent = "Hapus Permanen?";
  document.getElementById("modalDesc").textContent  = "Arsip ini akan dihapus permanen dan tidak bisa dikembalikan sama sekali.";
  document.getElementById("modalHapus").style.display = "flex";
};

document.getElementById("btnHapusSemua").addEventListener("click", () => {
  if (allData.length === 0) return;
  pendingAction = { type:"all" };
  document.getElementById("modalTitle").textContent = "Hapus Semua Permanen?";
  document.getElementById("modalDesc").textContent  = `Semua ${allData.length} arsip di trash akan dihapus permanen.`;
  document.getElementById("modalHapus").style.display = "flex";
});

document.getElementById("btnBatal").addEventListener("click", () => {
  pendingAction = null;
  document.getElementById("modalHapus").style.display = "none";
});

document.getElementById("btnKonfirm").addEventListener("click", async () => {
  if (!pendingAction) return;
  try {
    if (pendingAction.type === "single") {
      await fetch(`${BASE_URL}/api/arsip/trash/${pendingAction.id}`, {
        method: "DELETE", headers: { Authorization: `Bearer ${token}` }
      });
    } else {
      await Promise.all(allData.map(d =>
        fetch(`${BASE_URL}/api/arsip/trash/${d.id_arsip}`, {
          method: "DELETE", headers: { Authorization: `Bearer ${token}` }
        })
      ));
    }
    document.getElementById("modalHapus").style.display = "none";
    pendingAction = null;
    loadTrash();
  } catch { alert("Server error"); }
});

document.getElementById("modalHapus").addEventListener("click", e => {
  if (e.target === document.getElementById("modalHapus")) {
    pendingAction = null;
    document.getElementById("modalHapus").style.display = "none";
  }
});

["searchInput","filterKategori"].forEach(id => {
  document.getElementById(id).addEventListener("input",  applyFilter);
  document.getElementById(id).addEventListener("change", applyFilter);
});

loadTrash();
</script>

</DashboardLayout>