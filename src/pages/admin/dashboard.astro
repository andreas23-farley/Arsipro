---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout>

<title>Dashboard Admin | ARSIPRO</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<div class="dash">

  <!-- HEADER -->
  <div class="dash-header">
    <span class="eyebrow">Sistem Kearsipan</span>
    <h1>Dashboard Admin</h1>
    <p>Selamat datang kembali di Sistem ARSIPRO ISB</p>
  </div>

  <!-- STAT CARDS -->
  <div class="stat-grid">

    <div class="stat-card stat-amber">
      <div class="stat-blob stat-blob--1"></div>
      <div class="stat-blob stat-blob--2"></div>
      <div class="stat-top">
        <div class="stat-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <span class="stat-label">Surat Masuk</span>
      </div>
      <div id="statSuratMasuk" class="stat-value">-</div>
      <div class="stat-caption">Total keseluruhan</div>
    </div>

    <div class="stat-card stat-forest">
      <div class="stat-blob stat-blob--1"></div>
      <div class="stat-blob stat-blob--2"></div>
      <div class="stat-top">
        <div class="stat-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
            <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </div>
        <span class="stat-label">Surat Keluar</span>
      </div>
      <div id="statSuratKeluar" class="stat-value">-</div>
      <div class="stat-caption">Total keseluruhan</div>
    </div>

    <div class="stat-card stat-plum">
      <div class="stat-blob stat-blob--1"></div>
      <div class="stat-blob stat-blob--2"></div>
      <div class="stat-top">
        <div class="stat-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
            <polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/>
          </svg>
        </div>
        <span class="stat-label">Arsip</span>
      </div>
      <div id="statArsip" class="stat-value">-</div>
      <div class="stat-caption">Dokumen tersimpan</div>
    </div>

    <div class="stat-card stat-rust">
      <div class="stat-blob stat-blob--1"></div>
      <div class="stat-blob stat-blob--2"></div>
      <div class="stat-top">
        <div class="stat-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
          </svg>
        </div>
        <span class="stat-label">Request Surat</span>
      </div>
      <div id="statRequest" class="stat-value">-</div>
      <div class="stat-caption">Menunggu proses</div>
    </div>

  </div>

  <!-- MENU FITUR -->
  <div class="menu-section">
    <h2>Menu Fitur</h2>
    <div class="menu-grid">

      <a href="" class="menu-card menu-amber">
        <div class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <div>
          <div class="menu-title">Surat Masuk</div>
          <div class="menu-desc">Kelola surat masuk dengan upload &amp; kategori</div>
        </div>
      </a>

      <a href="" class="menu-card menu-forest">
        <div class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </div>
        <div>
          <div class="menu-title">Surat Keluar</div>
          <div class="menu-desc">Buat dan distribusikan surat keluar</div>
        </div>
      </a>

      <a href="" class="menu-card menu-plum">
        <div class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/>
          </svg>
        </div>
        <div>
          <div class="menu-title">Arsip Digital</div>
          <div class="menu-desc">Simpan dokumen secara aman &amp; terstruktur</div>
        </div>
      </a>

      <a href="" class="menu-card menu-teal">
        <div class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <div>
          <div class="menu-title">Pengguna</div>
          <div class="menu-desc">Kelola akses admin &amp; dosen</div>
        </div>
      </a>

      <a href="" class="menu-card menu-rust">
        <div class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
          </svg>
        </div>
        <div>
          <div class="menu-title">Request Surat</div>
          <div class="menu-desc">Lihat dan kelola request surat dosen</div>
        </div>
      </a>

      <a href="" class="menu-card menu-slate">
        <div class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/>
          </svg>
        </div>
        <div>
          <div class="menu-title">Trash</div>
          <div class="menu-desc">Kelola file yang dihapus</div>
        </div>
      </a>

    </div>
  </div>

</div>

<style>
  .dash {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding: 4px 0 32px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* Header */
  .eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #b45309;
    margin-bottom: 6px;
  }
  .dash-header h1 {
    font-family: 'Fraunces', serif;
    font-size: 32px;
    font-weight: 600;
    color: #1c1410;
    margin: 0 0 6px;
    letter-spacing: -0.5px;
  }
  .dash-header p {
    color: #78716c;
    font-size: 14.5px;
    margin: 0;
  }

  /* Stat cards */
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .stat-card {
    border-radius: 18px;
    padding: 22px;
    color: white;
    position: relative;
    overflow: hidden;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .stat-blob { position: absolute; border-radius: 50%; background: rgba(255,255,255,0.08); }
  .stat-blob--1 { top: -20px; right: -20px; width: 80px; height: 80px; }
  .stat-blob--2 { bottom: -30px; right: 10px; width: 100px; height: 100px; background: rgba(255,255,255,0.05); }
  .stat-top { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; position: relative; }
  .stat-icon {
    width: 34px; height: 34px; border-radius: 10px;
    background: rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .stat-label { font-size: 13px; font-weight: 600; letter-spacing: 0.2px; opacity: 0.92; }
  .stat-value {
    font-family: 'Fraunces', serif;
    font-size: 36px; font-weight: 600;
    position: relative; line-height: 1;
  }
  .stat-caption { font-size: 11.5px; opacity: 0.75; margin-top: 8px; position: relative; }

  .stat-amber  { background: linear-gradient(135deg,#b45309,#d97706); box-shadow: 0 10px 25px rgba(180,83,9,0.28); }
  .stat-forest { background: linear-gradient(135deg,#166534,#16a34a); box-shadow: 0 10px 25px rgba(22,101,52,0.25); }
  .stat-plum   { background: linear-gradient(135deg,#6d28d9,#8b5cf6); box-shadow: 0 10px 25px rgba(109,40,217,0.25); }
  .stat-rust   { background: linear-gradient(135deg,#b91c1c,#ef4444); box-shadow: 0 10px 25px rgba(185,28,28,0.25); }

  /* Menu */
  .menu-section h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13.5px;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: #78716c;
    margin: 0 0 14px;
    padding-left: 2px;
  }
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .menu-card {
    background: white;
    padding: 24px;
    border-radius: 18px;
    box-shadow: 0 4px 20px rgba(28,20,16,0.06);
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
    gap: 16px;
    border: 1.5px solid #f1efec;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .menu-card:hover { transform: translateY(-4px); }
  .menu-icon {
    width: 48px; height: 48px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .menu-title { font-family: 'Fraunces', serif; font-size: 16px; font-weight: 600; color: #1c1410; margin-bottom: 3px; }
  .menu-desc { font-size: 12.5px; color: #78716c; line-height: 1.5; }

  .menu-amber  .menu-icon { background: linear-gradient(135deg,#fef3c7,#fde68a); color: #b45309; }
  .menu-amber:hover  { box-shadow: 0 12px 30px rgba(180,83,9,0.15); border-color: #fde68a; }
  .menu-forest .menu-icon { background: linear-gradient(135deg,#dcfce7,#bbf7d0); color: #166534; }
  .menu-forest:hover { box-shadow: 0 12px 30px rgba(22,101,52,0.15); border-color: #bbf7d0; }
  .menu-plum   .menu-icon { background: linear-gradient(135deg,#ede9fe,#ddd6fe); color: #6d28d9; }
  .menu-plum:hover   { box-shadow: 0 12px 30px rgba(109,40,217,0.15); border-color: #ddd6fe; }
  .menu-teal   .menu-icon { background: linear-gradient(135deg,#cffafe,#a5f3fc); color: #0e7490; }
  .menu-teal:hover   { box-shadow: 0 12px 30px rgba(14,116,144,0.15); border-color: #a5f3fc; }
  .menu-rust   .menu-icon { background: linear-gradient(135deg,#fee2e2,#fecaca); color: #b91c1c; }
  .menu-rust:hover   { box-shadow: 0 12px 30px rgba(185,28,28,0.15); border-color: #fecaca; }
  .menu-slate  .menu-icon { background: linear-gradient(135deg,#f3f4f6,#e5e7eb); color: #57534e; }
  .menu-slate:hover  { box-shadow: 0 12px 30px rgba(87,83,78,0.12); border-color: #e5e7eb; }

  @media (max-width: 1100px) {
    .stat-grid { grid-template-columns: repeat(2, 1fr); }
    .menu-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .stat-grid, .menu-grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
const BASE_URL = window.__API_URL__;
const token = localStorage.getItem("token");
if (!token) window.location.href = "/login";

// Helper: ambil jumlah dari berbagai kemungkinan struktur response
function getCount(data) {
  if (Array.isArray(data)) return data.length;
  if (typeof data === "object" && data !== null) {
    if (typeof data.total === "number") return data.total;
    if (Array.isArray(data.data)) return data.data.length;
    if (typeof data.count === "number") return data.count;
  }
  return 0;
}

async function safeFetch(url, token) {
  try {
    const res = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });
    if (!res.ok) return null;
    return await res.json();
  } catch(e) {
    return null;
  }
}

async function loadStats() {
  // Set loading state
  ["statSuratMasuk","statSuratKeluar","statArsip","statRequest"].forEach(id => {
    document.getElementById(id).textContent = "...";
  });

  const [dataSM, dataSK, dataArsip, dataReq] = await Promise.all([
    safeFetch(`${BASE_URL}/api/surat-masuk`,   token),
    safeFetch(`${BASE_URL}/api/surat-keluar`,  token),
    safeFetch(`${BASE_URL}/api/arsip`,         token),
    safeFetch(`${BASE_URL}/api/request-surat`, token),
  ]);

  document.getElementById("statSuratMasuk").textContent  = dataSM   !== null ? getCount(dataSM)   : "–";
  document.getElementById("statSuratKeluar").textContent = dataSK   !== null ? getCount(dataSK)   : "–";
  document.getElementById("statArsip").textContent       = dataArsip !== null ? getCount(dataArsip) : "–";
  document.getElementById("statRequest").textContent     = dataReq  !== null ? getCount(dataReq)  : "–";
}

loadStats();
</script>

</DashboardLayout>