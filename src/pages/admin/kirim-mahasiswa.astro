---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout>

  <!-- Title tab -->
  <title>Dashboard Kirim Surat ke Mahasiswa</title>
<div style="display:flex;flex-direction:column;gap:22px;padding:4px 0;">

  <!-- HEADER -->
  <div>
    <h1 style="font-size:26px;font-weight:700;background:linear-gradient(135deg,#10b981,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0 0 4px;">Kirim Surat ke Mahasiswa</h1>
    <p style="color:#6b7280;font-size:14px;margin:0;line-height:1.6;">Admin dapat mengirim surat atau pengumuman kepada mahasiswa.</p>
  </div>

  <!-- STATS -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;">

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #10b981;">
      <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#d1fae5,#a7f3d0);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </div>
      <div>
        <div id="statTotal" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Total Terkirim</div>
      </div>
    </div>

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #06b6d4;">
      <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#cffafe,#a5f3fc);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0891b2" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      <div>
        <div id="statBulan" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Bulan Ini</div>
      </div>
    </div>

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #6366f1;">
      <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#ede9fe,#ddd6fe);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
        </svg>
      </div>
      <div>
        <div id="statMahasiswa" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Jumlah Mahasiswa</div>
      </div>
    </div>

  </div>

  <!-- FORM -->
  <div style="background:white;padding:24px;border-radius:18px;box-shadow:0 8px 25px rgba(0,0,0,0.07);">

    <div style="display:flex;align-items:center;gap:12px;margin-bottom:22px;padding-bottom:16px;border-bottom:1px solid #f3f4f6;">
      <div style="width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#10b981,#06b6d4);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </div>
      <div>
        <div style="font-size:15px;font-weight:700;color:#111827;">Form Pengiriman Surat</div>
        <div style="font-size:12px;color:#9ca3af;margin-top:1px;">Isi semua field yang diperlukan</div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;"><span style="color:#ef4444;">*</span> Pilih Mahasiswa</label>
        <select id="mahasiswa"
          style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;background:white;width:100%;box-sizing:border-box;"
          onfocus="this.style.borderColor='#10b981';this.style.boxShadow='0 0 0 3px rgba(16,185,129,0.1)';"
          onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
          <option value="">-- Pilih Mahasiswa --</option>
        </select>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;"><span style="color:#ef4444;">*</span> Judul Surat</label>
        <input type="text" id="judul" placeholder="Masukkan judul surat"
          style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;width:100%;box-sizing:border-box;"
          onfocus="this.style.borderColor='#10b981';this.style.boxShadow='0 0 0 3px rgba(16,185,129,0.1)';"
          onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;"><span style="color:#ef4444;">*</span> Kategori Surat</label>
        <select id="kategori"
          style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;background:white;width:100%;box-sizing:border-box;"
          onfocus="this.style.borderColor='#10b981';this.style.boxShadow='0 0 0 3px rgba(16,185,129,0.1)';"
          onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
          <option value="">-- Pilih Kategori --</option>
          <option value="Surat Keterangan">Surat Keterangan</option>
          <option value="Surat Pengumuman">Surat Pengumuman</option>
          <option value="Surat Undangan">Surat Undangan</option>
          <option value="Surat Tugas">Surat Tugas</option>
        </select>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;">Upload File Surat</label>
        <label id="dropzone"
          style="padding:10px 14px;border-radius:10px;border:1.5px dashed #d1d5db;font-size:13px;font-family:inherit;width:100%;box-sizing:border-box;cursor:pointer;display:flex;align-items:center;gap:8px;color:#6b7280;background:#fafafa;"
          onmouseover="this.style.borderColor='#10b981';this.style.background='#f0fdf4';"
          onmouseout="this.style.borderColor='#d1d5db';this.style.background='#fafafa';">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
          </svg>
          <span id="fileLabel">Klik untuk pilih file</span>
          <input type="file" id="fileSurat" accept=".pdf,.doc,.docx" style="display:none;"
            onchange="document.getElementById('fileLabel').textContent = this.files[0]?.name || 'Klik untuk pilih file';">
        </label>
        <span style="font-size:11px;color:#9ca3af;">Maks 15MB - PDF, DOC, DOCX</span>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:20px;">
      <label style="font-size:12px;font-weight:600;color:#374151;">Isi / Deskripsi Surat</label>
      <textarea id="deskripsi" rows="5" placeholder="Masukkan isi surat atau deskripsi..."
        style="padding:12px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;resize:vertical;width:100%;box-sizing:border-box;line-height:1.7;"
        onfocus="this.style.borderColor='#10b981';this.style.boxShadow='0 0 0 3px rgba(16,185,129,0.1)';"
        onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';"></textarea>
    </div>

    <div style="display:flex;align-items:center;gap:12px;padding-top:16px;border-top:1px solid #f3f4f6;">
      <button id="btnKirim"
        style="padding:11px 26px;border:none;border-radius:10px;background:linear-gradient(135deg,#10b981,#06b6d4);color:white;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:8px;"
        onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 15px rgba(16,185,129,0.35)';"
        onmouseout="this.style.transform='none';this.style.boxShadow='none';">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
        Kirim Surat
      </button>
      <button id="btnResetForm"
        style="padding:11px 20px;border:1.5px solid #e5e7eb;border-radius:10px;background:white;color:#374151;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;"
        onmouseover="this.style.background='#f9fafb';"
        onmouseout="this.style.background='white';">
        Reset
      </button>
      <div id="formMsg" style="display:none;padding:10px 16px;border-radius:10px;font-size:13px;font-weight:600;"></div>
    </div>

  </div>

  <!-- RIWAYAT -->
  <div style="background:white;padding:20px 24px;border-radius:18px;box-shadow:0 8px 25px rgba(0,0,0,0.07);">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px;">
      <div>
        <h3 style="font-size:16px;font-weight:700;color:#111827;margin:0 0 2px;">Riwayat Surat Terkirim</h3>
        <span id="jumlahTampil" style="font-size:12px;color:#9ca3af;">Menampilkan 0 surat</span>
      </div>
      <div style="position:relative;">
        <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);display:flex;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <input type="text" id="searchInput" placeholder="Cari penerima, judul..."
          style="padding:8px 14px 8px 34px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:13px;font-family:inherit;width:220px;box-sizing:border-box;"
          onfocus="this.style.borderColor='#10b981';"
          onblur="this.style.borderColor='#e5e7eb';">
      </div>
    </div>

    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;min-width:680px;">
        <thead>
          <tr style="background:#f9fafb;">
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">No</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Penerima</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Judul Surat</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Kategori</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;white-space:nowrap;">Tanggal</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">File</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Aksi</th>
          </tr>
        </thead>
        <tbody id="riwayatBody">
          <tr><td colspan="7" style="text-align:center;padding:40px;color:#9ca3af;">Loading...</td></tr>
        </tbody>
      </table>
    </div>

  </div>

</div>

<!-- Modal Hapus -->
<div id="modalHapus" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);backdrop-filter:blur(4px);align-items:center;justify-content:center;z-index:9999;">
  <div style="background:white;border-radius:22px;padding:36px 30px;max-width:380px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.2);">
    <div style="display:flex;justify-content:center;margin-bottom:14px;">
      <div style="width:60px;height:60px;border-radius:50%;background:#fee2e2;display:flex;align-items:center;justify-content:center;">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2">
          <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/>
        </svg>
      </div>
    </div>
    <h3 style="font-size:20px;font-weight:700;color:#111827;margin:0 0 8px;">Hapus Surat?</h3>
    <p style="font-size:14px;color:#6b7280;margin:0 0 26px;line-height:1.6;">Surat ini akan dihapus permanen dari riwayat pengiriman.</p>
    <div style="display:flex;gap:12px;justify-content:center;">
      <button id="btnBatalHapus"
        style="padding:11px 24px;border:1px solid #e5e7eb;border-radius:12px;background:white;color:#374151;cursor:pointer;font-size:14px;font-weight:600;font-family:inherit;"
        onmouseover="this.style.background='#f9fafb';"
        onmouseout="this.style.background='white';">Batal</button>
      <button id="btnKonfirmHapus"
        style="padding:11px 24px;border:none;border-radius:12px;background:#dc2626;color:white;cursor:pointer;font-size:14px;font-weight:700;font-family:inherit;"
        onmouseover="this.style.background='#b91c1c';"
        onmouseout="this.style.background='#dc2626';">Ya, Hapus</button>
    </div>
  </div>
</div>

<script is:inline>
const BASE_URL = window.__API_URL__;
const token = localStorage.getItem("token");
if (!token) window.location.href = "/login";

let allRiwayat = [];
let hapusId = null;

async function loadMahasiswa() {
  try {
    const res  = await fetch(`${BASE_URL}/api/users`, { headers: { Authorization: `Bearer ${token}` } });
    const data = await res.json();
    const mahasiswa = data.filter(u => (u.role || "").toLowerCase() === "mahasiswa");
    const sel = document.getElementById("mahasiswa");
    mahasiswa.forEach(d => { sel.innerHTML += `<option value="${d.id_user}">${d.nama} (${d.jabatan || d.role})</option>`; });
    document.getElementById("statMahasiswa").textContent = mahasiswa.length;
  } catch(e) { console.error(e); }
}

async function loadRiwayat() {
  try {
    const res  = await fetch(`${BASE_URL}/api/surat-dosen?role_penerima=mahasiswa`, { headers: { Authorization: `Bearer ${token}` } });
    let data = await res.json();
    // filter kalau backend kirim semua: ambil yang penerimanya mahasiswa
    allRiwayat = Array.isArray(data) ? data.filter(s => (s.role_penerima || "mahasiswa").toLowerCase() === "mahasiswa") : [];
    const now = new Date();
    const bulanIni = allRiwayat.filter(s => {
      const d = new Date(s.created_at);
      return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
    });
    document.getElementById("statTotal").textContent = allRiwayat.length;
    document.getElementById("statBulan").textContent = bulanIni.length;
    applySearch();
  } catch(e) { console.error(e); }
}

function applySearch() {
  const q = document.getElementById("searchInput").value.toLowerCase();
  const filtered = allRiwayat.filter(s =>
    !q || s.nama_penerima?.toLowerCase().includes(q) || s.judul_surat?.toLowerCase().includes(q) || s.kategori?.toLowerCase().includes(q)
  );
  renderTable(filtered);
}

function renderTable(data) {
  document.getElementById("jumlahTampil").textContent = `Menampilkan ${data.length} surat`;
  const tbody = document.getElementById("riwayatBody");
  if (!data || data.length === 0) {
    tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:40px;color:#9ca3af;">Belum ada surat yang dikirim</td></tr>`;
    return;
  }
  tbody.innerHTML = data.map((s, i) => `
    <tr>
      <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;color:#6b7280;">${i + 1}</td>
      <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;font-weight:700;color:#111827;">${s.nama_penerima}</td>
      <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;font-weight:600;color:#1e293b;">${s.judul_surat}</td>
      <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;">
        <span style="background:#d1fae5;color:#065f46;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;">${s.kategori || '-'}</span>
      </td>
      <td style="padding:13px 14px;font-size:13px;border-bottom:1px solid #f3f4f6;color:#6b7280;white-space:nowrap;">${new Date(s.created_at).toLocaleDateString("id-ID",{day:"2-digit",month:"short",year:"numeric"})}</td>
      <td style="padding:13px 14px;border-bottom:1px solid #f3f4f6;">
        ${s.file_surat ? `
        <a href="${BASE_URL}/uploads/${s.file_surat}" target="_blank"
          style="display:inline-flex;align-items:center;gap:5px;background:#f3f4f6;color:#374151;padding:5px 12px;border-radius:8px;font-size:12px;font-weight:600;text-decoration:none;"
          onmouseover="this.style.background='#10b981';this.style.color='white';"
          onmouseout="this.style.background='#f3f4f6';this.style.color='#374151';">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Lihat
        </a>` : '<span style="font-size:12px;color:#9ca3af;">-</span>'}
      </td>
      <td style="padding:13px 14px;border-bottom:1px solid #f3f4f6;">
        <button onclick="bukaModalHapus(${s.id_surat})"
          style="border:none;border-radius:8px;padding:6px 12px;background:#fee2e2;color:#dc2626;cursor:pointer;font-size:12px;font-weight:600;font-family:inherit;display:inline-flex;align-items:center;gap:5px;"
          onmouseover="this.style.background='#dc2626';this.style.color='white';"
          onmouseout="this.style.background='#fee2e2';this.style.color='#dc2626';">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
          Hapus
        </button>
      </td>
    </tr>
  `).join("");
}

function showMsg(text, ok) {
  const el = document.getElementById("formMsg");
  el.textContent = text;
  el.style.background = ok ? "#dcfce7" : "#fee2e2";
  el.style.color = ok ? "#166534" : "#991b1b";
  el.style.display = "block";
  setTimeout(() => { el.style.display = "none"; }, 3500);
}

document.getElementById("btnKirim").addEventListener("click", async () => {
  const id_penerima = document.getElementById("mahasiswa").value;
  const judul_surat = document.getElementById("judul").value.trim();
  const kategori    = document.getElementById("kategori").value;
  const deskripsi   = document.getElementById("deskripsi").value.trim();
  const file        = document.getElementById("fileSurat").files[0];

  if (!id_penerima || !judul_surat || !kategori || !file) {
    showMsg("Mahasiswa, judul, kategori, dan file wajib diisi.", false);
    return;
  }

  const btn = document.getElementById("btnKirim");
  btn.disabled = true; btn.textContent = "Mengirim...";

  const formData = new FormData();
  formData.append("id_penerima", id_penerima);
  formData.append("judul_surat", judul_surat);
  formData.append("kategori",    kategori);
  formData.append("deskripsi",   deskripsi);
  formData.append("file_surat",  file);
  formData.append("role_penerima", "mahasiswa");

  try {
    const res  = await fetch(`${BASE_URL}/api/surat-dosen`, {
      method: "POST", headers: { Authorization: `Bearer ${token}` }, body: formData
    });
    const data = await res.json();
    if (res.ok) {
      showMsg("Surat berhasil dikirim!", true);
      ["mahasiswa","judul","kategori","deskripsi"].forEach(id => document.getElementById(id).value = "");
      document.getElementById("fileSurat").value = "";
      document.getElementById("fileLabel").textContent = "Klik untuk pilih file";
      loadRiwayat();
    } else { showMsg(data.message || "Gagal kirim surat.", false); }
  } catch { showMsg("Server error. Coba lagi.", false); }
  finally {
    btn.disabled = false;
    btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Kirim Surat`;
  }
});

document.getElementById("btnResetForm").addEventListener("click", () => {
  ["mahasiswa","judul","kategori","deskripsi"].forEach(id => document.getElementById(id).value = "");
  document.getElementById("fileSurat").value = "";
  document.getElementById("fileLabel").textContent = "Klik untuk pilih file";
  document.getElementById("formMsg").style.display = "none";
});

window.bukaModalHapus = function(id) {
  hapusId = id;
  document.getElementById("modalHapus").style.display = "flex";
};

document.getElementById("btnBatalHapus").addEventListener("click", () => {
  hapusId = null;
  document.getElementById("modalHapus").style.display = "none";
});

document.getElementById("btnKonfirmHapus").addEventListener("click", async () => {
  if (!hapusId) return;
  try {
    const res  = await fetch(`${BASE_URL}/api/surat-dosen/${hapusId}`, {
      method: "DELETE", headers: { Authorization: `Bearer ${token}` }
    });
    const data = await res.json();
    if (res.ok) {
      document.getElementById("modalHapus").style.display = "none";
      hapusId = null;
      loadRiwayat();
    } else { alert(data.message || "Gagal hapus surat"); }
  } catch { alert("Server error"); }
});

document.getElementById("modalHapus").addEventListener("click", e => {
  if (e.target === document.getElementById("modalHapus")) {
    hapusId = null;
    document.getElementById("modalHapus").style.display = "none";
  }
});

document.getElementById("searchInput").addEventListener("input", applySearch);

loadMahasiswa();
loadRiwayat();
</script>

</DashboardLayout>