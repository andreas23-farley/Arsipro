---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout>

  <!-- Title tab -->
  <title>Dashboard Surat Keluar</title>
<div style="display:flex;flex-direction:column;gap:22px;padding:4px 0;">

  <!-- HEADER -->
  <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">
    <div>
      <h1 style="font-size:26px;font-weight:700;background:linear-gradient(135deg,#4f46e5,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0 0 4px;">Input Surat Keluar</h1>
      <p style="color:#6b7280;font-size:14px;margin:0;line-height:1.6;">Buat dan kirim surat keluar baru.</p>
    </div>
    <a href="/admin/surat-keluar/tabel"
      style="display:inline-flex;align-items:center;gap:6px;padding:10px 18px;border-radius:10px;background:linear-gradient(135deg,#4f46e5,#06b6d4);color:white;font-size:13px;font-weight:700;text-decoration:none;"
      onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 15px rgba(79,70,229,0.35)';"
      onmouseout="this.style.transform='none';this.style.boxShadow='none';">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      Lihat Semua Surat
    </a>
  </div>

  <!-- STATS -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;">

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #4f46e5;">
      <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#ede9fe,#ddd6fe);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </div>
      <div>
        <div id="statTotal" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Total Surat Keluar</div>
      </div>
    </div>

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #06b6d4;">
      <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#cffafe,#a5f3fc);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0891b2" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      <div>
        <div id="statBulanIni" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Bulan Ini</div>
      </div>
    </div>

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #10b981;">
      <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#d1fae5,#a7f3d0);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
          <line x1="7" y1="7" x2="7.01" y2="7"/>
        </svg>
      </div>
      <div>
        <div id="statKategori" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Kategori</div>
      </div>
    </div>

  </div>

  <!-- FORM -->
  <div style="background:white;padding:24px;border-radius:18px;box-shadow:0 8px 25px rgba(0,0,0,0.07);">

    <div style="display:flex;align-items:center;gap:12px;margin-bottom:22px;padding-bottom:16px;border-bottom:1px solid #f3f4f6;">
      <div style="width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#4f46e5,#06b6d4);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </div>
      <div>
        <div style="font-size:15px;font-weight:700;color:#111827;">Form Surat Keluar</div>
        <div style="font-size:12px;color:#9ca3af;margin-top:1px;">Isi semua field yang diperlukan</div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;"><span style="color:#ef4444;">*</span> No Surat</label>
        <input type="text" id="no_surat" placeholder="Contoh: 001/KEL/VI/2025"
          style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;width:100%;box-sizing:border-box;"
          onfocus="this.style.borderColor='#4f46e5';this.style.boxShadow='0 0 0 3px rgba(79,70,229,0.1)';"
          onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;"><span style="color:#ef4444;">*</span> Nama Penerima</label>
        <input type="text" id="nama_penerima" placeholder="Masukkan nama penerima"
          style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;width:100%;box-sizing:border-box;"
          onfocus="this.style.borderColor='#4f46e5';this.style.boxShadow='0 0 0 3px rgba(79,70,229,0.1)';"
          onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;">
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;"><span style="color:#ef4444;">*</span> Kategori</label>
        <select id="id_kategori"
          style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;background:white;width:100%;box-sizing:border-box;"
          onfocus="this.style.borderColor='#4f46e5';this.style.boxShadow='0 0 0 3px rgba(79,70,229,0.1)';"
          onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
          <option value="">Pilih kategori</option>
        </select>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;">Upload Surat</label>
        <label id="dropzone"
          style="padding:10px 14px;border-radius:10px;border:1.5px dashed #d1d5db;font-size:13px;font-family:inherit;width:100%;box-sizing:border-box;cursor:pointer;display:flex;align-items:center;gap:8px;color:#6b7280;background:#fafafa;"
          onmouseover="this.style.borderColor='#4f46e5';this.style.background='#f5f3ff';"
          onmouseout="this.style.borderColor='#d1d5db';this.style.background='#fafafa';">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
          </svg>
          <span id="fileLabel">Klik untuk pilih file</span>
          <input type="file" id="file_surat" accept=".pdf,.doc,.docx" style="display:none;"
            onchange="document.getElementById('fileLabel').textContent = this.files[0]?.name || 'Klik untuk pilih file';">
        </label>
        <span style="font-size:11px;color:#9ca3af;">Maks 15MB - PDF, DOC, DOCX</span>
      </div>
    </div>

    <div style="display:flex;align-items:center;gap:12px;padding-top:16px;border-top:1px solid #f3f4f6;">
      <button id="btnSimpan"
        style="padding:11px 26px;border:none;border-radius:10px;background:linear-gradient(135deg,#4f46e5,#06b6d4);color:white;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:8px;"
        onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 15px rgba(79,70,229,0.35)';"
        onmouseout="this.style.transform='none';this.style.boxShadow='none';">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
        Input Surat
      </button>
      <button id="btnResetForm"
        style="padding:11px 20px;border:1.5px solid #e5e7eb;border-radius:10px;background:white;color:#374151;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;"
        onmouseover="this.style.background='#f9fafb';"
        onmouseout="this.style.background='white';">
        Reset
      </button>
      <div id="formMsg" style="display:none;padding:10px 16px;border-radius:10px;font-size:13px;font-weight:600;"></div>
    </div>

  </div>

  <!-- RECENT TABLE -->
  <div style="background:white;padding:20px 24px;border-radius:18px;box-shadow:0 8px 25px rgba(0,0,0,0.07);">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px;">
      <div>
        <h3 style="font-size:16px;font-weight:700;color:#111827;margin:0 0 2px;">Surat Keluar Terbaru</h3>
        <span style="font-size:12px;color:#9ca3af;">5 surat paling baru</span>
      </div>
      <a href="/admin/surat-keluar-tabel"
        style="font-size:13px;color:#4f46e5;text-decoration:none;font-weight:600;display:inline-flex;align-items:center;gap:5px;"
        onmouseover="this.style.textDecoration='underline';"
        onmouseout="this.style.textDecoration='none';">
        Lihat Semua
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;min-width:620px;">
        <thead>
          <tr style="background:#f9fafb;">
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">No</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">No Surat</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Nama Penerima</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Kategori</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;white-space:nowrap;">Tanggal</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">File</th>
          </tr>
        </thead>
        <tbody id="tableRecent">
          <tr><td colspan="6" style="text-align:center;padding:40px;color:#9ca3af;">Loading...</td></tr>
        </tbody>
      </table>
    </div>

  </div>

</div>

<script is:inline>
const BASE_URL = window.__API_URL__;
const token = localStorage.getItem("token");
if (!token) window.location.href = "/login";

let kategoriList = [];

async function loadKategori() {
  try {
    const res = await fetch(`${BASE_URL}/api/kategori`, { headers: { Authorization: `Bearer ${token}` } });
    kategoriList = await res.json();
    const sel = document.getElementById("id_kategori");
    kategoriList.forEach(k => { sel.innerHTML += `<option value="${k.id_kategori}">${k.nama_kategori}</option>`; });
    document.getElementById("statKategori").textContent = kategoriList.length;
  } catch(e) { console.error(e); }
}

async function loadRecent() {
  try {
    const res     = await fetch(`${BASE_URL}/api/surat-keluar`, { headers: { Authorization: `Bearer ${token}` } });
    const json    = await res.json();
    const allList = json.data || json;
    const list    = allList.slice(0, 5);

    const now = new Date();
    const bulanIni = allList.filter(s => {
      const d = new Date(s.created_at);
      return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
    });
    document.getElementById("statTotal").textContent    = allList.length;
    document.getElementById("statBulanIni").textContent = bulanIni.length;

    const tbody = document.getElementById("tableRecent");
    if (list.length === 0) {
      tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:40px;color:#9ca3af;">Belum ada surat keluar</td></tr>`;
      return;
    }

    tbody.innerHTML = list.map((s, i) => `
      <tr>
        <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;color:#6b7280;">${i + 1}</td>
        <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;">
          <span style="background:#ede9fe;color:#4f46e5;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;">${s.no_surat}</span>
        </td>
        <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;font-weight:600;color:#111827;">${s.nama_penerima}</td>
        <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;">
          <span style="background:#e0f2fe;color:#0369a1;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;">${s.nama_kategori ?? s.id_kategori}</span>
        </td>
        <td style="padding:13px 14px;font-size:13px;border-bottom:1px solid #f3f4f6;color:#6b7280;white-space:nowrap;">${new Date(s.created_at).toLocaleDateString("id-ID",{day:"2-digit",month:"short",year:"numeric"})}</td>
        <td style="padding:13px 14px;border-bottom:1px solid #f3f4f6;">
          <a href="${BASE_URL}/uploads/${s.file_surat}" target="_blank"
            style="display:inline-flex;align-items:center;gap:5px;background:#f3f4f6;color:#374151;padding:5px 12px;border-radius:8px;font-size:12px;font-weight:600;text-decoration:none;"
            onmouseover="this.style.background='#4f46e5';this.style.color='white';"
            onmouseout="this.style.background='#f3f4f6';this.style.color='#374151';">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Lihat
          </a>
        </td>
      </tr>
    `).join("");
  } catch(e) { console.error(e); }
}

function showMsg(text, ok) {
  const el = document.getElementById("formMsg");
  el.textContent = text;
  el.style.background = ok ? "#dcfce7" : "#fee2e2";
  el.style.color = ok ? "#166534" : "#991b1b";
  el.style.display = "block";
  setTimeout(() => { el.style.display = "none"; }, 3500);
}

document.getElementById("btnSimpan").addEventListener("click", async () => {
  const no_surat      = document.getElementById("no_surat").value.trim();
  const nama_penerima = document.getElementById("nama_penerima").value.trim();
  const id_kategori   = document.getElementById("id_kategori").value;
  const file          = document.getElementById("file_surat").files[0];

  if (!no_surat || !nama_penerima || !id_kategori) {
    showMsg("No surat, nama penerima, dan kategori wajib diisi.", false);
    return;
  }

  const btn = document.getElementById("btnSimpan");
  btn.disabled = true; btn.textContent = "Menyimpan...";

  const formData = new FormData();
  formData.append("no_surat", no_surat);
  formData.append("nama_penerima", nama_penerima);
  formData.append("id_kategori", id_kategori);
  if (file) formData.append("file_surat", file);

  try {
    const res = await fetch(`${BASE_URL}/api/surat-keluar`, {
      method: "POST", headers: { Authorization: `Bearer ${token}` }, body: formData
    });
    const data = await res.json();
    if (res.ok) {
      showMsg("Surat keluar berhasil ditambahkan!", true);
      document.getElementById("no_surat").value      = "";
      document.getElementById("nama_penerima").value = "";
      document.getElementById("id_kategori").value   = "";
      document.getElementById("file_surat").value    = "";
      document.getElementById("fileLabel").textContent = "Klik untuk pilih file";
      loadRecent();
    } else { showMsg(data.message || "Gagal menambahkan surat.", false); }
  } catch { showMsg("Server error. Coba lagi.", false); }
  finally {
    btn.disabled = false;
    btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Input Surat`;
  }
});

document.getElementById("btnResetForm").addEventListener("click", () => {
  document.getElementById("no_surat").value        = "";
  document.getElementById("nama_penerima").value   = "";
  document.getElementById("id_kategori").value     = "";
  document.getElementById("file_surat").value      = "";
  document.getElementById("fileLabel").textContent = "Klik untuk pilih file";
  document.getElementById("formMsg").style.display = "none";
});

loadKategori();
loadRecent();
</script>

</DashboardLayout>