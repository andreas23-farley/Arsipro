---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout>

  <!-- Title tab -->
  <title>Dashboard Upload Arsip</title>
<div style="display:flex;flex-direction:column;gap:22px;padding:4px 0;">

  <!-- HEADER -->
  <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">
    <div>
      <h1 style="font-size:26px;font-weight:700;background:linear-gradient(135deg,#8b5cf6,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0 0 4px;">Upload Arsip</h1>
      <p style="color:#6b7280;font-size:14px;margin:0;line-height:1.6;">Upload dan simpan dokumen arsip baru.</p>
    </div>
    <a href="/admin/arsip-tabel"
      style="display:inline-flex;align-items:center;gap:6px;padding:10px 18px;border-radius:10px;background:linear-gradient(135deg,#8b5cf6,#06b6d4);color:white;font-size:13px;font-weight:700;text-decoration:none;"
      onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 15px rgba(139,92,246,0.35)';"
      onmouseout="this.style.transform='none';this.style.boxShadow='none';">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      Lihat Semua Arsip
    </a>
  </div>

  <!-- STATS -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px;">

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #8b5cf6;">
      <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#ede9fe,#ddd6fe);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2">
          <polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/>
        </svg>
      </div>
      <div>
        <div id="statTotal" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Total Arsip</div>
      </div>
    </div>

    <!-- Kartu per kategori di-generate otomatis di sini -->
    <div id="statsKategori" style="display:contents;"></div>

  </div>

  <!-- FORM -->
  <div style="background:white;padding:24px;border-radius:18px;box-shadow:0 8px 25px rgba(0,0,0,0.07);">

    <div style="display:flex;align-items:center;gap:12px;margin-bottom:22px;padding-bottom:16px;border-bottom:1px solid #f3f4f6;">
      <div style="width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#8b5cf6,#06b6d4);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
      </div>
      <div>
        <div style="font-size:15px;font-weight:700;color:#111827;">Form Upload Arsip</div>
        <div style="font-size:12px;color:#9ca3af;margin-top:1px;">Isi semua field yang diperlukan</div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;"><span style="color:#ef4444;">*</span> Nama Surat</label>
        <input type="text" id="nama_surat" placeholder="Masukkan nama surat / dokumen"
          style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;width:100%;box-sizing:border-box;"
          onfocus="this.style.borderColor='#8b5cf6';this.style.boxShadow='0 0 0 3px rgba(139,92,246,0.1)';"
          onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;"><span style="color:#ef4444;">*</span> Kategori</label>
        <select id="kategori"
          style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;background:white;width:100%;box-sizing:border-box;"
          onfocus="this.style.borderColor='#8b5cf6';this.style.boxShadow='0 0 0 3px rgba(139,92,246,0.1)';"
          onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
          <option value="">Memuat kategori...</option>
        </select>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;">
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;"><span style="color:#ef4444;">*</span> Tanggal Dokumen</label>
        <input type="date" id="tanggal"
          style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;width:100%;box-sizing:border-box;"
          onfocus="this.style.borderColor='#8b5cf6';this.style.boxShadow='0 0 0 3px rgba(139,92,246,0.1)';"
          onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;">Upload File</label>
        <label id="dropzone"
          style="padding:10px 14px;border-radius:10px;border:1.5px dashed #d1d5db;font-size:13px;font-family:inherit;width:100%;box-sizing:border-box;cursor:pointer;display:flex;align-items:center;gap:8px;color:#6b7280;background:#fafafa;"
          onmouseover="this.style.borderColor='#8b5cf6';this.style.background='#f5f3ff';"
          onmouseout="this.style.borderColor='#d1d5db';this.style.background='#fafafa';">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
          </svg>
          <span id="fileLabel">Klik untuk pilih file</span>
          <input type="file" id="file_arsip" accept=".pdf,.doc,.docx" style="display:none;"
            onchange="document.getElementById('fileLabel').textContent = this.files[0]?.name || 'Klik untuk pilih file';">
        </label>
        <span style="font-size:11px;color:#9ca3af;">Maks 15MB - PDF, DOC, DOCX</span>
      </div>
    </div>

    <div style="display:flex;align-items:center;gap:12px;padding-top:16px;border-top:1px solid #f3f4f6;">
      <button id="btnSimpan"
        style="padding:11px 26px;border:none;border-radius:10px;background:linear-gradient(135deg,#8b5cf6,#06b6d4);color:white;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:8px;"
        onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 15px rgba(139,92,246,0.35)';"
        onmouseout="this.style.transform='none';this.style.boxShadow='none';">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
        </svg>
        Simpan Arsip
      </button>
      <button id="btnResetForm"
        style="padding:11px 20px;border:1.5px solid #e5e7eb;border-radius:10px;background:white;color:#374151;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;"
        onmouseover="this.style.background='#f9fafb';"
        onmouseout="this.style.background='white';">
        Reset
      </button>
      <div id="formMsg" style="display:none;padding:10px 16px;border-radius:10px;font-size:13px;font-weight:600;"></div>
    </div>

  </div>

  <!-- ARSIP TERBARU -->
  <div style="background:white;padding:20px 24px;border-radius:18px;box-shadow:0 8px 25px rgba(0,0,0,0.07);">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px;">
      <div>
        <h3 style="font-size:16px;font-weight:700;color:#111827;margin:0 0 2px;">Arsip Terbaru</h3>
        <span style="font-size:12px;color:#9ca3af;">5 dokumen paling baru</span>
      </div>
      <a href="/admin/arsip-tabel"
        style="font-size:13px;color:#8b5cf6;text-decoration:none;font-weight:600;display:inline-flex;align-items:center;gap:5px;"
        onmouseover="this.style.textDecoration='underline';"
        onmouseout="this.style.textDecoration='none';">
        Lihat Semua
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

    <div id="arsipRecent" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;">
      <p style="color:#9ca3af;text-align:center;grid-column:1/-1;">Loading...</p>
    </div>

  </div>

</div>

<script is:inline>
const BASE_URL = window.__API_URL__;
const token = localStorage.getItem("token");
if (!token) window.location.href = "/login";

// Palet warna yang dirotasi otomatis untuk tiap kategori,
// jadi berapa pun jumlah kategorinya (3, 7, 12...) tetap kebagian style.
const colorPalette = [
  { bg:"#ede9fe", color:"#6d28d9" }, // violet
  { bg:"#e0f2fe", color:"#0369a1" }, // sky
  { bg:"#fee2e2", color:"#991b1b" }, // red
  { bg:"#dcfce7", color:"#166534" }, // green
  { bg:"#fef3c7", color:"#92400e" }, // amber
  { bg:"#fce7f3", color:"#9d174d" }, // pink
  { bg:"#e0e7ff", color:"#3730a3" }, // indigo
  { bg:"#ccfbf1", color:"#0f766e" }, // teal
];

let kategoriList  = [];   // hasil fetch dari /api/kategori
let kategoriStyle = {};   // map nama_kategori -> {bg,color}

function escapeHtml(str) {
  if (!str) return "";
  return String(str).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;");
}

// ── Ambil daftar kategori dari API kategori, isi dropdown + siapkan style ──
async function loadKategoriOptions() {
  const select = document.getElementById("kategori");
  try {
    const res  = await fetch(`${BASE_URL}/api/kategori`, { headers: { Authorization: `Bearer ${token}` } });
    const data = await res.json();
    kategoriList = Array.isArray(data) ? data : (data.data || []);

    kategoriStyle = {};
    kategoriList.forEach((k, i) => {
      kategoriStyle[k.nama_kategori] = colorPalette[i % colorPalette.length];
    });

    if (kategoriList.length === 0) {
      select.innerHTML = `<option value="">Belum ada kategori, tambahkan dulu</option>`;
    } else {
      select.innerHTML = kategoriList
        .map(k => `<option value="${escapeHtml(k.nama_kategori)}">${escapeHtml(k.nama_kategori)}</option>`)
        .join("");
    }
  } catch (e) {
    console.error(e);
    select.innerHTML = `<option value="">Gagal memuat kategori</option>`;
  }
}

// ── Stats: total + 1 kartu per kategori, otomatis sebanyak apapun kategorinya ──
function renderStatsKategori(list) {
  const container = document.getElementById("statsKategori");
  if (kategoriList.length === 0) {
    container.innerHTML = "";
    return;
  }
  container.innerHTML = kategoriList.map(k => {
    const s     = kategoriStyle[k.nama_kategori] || { bg:"#f3f4f6", color:"#374151" };
    const count = list.filter(a => a.kategori === k.nama_kategori).length;
    return `
      <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid ${s.color};">
        <div style="width:42px;height:42px;border-radius:12px;background:${s.bg};display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="${s.color}" stroke-width="2">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
            <line x1="7" y1="7" x2="7.01" y2="7"/>
          </svg>
        </div>
        <div>
          <div style="font-size:24px;font-weight:700;color:#111827;">${count}</div>
          <div style="font-size:12px;color:#6b7280;margin-top:2px;">${escapeHtml(k.nama_kategori)}</div>
        </div>
      </div>
    `;
  }).join("");
}

async function loadStats() {
  try {
    const res  = await fetch(`${BASE_URL}/api/arsip`, { headers: { Authorization: `Bearer ${token}` } });
    const data = await res.json();
    const list = Array.isArray(data) ? data : (data.data || []);
    document.getElementById("statTotal").textContent = list.length;
    renderStatsKategori(list);
    renderRecent(list.slice(0, 5));
  } catch(e) { console.error(e); }
}

function renderRecent(data) {
  const container = document.getElementById("arsipRecent");
  if (!data || data.length === 0) {
    container.innerHTML = `<p style="color:#9ca3af;text-align:center;grid-column:1/-1;">Belum ada arsip</p>`;
    return;
  }
  container.innerHTML = data.map(a => {
    const s = kategoriStyle[a.kategori] || { bg:"#f3f4f6", color:"#374151" };
    return `
      <div style="background:#fafafa;border:1.5px solid #f3f4f6;border-radius:14px;padding:16px;display:flex;flex-direction:column;gap:8px;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
          <div style="font-size:14px;font-weight:700;color:#111827;line-height:1.4;flex:1;">${escapeHtml(a.nama_surat)}</div>
          <span style="background:${s.bg};color:${s.color};padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;white-space:nowrap;flex-shrink:0;">${escapeHtml(a.kategori)}</span>
        </div>
        <div style="font-size:12px;color:#6b7280;display:flex;align-items:center;gap:5px;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          ${new Date(a.tanggal).toLocaleDateString("id-ID",{day:"2-digit",month:"short",year:"numeric"})}
        </div>
        <a href="${BASE_URL}/uploads/${a.file_arsip}" target="_blank"
          style="display:inline-flex;align-items:center;gap:5px;background:#ede9fe;color:#6d28d9;padding:6px 12px;border-radius:8px;font-size:12px;font-weight:600;text-decoration:none;margin-top:2px;width:fit-content;"
          onmouseover="this.style.background='#8b5cf6';this.style.color='white';"
          onmouseout="this.style.background='#ede9fe';this.style.color='#6d28d9';">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Lihat File
        </a>
      </div>
    `;
  }).join("");
}

function showMsg(text, ok) {
  const el = document.getElementById("formMsg");
  el.textContent = text;
  el.style.background = ok ? "#dcfce7" : "#fee2e2";
  el.style.color = ok ? "#166534" : "#991b1b";
  el.style.display = "block";
  setTimeout(() => { el.style.display = "none"; }, 3500);
}

document.getElementById("btnSimpan").addEventListener("click", async () => {
  const nama_surat = document.getElementById("nama_surat").value.trim();
  const kategori   = document.getElementById("kategori").value;
  const tanggal    = document.getElementById("tanggal").value;
  const file       = document.getElementById("file_arsip").files[0];

  if (!kategori) {
    showMsg("Kategori belum tersedia. Tambahkan kategori terlebih dahulu.", false);
    return;
  }
  if (!nama_surat || !tanggal || !file) {
    showMsg("Nama surat, tanggal, dan file wajib diisi.", false);
    return;
  }

  const btn = document.getElementById("btnSimpan");
  btn.disabled = true; btn.textContent = "Menyimpan...";

  const formData = new FormData();
  formData.append("nama_surat", nama_surat);
  formData.append("kategori", kategori);
  formData.append("tanggal", tanggal);
  formData.append("file_arsip", file);

  try {
    const res  = await fetch(`${BASE_URL}/api/arsip`, {
      method: "POST", headers: { Authorization: `Bearer ${token}` }, body: formData
    });
    const data = await res.json();
    if (res.ok) {
      showMsg("Arsip berhasil disimpan!", true);
      document.getElementById("nama_surat").value = "";
      document.getElementById("tanggal").value    = "";
      document.getElementById("file_arsip").value = "";
      document.getElementById("fileLabel").textContent = "Klik untuk pilih file";
      loadStats();
    } else { showMsg(data.message || "Gagal simpan arsip.", false); }
  } catch { showMsg("Server error. Coba lagi.", false); }
  finally {
    btn.disabled = false;
    btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Simpan Arsip`;
  }
});

document.getElementById("btnResetForm").addEventListener("click", () => {
  document.getElementById("nama_surat").value = "";
  document.getElementById("tanggal").value    = "";
  document.getElementById("file_arsip").value = "";
  document.getElementById("fileLabel").textContent = "Klik untuk pilih file";
  document.getElementById("formMsg").style.display = "none";
});

// Urutan penting: kategori dulu (biar dropdown + style siap), baru stats/arsip.
(async function init() {
  await loadKategoriOptions();
  await loadStats();
})();
</script>

</DashboardLayout>