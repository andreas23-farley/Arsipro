---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout>

  <!-- Title tab -->
  <title>Dashboard Kategori Surat</title>
<div style="display:flex;flex-direction:column;gap:22px;padding:4px 0;">

  <!-- HEADER -->
  <div>
    <h1 style="font-size:26px;font-weight:700;background:linear-gradient(135deg,#4f46e5,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0 0 4px;">Kategori Surat</h1>
    <p style="color:#6b7280;font-size:14px;margin:0;line-height:1.6;">Kelola kategori surat masuk dan keluar.</p>
  </div>

  <!-- STATS -->
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:14px;max-width:440px;">

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #4f46e5;">
      <span style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;flex-shrink:0;">
        <!-- Tag icon -->
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
          <line x1="7" y1="7" x2="7.01" y2="7"/>
        </svg>
      </span>
      <div>
        <div id="statTotal" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Total Kategori</div>
      </div>
    </div>

    <div style="background:white;border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 15px rgba(0,0,0,0.06);border-left:4px solid #06b6d4;">
      <span style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;flex-shrink:0;">
        <!-- FileText icon -->
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
      </span>
      <div>
        <div id="statDeskripsi" style="font-size:24px;font-weight:700;color:#111827;">0</div>
        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Punya Deskripsi</div>
      </div>
    </div>

  </div>

  <!-- FORM -->
  <div style="background:white;padding:24px;border-radius:18px;box-shadow:0 8px 25px rgba(0,0,0,0.07);">

    <!-- Form Header -->
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:22px;padding-bottom:16px;border-bottom:1px solid #f3f4f6;">
      <div style="width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#4f46e5,#06b6d4);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
          <line x1="7" y1="7" x2="7.01" y2="7"/>
        </svg>
      </div>
      <div>
        <div style="font-size:15px;font-weight:700;color:#111827;">Tambah Kategori Baru</div>
        <div style="font-size:12px;color:#9ca3af;margin-top:1px;">Isi nama dan deskripsi kategori</div>
      </div>
    </div>

    <!-- Row -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">

      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;">
          <span style="color:#ef4444;">*</span> Nama Kategori
        </label>
        <input type="text" id="nama_kategori" placeholder="Contoh: Surat Tugas, Surat Undangan..."
          style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;width:100%;box-sizing:border-box;"
          onfocus="this.style.borderColor='#4f46e5';this.style.boxShadow='0 0 0 3px rgba(79,70,229,0.1)';"
          onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
      </div>

      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:12px;font-weight:600;color:#374151;">Deskripsi</label>
        <input type="text" id="deskripsi" placeholder="Deskripsi singkat kategori (opsional)"
          style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;width:100%;box-sizing:border-box;"
          onfocus="this.style.borderColor='#4f46e5';this.style.boxShadow='0 0 0 3px rgba(79,70,229,0.1)';"
          onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
      </div>

    </div>

    <!-- Actions -->
    <div style="display:flex;align-items:center;gap:12px;padding-top:16px;border-top:1px solid #f3f4f6;">
      <button id="btnSimpan"
        style="padding:11px 26px;border:none;border-radius:10px;background:linear-gradient(135deg,#4f46e5,#06b6d4);color:white;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:8px;"
        onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 15px rgba(79,70,229,0.35)';"
        onmouseout="this.style.transform='none';this.style.boxShadow='none';">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
        Simpan Kategori
      </button>
      <button id="btnReset"
        style="padding:11px 20px;border:1.5px solid #e5e7eb;border-radius:10px;background:white;color:#374151;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:8px;"
        onmouseover="this.style.background='#f9fafb';"
        onmouseout="this.style.background='white';">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="1 4 1 10 7 10"/>
          <path d="M3.51 15a9 9 0 1 0 .49-3.5"/>
        </svg>
        Reset
      </button>
      <div id="formMsg" style="display:none;padding:10px 16px;border-radius:10px;font-size:13px;font-weight:600;"></div>
    </div>

  </div>

  <!-- TABLE -->
  <div style="background:white;padding:20px 24px;border-radius:18px;box-shadow:0 8px 25px rgba(0,0,0,0.07);">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px;">
      <div>
        <h3 style="font-size:16px;font-weight:700;color:#111827;margin:0 0 2px;">Daftar Kategori</h3>
        <span id="jumlahTampil" style="font-size:12px;color:#9ca3af;">Menampilkan 0 kategori</span>
      </div>
      <div style="position:relative;display:inline-flex;align-items:center;">
        <span style="position:absolute;left:10px;pointer-events:none;display:flex;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </span>
        <input type="text" id="searchInput" placeholder="Cari kategori..."
          style="padding:8px 14px 8px 32px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:13px;font-family:inherit;width:200px;box-sizing:border-box;"
          onfocus="this.style.borderColor='#4f46e5';"
          onblur="this.style.borderColor='#e5e7eb';">
      </div>
    </div>

    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;min-width:520px;">
        <thead>
          <tr style="background:#f9fafb;">
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;width:50px;">No</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Nama Kategori</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;">Deskripsi</th>
            <th style="padding:12px 14px;text-align:left;font-size:13px;font-weight:700;color:#374151;border-bottom:2px solid #f0f0f0;width:140px;">Aksi</th>
          </tr>
        </thead>
        <tbody id="tableKategori">
          <tr><td colspan="4" style="text-align:center;padding:40px;color:#9ca3af;">Loading...</td></tr>
        </tbody>
      </table>
    </div>

  </div>

</div>

<!-- Modal Edit -->
<div id="modalOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);backdrop-filter:blur(4px);align-items:center;justify-content:center;z-index:9999;padding:20px;">
  <div style="background:white;border-radius:22px;padding:28px;max-width:460px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,0.2);">

    <!-- Modal Header -->
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:22px;padding-bottom:16px;border-bottom:1px solid #f3f4f6;">
      <div style="width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#4f46e5,#06b6d4);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
      </div>
      <div>
        <div style="font-size:15px;font-weight:700;color:#111827;">Edit Kategori</div>
        <div style="font-size:12px;color:#9ca3af;margin-top:1px;">Perbarui nama atau deskripsi</div>
      </div>
    </div>

    <input type="hidden" id="edit_id">

    <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:14px;">
      <label style="font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;">
        <span style="color:#ef4444;">*</span> Nama Kategori
      </label>
      <input type="text" id="edit_nama_kategori" placeholder="Masukkan nama kategori"
        style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;width:100%;box-sizing:border-box;"
        onfocus="this.style.borderColor='#4f46e5';this.style.boxShadow='0 0 0 3px rgba(79,70,229,0.1)';"
        onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
    </div>

    <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:22px;">
      <label style="font-size:12px;font-weight:600;color:#374151;">Deskripsi</label>
      <textarea id="edit_deskripsi" rows="3" placeholder="Masukkan deskripsi kategori"
        style="padding:10px 14px;border-radius:10px;border:1.5px solid #e5e7eb;outline:none;font-size:14px;font-family:inherit;resize:vertical;width:100%;box-sizing:border-box;line-height:1.6;"
        onfocus="this.style.borderColor='#4f46e5';this.style.boxShadow='0 0 0 3px rgba(79,70,229,0.1)';"
        onblur="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';"></textarea>
    </div>

    <div style="display:flex;gap:10px;justify-content:flex-end;padding-top:16px;border-top:1px solid #f3f4f6;">
      <button onclick="closeModal()"
        style="padding:10px 22px;border:1.5px solid #e5e7eb;border-radius:10px;background:white;color:#374151;cursor:pointer;font-size:14px;font-weight:600;font-family:inherit;"
        onmouseover="this.style.background='#f9fafb';"
        onmouseout="this.style.background='white';">
        Batal
      </button>
      <button onclick="submitEdit()"
        style="padding:10px 22px;border:none;border-radius:10px;background:linear-gradient(135deg,#4f46e5,#06b6d4);color:white;cursor:pointer;font-size:14px;font-weight:700;font-family:inherit;display:flex;align-items:center;gap:8px;"
        onmouseover="this.style.transform='translateY(-1px)';"
        onmouseout="this.style.transform='none';">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 21H5a2 2 0 0 0-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
        Simpan
      </button>
    </div>

  </div>
</div>

<script is:inline>
const BASE_URL = window.__API_URL__;
const token = localStorage.getItem("token");
if (!token) window.location.href = "/login";

let allData = [];

function escapeHtml(str) {
  if (!str) return "";
  return str.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;");
}

// SVG strings for use inside innerHTML
const svgEdit = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;
const svgTrash = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>`;

async function loadKategori() {
  try {
    const res  = await fetch(`${BASE_URL}/api/kategori`, { headers: { Authorization: `Bearer ${token}` } });
    allData = await res.json();

    document.getElementById("statTotal").textContent    = allData.length;
    document.getElementById("statDeskripsi").textContent = allData.filter(k => k.deskripsi && k.deskripsi.trim()).length;

    applySearch();
  } catch(e) { console.error(e); }
}

function applySearch() {
  const q = document.getElementById("searchInput").value.toLowerCase();
  const filtered = allData.filter(k =>
    !q ||
    k.nama_kategori?.toLowerCase().includes(q) ||
    k.deskripsi?.toLowerCase().includes(q)
  );
  renderTable(filtered);
}

function renderTable(data) {
  document.getElementById("jumlahTampil").textContent = `Menampilkan ${data.length} kategori`;
  const tbody = document.getElementById("tableKategori");

  if (!data || data.length === 0) {
    tbody.innerHTML = `<tr><td colspan="4" style="text-align:center;padding:40px;color:#9ca3af;">Belum ada kategori</td></tr>`;
    return;
  }

  tbody.innerHTML = data.map((k, i) => `
    <tr>
      <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;color:#6b7280;">${i + 1}</td>
      <td style="padding:13px 14px;font-size:14px;border-bottom:1px solid #f3f4f6;">
        <span style="background:#ede9fe;color:#4f46e5;padding:4px 12px;border-radius:20px;font-size:13px;font-weight:600;">${escapeHtml(k.nama_kategori)}</span>
      </td>
      <td style="padding:13px 14px;font-size:13px;border-bottom:1px solid #f3f4f6;color:#6b7280;">${escapeHtml(k.deskripsi) || '<span style="color:#d1d5db;">—</span>'}</td>
      <td style="padding:13px 14px;border-bottom:1px solid #f3f4f6;">
        <div style="display:flex;gap:6px;">
          <button onclick="openEdit(${k.id_kategori},'${escapeHtml(k.nama_kategori)}','${escapeHtml(k.deskripsi || '')}')"
            style="border:none;border-radius:8px;padding:6px 12px;background:#dcfce7;color:#166534;cursor:pointer;font-size:12px;font-weight:700;font-family:inherit;display:inline-flex;align-items:center;gap:5px;"
            onmouseover="this.style.background='#16a34a';this.style.color='white';"
            onmouseout="this.style.background='#dcfce7';this.style.color='#166534';">
            ${svgEdit} Edit
          </button>
          <button onclick="hapusKategori(${k.id_kategori})"
            style="border:none;border-radius:8px;padding:6px 12px;background:#fee2e2;color:#dc2626;cursor:pointer;font-size:12px;font-weight:700;font-family:inherit;display:inline-flex;align-items:center;gap:5px;"
            onmouseover="this.style.background='#dc2626';this.style.color='white';"
            onmouseout="this.style.background='#fee2e2';this.style.color='#dc2626';">
            ${svgTrash} Hapus
          </button>
        </div>
      </td>
    </tr>
  `).join("");
}

// ── FORM MSG ──
function showMsg(text, ok) {
  const el = document.getElementById("formMsg");
  el.textContent = text;
  el.style.background = ok ? "#dcfce7" : "#fee2e2";
  el.style.color      = ok ? "#166534" : "#991b1b";
  el.style.display    = "block";
  setTimeout(() => { el.style.display = "none"; }, 3500);
}

// ── SIMPAN ──
document.getElementById("btnSimpan").addEventListener("click", async () => {
  const nama_kategori = document.getElementById("nama_kategori").value.trim();
  const deskripsi     = document.getElementById("deskripsi").value.trim();

  if (!nama_kategori) {
    showMsg("Nama kategori wajib diisi.", false);
    return;
  }

  const btn = document.getElementById("btnSimpan");
  btn.disabled    = true;
  btn.textContent = "Menyimpan...";

  try {
    const res  = await fetch(`${BASE_URL}/api/kategori`, {
      method: "POST",
      headers: { Authorization: `Bearer ${token}`, "Content-Type": "application/json" },
      body: JSON.stringify({ nama_kategori, deskripsi })
    });
    const data = await res.json();
    if (res.ok) {
      showMsg("Kategori berhasil ditambahkan!", true);
      document.getElementById("nama_kategori").value = "";
      document.getElementById("deskripsi").value     = "";
      loadKategori();
    } else {
      showMsg(data.message || "Gagal menambahkan kategori.", false);
    }
  } catch {
    showMsg("Server error. Coba lagi.", false);
  } finally {
    btn.disabled = false;
    btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Simpan Kategori`;
  }
});

// ── RESET ──
document.getElementById("btnReset").addEventListener("click", () => {
  document.getElementById("nama_kategori").value = "";
  document.getElementById("deskripsi").value     = "";
  document.getElementById("formMsg").style.display = "none";
});

// ── SEARCH ──
document.getElementById("searchInput").addEventListener("input", applySearch);

// ── HAPUS ──
window.hapusKategori = function(id) {
  hapusPendingId = id;
  document.getElementById("modalHapus").style.display = "flex";
};

// ── EDIT ──
window.openEdit = function(id, nama, deskripsi) {
  document.getElementById("edit_id").value            = id;
  document.getElementById("edit_nama_kategori").value = nama;
  document.getElementById("edit_deskripsi").value     = deskripsi;
  document.getElementById("modalOverlay").style.display = "flex";
};

window.closeModal = function() {
  document.getElementById("modalOverlay").style.display = "none";
};

window.submitEdit = async function() {
  const id            = document.getElementById("edit_id").value;
  const nama_kategori = document.getElementById("edit_nama_kategori").value.trim();
  const deskripsi     = document.getElementById("edit_deskripsi").value.trim();

  if (!nama_kategori) { alert("Nama kategori wajib diisi."); return; }

  try {
    const res  = await fetch(`${BASE_URL}/api/kategori/${id}`, {
      method: "PUT",
      headers: { Authorization: `Bearer ${token}`, "Content-Type": "application/json" },
      body: JSON.stringify({ nama_kategori, deskripsi })
    });
    const data = await res.json();
    if (res.ok) {
      closeModal();
      loadKategori();
    } else {
      alert(data.message || "Gagal update kategori");
    }
  } catch { alert("Server error"); }
};

document.getElementById("modalOverlay").addEventListener("click", e => {
  if (e.target === document.getElementById("modalOverlay")) closeModal();
});

// ── MODAL HAPUS ──
let hapusPendingId = null;

loadKategori();
</script>

<!-- Modal Hapus -->
<div id="modalHapus" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);backdrop-filter:blur(4px);align-items:center;justify-content:center;z-index:9999;">
  <div style="background:white;border-radius:22px;padding:36px 30px;max-width:380px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.2);">
    <div style="display:flex;justify-content:center;margin-bottom:12px;">
      <div style="width:64px;height:64px;border-radius:50%;background:#fee2e2;display:flex;align-items:center;justify-content:center;">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
          <path d="M10 11v6"/><path d="M14 11v6"/>
          <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
        </svg>
      </div>
    </div>
    <h3 style="font-size:20px;font-weight:700;color:#111827;margin:0 0 8px;">Hapus Kategori?</h3>
    <p style="font-size:14px;color:#6b7280;margin:0 0 26px;line-height:1.6;">Kategori ini akan dihapus permanen. Pastikan tidak ada surat yang menggunakan kategori ini.</p>
    <div style="display:flex;gap:12px;justify-content:center;">
      <button id="btnBatalHapus"
        style="padding:11px 24px;border:1px solid #e5e7eb;border-radius:12px;background:white;color:#374151;cursor:pointer;font-size:14px;font-weight:600;font-family:inherit;"
        onmouseover="this.style.background='#f9fafb';"
        onmouseout="this.style.background='white';">
        Batal
      </button>
      <button id="btnKonfirmHapus"
        style="padding:11px 24px;border:none;border-radius:12px;background:#dc2626;color:white;cursor:pointer;font-size:14px;font-weight:700;font-family:inherit;display:inline-flex;align-items:center;gap:8px;"
        onmouseover="this.style.background='#b91c1c';"
        onmouseout="this.style.background='#dc2626';">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
          <path d="M10 11v6"/><path d="M14 11v6"/>
          <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
        </svg>
        Ya, Hapus
      </button>
    </div>
  </div>
</div>

<script is:inline>
document.getElementById("btnBatalHapus").addEventListener("click", () => {
  hapusPendingId = null;
  document.getElementById("modalHapus").style.display = "none";
});

document.getElementById("btnKonfirmHapus").addEventListener("click", async () => {
  if (!hapusPendingId) return;
  try {
    const res  = await fetch(`${BASE_URL}/api/kategori/${hapusPendingId}`, {
      method: "DELETE",
      headers: { Authorization: `Bearer ${token}` }
    });
    const data = await res.json();
    if (res.ok) {
      document.getElementById("modalHapus").style.display = "none";
      hapusPendingId = null;
      loadKategori();
    } else {
      alert(data.message || "Gagal hapus kategori");
    }
  } catch { alert("Server error"); }
});

document.getElementById("modalHapus").addEventListener("click", e => {
  if (e.target === document.getElementById("modalHapus")) {
    hapusPendingId = null;
    document.getElementById("modalHapus").style.display = "none";
  }
});
</script>

</DashboardLayout>