---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout>
  <!-- Title tab -->
  <title>Dashboard Profil Admin</title>
<div class="container">
  <div class="content">

    <h1 class="title">Profil Admin</h1>

    <!-- PROFILE CARD -->
    <div class="profile-card">
        <div class="profile-img">
          <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png" alt="Foto Profil" id="fotoProfile">
        </div>
      <div class="profile-info">
        <h2 id="profileNama">-</h2>
        <p id="profileJabatan">-</p>
        <p>Institut Shanti Bhuana</p>
      </div>
    </div>

    <!-- DETAIL -->
    <div class="profile-details">
      <div class="detail-box">
        <h4>Email</h4>
        <p id="profileEmail">-</p>
      </div>
      <div class="detail-box">
        <h4>Role</h4>
        <p id="profileRole">-</p>
      </div>
      <div class="detail-box">
        <h4>Jabatan</h4>
        <p id="profileJabatan2">-</p>
      </div>
      <div class="detail-box">
        <h4>Status</h4>
        <p style="color:#16a34a;font-weight:600">Aktif</p>
      </div>
    </div>

  </div>
</div>
<script is:inline>
const token = localStorage.getItem("token");

if (!token) {
    window.location.href = "/login";
}

const userData = JSON.parse(localStorage.getItem("user") || "{}");

if (userData.nama) {
    document.getElementById("profileNama").innerText = userData.nama;
    document.getElementById("profileEmail").innerText = userData.email || "-";
    document.getElementById("profileRole").innerText = userData.role || "-";
    document.getElementById("profileJabatan").innerText = userData.jabatan || "-";
    document.getElementById("profileJabatan2").innerText = userData.jabatan || "-";

    if (userData.foto) {
        document.getElementById("fotoProfile").src = `${window.__API_URL__}/uploads/${userData.foto}`;
    }
}
</script>
</DashboardLayout>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Plus Jakarta Sans', sans-serif;
}
.container {
  padding: 40px;
  display: flex;
  justify-content: center;
}
.content {
  width: 100%;
  max-width: 900px;
  text-align: center;
}
.title {
  font-size: 28px;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 25px;
}
.profile-card {
  background: white;
  border-radius: 20px;
  padding: 30px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}
.profile-img img {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  object-fit: cover;
  border: 4px solid #4f46e5;
  margin-bottom: 15px;
}
.profile-info h2 { font-size: 22px; color: #111827; }
.profile-info p { font-size: 14px; color: #6b7280; margin-top: 5px; }
.profile-details {
  margin-top: 30px;
  display: grid;
  grid-template-columns: repeat(2,1fr);
  gap: 20px;
}
.detail-box {
  background: white;
  padding: 20px;
  border-radius: 16px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.04);
  text-align: center;
}
.detail-box h4 { font-size: 13px; color: #6b7280; margin-bottom: 5px; }
.detail-box p { font-size: 15px; font-weight: 500; color: #111827; }
.back-wrapper { text-align: center; margin-top: 40px; }
.btn-back {
  display: inline-block;
  padding: 12px 24px;
  border-radius: 12px;
  background: linear-gradient(135deg,#0c0d0f,#334155);
  color: white;
  text-decoration: none;
  font-weight: 600;
  transition: 0.3s;
}
.btn-back:hover { transform: translateY(-2px); opacity: 0.9; }
@media (max-width: 768px) {
  .container { padding: 20px; }
  .profile-details { grid-template-columns: 1fr; }
}
</style>