  ---
  ---

  <!DOCTYPE html>
  <html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Login — ARSIPRO ISB</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>

    <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; font-family:'Plus Jakarta Sans',sans-serif; }

    body {
      min-height:100vh; background:#0e0a06;
      display:flex; align-items:center; justify-content:center;
      overflow:hidden; position:relative;
    }

    .bg-mesh {
      position:fixed; inset:0; z-index:0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 20%, rgba(180,83,9,0.30) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 80% 80%, rgba(120,53,15,0.25) 0%, transparent 55%),
        radial-gradient(ellipse 50% 40% at 55% 5%,  rgba(217,119,6,0.18) 0%, transparent 50%),
        linear-gradient(160deg, #0e0a06 0%, #1a1008 50%, #0f0b05 100%);
    }

    .stars { position:fixed; inset:0; z-index:0; overflow:hidden; }
    .star {
      position:absolute; background:#fde68a; border-radius:50%; opacity:0;
      animation:twinkle var(--d,4s) ease-in-out infinite var(--delay,0s);
    }
    @keyframes twinkle {
      0%,100% { opacity:0; transform:scale(0.8); }
      50%      { opacity:var(--op,0.5); transform:scale(1); }
    }

    .blob { position:fixed; border-radius:50%; filter:blur(90px); opacity:0.22; z-index:0; pointer-events:none; animation:blobFloat var(--bd,12s) ease-in-out infinite alternate; }
    .blob-1 { width:520px;height:520px;background:#92400e;top:-180px;left:-140px;--bd:10s; }
    .blob-2 { width:400px;height:400px;background:#b45309;bottom:-120px;right:-100px;--bd:14s; }
    .blob-3 { width:300px;height:300px;background:#d97706;top:35%;left:58%;--bd:17s;opacity:0.14; }
    @keyframes blobFloat {
      from { transform:translate(0,0) scale(1); }
      to   { transform:translate(24px,18px) scale(1.06); }
    }

    .wrapper { position:relative; z-index:10; width:100%; max-width:440px; padding:0 20px; animation:slideUp 0.8s cubic-bezier(.22,1,.36,1) both; }
    @keyframes slideUp { from{opacity:0;transform:translateY(40px);}to{opacity:1;transform:translateY(0);} }

    .card {
      background:rgba(255,255,255,0.035);
      backdrop-filter:blur(28px); -webkit-backdrop-filter:blur(28px);
      border:1px solid rgba(251,191,36,0.12);
      border-radius:35px; padding:30px 34px 26px;
      box-shadow: 0 0 0 1px rgba(255,255,255,0.03) inset, 0 40px 80px rgba(0,0,0,0.55), 0 0 70px rgba(180,83,9,0.10);
    }

    .card-header { text-align:center; margin-bottom:18px; }
    .logo-wrap   { display:flex; justify-content:center; margin-bottom:10px; }
    .logo-ring   { position:relative; width:64px; height:64px; }
    .logo-ring img { width:60px;height:60px;border-radius:50%;object-fit:cover;border:2px solid rgba(251,191,36,0.25);position:relative;z-index:1; }

    .logo-ring::before, .logo-ring::after {
      content:''; position:absolute; border-radius:50%; inset:-6px;
      border:1.5px solid transparent;
      background:linear-gradient(135deg,#d97706,#fbbf24,#92400e) border-box;
      -webkit-mask:linear-gradient(white,white) padding-box, linear-gradient(white,white);
      -webkit-mask-composite:destination-out; mask-composite:exclude;
      animation:spinRing 6s linear infinite;
    }
    .logo-ring::after { inset:-12px;border-width:1px;opacity:0.35;animation-duration:10s;animation-direction:reverse; }
    @keyframes spinRing { from{transform:rotate(0deg);}to{transform:rotate(360deg);} }

    .brand-name { font-size:22px;font-weight:800;color:white;letter-spacing:-0.5px;margin-bottom:3px; }
    .brand-name span { background:linear-gradient(135deg,#fbbf24,#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent; }
    .brand-sub  { font-size:12px;color:rgba(255,255,255,0.4);font-weight:500; }

    .ticker-wrap { overflow:hidden;margin:0 -6px 12px;mask-image:linear-gradient(90deg,transparent,black 15%,black 85%,transparent); }
    .ticker { display:flex;gap:40px;white-space:nowrap;animation:ticker 5s linear infinite; }
    .ticker span { font-size:11px;color:rgba(255,255,255,0.28);font-weight:500;flex-shrink:0; }
    .ticker-dot  { color:#d97706; }
    @keyframes ticker { from{transform:translateX(0);}to{transform:translateX(-50%);} }

    .divider { display:flex;align-items:center;gap:10px;margin-bottom:12px; }
    .divider-line { flex:1;height:1px;background:rgba(251,191,36,0.08); }
    .divider-text { font-size:11px;color:rgba(255,255,255,0.2);font-weight:600;letter-spacing:0.5px; }

    .form-group  { margin-bottom:10px;position:relative; }
    .form-label  { display:block;font-size:11.5px;font-weight:600;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:5px; }
    .input-wrap  { position:relative; }
    .input-icon  { position:absolute;left:14px;top:50%;transform:translateY(-50%);color:rgba(255,255,255,0.25);pointer-events:none;transition:color 0.2s;display:flex; }

    .form-input {
      width:100%;padding:11px 14px 11px 42px;
      background:rgba(255,255,255,0.05);
      border:1.5px solid rgba(251,191,36,0.10);
      border-radius:12px;color:white;font-size:14px;font-family:inherit;outline:none;transition:all 0.25s;
    }
    .form-input::placeholder { color:rgba(255,255,255,0.2); }
    .form-input:focus { background:rgba(255,255,255,0.08);border-color:rgba(217,119,6,0.55);box-shadow:0 0 0 3px rgba(180,83,9,0.18); }
    .form-group:focus-within .input-icon { color:rgba(217,119,6,0.8); }

    .toggle-pw { position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:rgba(255,255,255,0.25);cursor:pointer;padding:0;display:flex;transition:color 0.2s; }
    .toggle-pw:hover { color:rgba(255,255,255,0.65); }

    .error-msg { display:none;align-items:center;gap:8px;background:rgba(239,68,68,0.14);border:1px solid rgba(239,68,68,0.28);border-radius:10px;padding:9px 14px;font-size:13px;color:#fca5a5;margin-bottom:12px; }

    .form-input::-ms-reveal,
    .form-input::-ms-clear { display: none; }
    .form-input::-webkit-credentials-auto-fill-button,
    .form-input::-webkit-strong-password-auto-fill-button { display: none !important; visibility: hidden; pointer-events: none; }

    .btn-submit {
      width:100%;padding:12.5px;border:none;border-radius:13px;
      font-size:15px;font-weight:700;color:white;cursor:pointer;font-family:inherit;
      background:linear-gradient(135deg,#b45309,#a05a0b,#3a240b);
      position:relative;overflow:hidden;transition:all 0.25s;
      box-shadow:0 8px 28px rgba(180,83,9,0.45);
      display:flex;align-items:center;justify-content:center;gap:8px;margin-top:4px;
    }
    .btn-submit::before { content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.14),transparent);opacity:0;transition:opacity 0.2s; }
    .btn-submit:hover { transform:translateY(-2px);box-shadow:0 14px 36px rgba(180,83,9,0.55); }
    .btn-submit:hover::before { opacity:1; }
    .btn-submit:active { transform:translateY(0); }
    .btn-submit.loading { pointer-events:none;opacity:0.8; }

    .spinner { width:18px;height:18px;border:2.5px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;animation:spin 0.7s linear infinite;display:none; }
    .btn-text { transition:opacity 0.2s; }
    @keyframes spin { to{transform:rotate(360deg);} }

    .divider-mini { display:flex;align-items:center;gap:10px;margin:14px 0 10px; }
    .divider-mini-line { flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(251,191,36,0.14),transparent); }
    .divider-mini-text { font-size:10px;color:rgba(255,255,255,0.22);font-weight:700;letter-spacing:1.5px; }

    .btn-register-secondary {
      width:100%; padding:11px 16px; border-radius:13px;
      border:1.5px solid rgba(251,191,36,0.16);
      background:rgba(251,191,36,0.03);
      color:#fcd34d; font-size:13.5px; font-weight:700; font-family:inherit;
      text-decoration:none; cursor:pointer;
      display:flex; align-items:center; justify-content:center; gap:9px;
      position:relative; overflow:hidden;
      transition:border-color 0.3s, transform 0.3s cubic-bezier(.22,1,.36,1), box-shadow 0.3s;
    }
    .btn-register-secondary::before {
      content:''; position:absolute; inset:0; z-index:0;
      background:linear-gradient(135deg, rgba(251,191,36,0.14), rgba(217,119,6,0.05) 60%, transparent);
      opacity:0; transition:opacity 0.3s;
    }
    .btn-register-secondary::after {
      content:''; position:absolute; top:0; left:-60%; width:40%; height:100%;
      background:linear-gradient(120deg, transparent, rgba(255,255,255,0.10), transparent);
      transform:skewX(-20deg); transition:left 0.6s ease;
    }
    .btn-register-secondary:hover {
      border-color:rgba(251,191,36,0.5);
      transform:translateY(-2px);
      box-shadow:0 12px 30px rgba(180,83,9,0.28), 0 0 0 1px rgba(251,191,36,0.08) inset;
    }
    .btn-register-secondary:hover::before { opacity:1; }
    .btn-register-secondary:hover::after { left:130%; }
    .btn-register-secondary span,
    .btn-register-secondary svg { position:relative; z-index:1; }
    .btn-register-secondary .arrow-icon { transition:transform 0.3s; }
    .btn-register-secondary:hover .arrow-icon { transform:translateX(4px); }

    .card-footer { margin-top:14px;text-align:center; }
    .footer-notice { display:inline-flex;align-items:center;gap:7px;font-size:11.5px;color:rgba(255,255,255,0.25);line-height:1.5; }

    @media(max-width:480px) { .card{padding:26px 24px 22px;border-radius:22px;} .brand-name{font-size:20px;} }
    </style>
  </head>

  <body>

  <div class="bg-mesh"></div>
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
  <div class="stars" id="stars"></div>

  <div class="wrapper">
    <div class="card">

      <div class="card-header">
        <div class="logo-wrap">
          <div class="logo-ring">
            <img src="/LOGO.jpg" alt="Logo ARSIPRO"/>
          </div>
        </div>
        <div class="brand-name">ARSIPRO <span>ISB</span></div>
        <div class="brand-sub">Sistem Informasi Arsip Digital</div>
      </div>

      <div class="ticker-wrap">
        <div class="ticker">
          <span>Selamat Datang di ARSIPRO</span><span class="ticker-dot">•</span>
          <span>Salam Amare</span><span class="ticker-dot">•</span>
          <span>Deum Amare Et Amatum Facere</span><span class="ticker-dot">•</span>
          <span>Institut Shanti Bhuana</span><span class="ticker-dot">•</span>
          <span>Selamat Datang di ARSIPRO</span><span class="ticker-dot">•</span>
          <span>Salam Amare</span><span class="ticker-dot">•</span>
          <span>Deum Amare Et Amatum Facere</span><span class="ticker-dot">•</span>
          <span>Institut Shanti Bhuana</span><span class="ticker-dot">•</span>
        </div>
      </div>

      <div class="divider">
        <div class="divider-line"></div>
        <div class="divider-text">MASUK KE SISTEM</div>
        <div class="divider-line"></div>
      </div>

      <div class="error-msg" id="errorMsg">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span id="errorText">Username atau password salah.</span>
      </div>

      <form id="loginForm" autocomplete="off">

        <!-- ✅ DIGANTI: email → username -->
        <div class="form-group">
          <label class="form-label">Username</label>
          <div class="input-wrap">
            <span class="input-icon">
              <!-- Icon user -->
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </span>
            <input type="text" id="username" class="form-input" placeholder="Masukkan username" required autocomplete="username"/>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Password</label>
          <div class="input-wrap">
            <span class="input-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <input type="password" id="password" class="form-input" placeholder="Masukkan password" required autocomplete="current-password"/>
            <button type="button" class="toggle-pw" id="togglePw">
              <svg id="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <button type="submit" class="btn-submit" id="btnLogin">
          <div class="spinner" id="spinner"></div>
          <span class="btn-text" id="btnText">
            <span style="display:flex;align-items:center;gap:8px;">
              Masuk ke Sistem
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </span>
          </span>
        </button>

        <div class="divider-mini">
          <div class="divider-mini-line"></div>
          <div class="divider-mini-text">BELUM PUNYA AKUN?</div>
          <div class="divider-mini-line"></div>
        </div>

        <a href="/register" class="btn-register-secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <line x1="19" y1="8" x2="19" y2="14"/>
            <line x1="22" y1="11" x2="16" y2="11"/>
          </svg>
          <span>Buat Akun Baru</span>
          <svg class="arrow-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>

      </form>

      <div class="card-footer">
        <div class="footer-notice">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Akses terbatas — jaga kerahasiaan data Anda
        </div>
      </div>

    </div>
  </div>

  <script is:inline>
  const starsEl = document.getElementById("stars");
  for (let i = 0; i < 80; i++) {
    const s = document.createElement("div");
    s.className = "star";
    s.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*100}%;--d:${3+Math.random()*5}s;--delay:-${Math.random()*8}s;--op:${0.2+Math.random()*0.4};width:${Math.random()>0.7?3:2}px;height:${Math.random()>0.7?3:2}px;`;
    starsEl.appendChild(s);
  }

  const togglePw = document.getElementById("togglePw");
  const pwInput  = document.getElementById("password");
  const eyeIcon  = document.getElementById("eyeIcon");
  togglePw.addEventListener("click", () => {
    const isHidden = pwInput.type === "password";
    pwInput.type   = isHidden ? "text" : "password";
    eyeIcon.innerHTML = isHidden
      ? `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>`
      : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
  });

  const form    = document.getElementById("loginForm");
  const btn     = document.getElementById("btnLogin");
  const spinner = document.getElementById("spinner");
  const btnText = document.getElementById("btnText");
  const errMsg  = document.getElementById("errorMsg");
  const errText = document.getElementById("errorText");

  function setLoading(v) {
    btn.classList.toggle("loading",v);
    spinner.style.display  = v?"block":"none";
    btnText.style.opacity  = v?"0":"1";
    btnText.style.position = v?"absolute":"";
  }
  function showError(msg) { errText.textContent=msg; errMsg.style.display="flex"; }
  function hideError()    { errMsg.style.display="none"; }

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault(); hideError();

      // ✅ DIGANTI: ambil username, bukan email
      const username = document.getElementById("username").value.trim();
      const password = document.getElementById("password").value;

      if (!username || !password) { showError("Username dan password wajib diisi."); return; }
      setLoading(true);
      try {
        const res  = await fetch("http://100.85.49.78:3000/api/auth/login", {
          method:"POST", headers:{"Content-Type":"application/json"},
          // ✅ DIGANTI: kirim username, bukan email
          body: JSON.stringify({ username, password })
        });
        const data = await res.json();
        if (res.ok) {
          localStorage.setItem("token", data.token);
          localStorage.setItem("user", JSON.stringify(data.user));
          const role = data.user?.role;
          if      (role === "admin")     window.location.href = "/admin/dashboard";
          else if (role === "mahasiswa") window.location.href = "/mahasiswa/dashboard";
          else                           window.location.href = "/dosen/dashboard";
        } else {
          showError(data.message || "Username atau password salah.");
          setLoading(false);
        }
      } catch(err) {
        console.error(err);
        showError("Tidak dapat terhubung ke server. Coba lagi.");
        setLoading(false);
      }
    });
  }
  </script>

  </body>
  </html>