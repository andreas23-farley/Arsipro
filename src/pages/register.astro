---
const API_URL = import.meta.env.PUBLIC_API_URL;
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Daftar — ARSIPRO ISB</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>

  <style>
  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; font-family:'Plus Jakarta Sans',sans-serif; }

  body {
    min-height:100vh; background:#0e0a06;
    display:flex; align-items:center; justify-content:center;
    overflow-x:hidden; position:relative;
    padding:20px 0;
  }

  .bg-mesh {
    position:fixed; inset:0; z-index:0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 20%, rgba(180,83,9,0.30) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 80%, rgba(120,53,15,0.25) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 55% 5%,  rgba(217,119,6,0.18) 0%, transparent 50%),
      linear-gradient(160deg, #0e0a06 0%, #1a1008 50%, #0f0b05 100%);
  }

  .stars { position:fixed; inset:0; z-index:0; overflow:hidden; }
  .star {
    position:absolute; background:#fde68a; border-radius:50%; opacity:0;
    animation:twinkle var(--d,4s) ease-in-out infinite var(--delay,0s);
  }
  @keyframes twinkle {
    0%,100% { opacity:0; transform:scale(0.8); }
    50%      { opacity:var(--op,0.5); transform:scale(1); }
  }

  .blob { position:fixed; border-radius:50%; filter:blur(90px); opacity:0.22; z-index:0; pointer-events:none; animation:blobFloat var(--bd,12s) ease-in-out infinite alternate; }
  .blob-1 { width:520px;height:520px;background:#92400e;top:-180px;left:-140px;--bd:10s; }
  .blob-2 { width:400px;height:400px;background:#b45309;bottom:-120px;right:-100px;--bd:14s; }
  .blob-3 { width:300px;height:300px;background:#d97706;top:35%;left:58%;--bd:17s;opacity:0.14; }
  @keyframes blobFloat {
    from { transform:translate(0,0) scale(1); }
    to   { transform:translate(24px,18px) scale(1.06); }
  }

  .wrapper { position:relative; z-index:10; width:100%; max-width:480px; padding:0 20px; animation:slideUp 0.8s cubic-bezier(.22,1,.36,1) both; }
  @keyframes slideUp { from{opacity:0;transform:translateY(40px);}to{opacity:1;transform:translateY(0);} }

  .card {
    background:rgba(255,255,255,0.035);
    backdrop-filter:blur(28px); -webkit-backdrop-filter:blur(28px);
    border:1px solid rgba(251,191,36,0.12);
    border-radius:18px; padding: 30px 40px 34px;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.03) inset, 0 40px 80px rgba(0,0,0,0.55), 0 0 70px rgba(180,83,9,0.10);
  }

  .card-header { text-align:center; margin-bottom:20px; }
  .logo-wrap   { display:flex; justify-content:center; margin-bottom:16px; }
  .logo-ring   { position:relative; width:80px; height:80px; }
  .logo-ring img { width:76px;height:76px;border-radius:50%;object-fit:cover;border:2px solid rgba(251,191,36,0.25);position:relative;z-index:1; }

  .logo-ring::before, .logo-ring::after {
    content:''; position:absolute; border-radius:50%; inset:-6px;
    border:1.5px solid transparent;
    background:linear-gradient(135deg,#d97706,#fbbf24,#92400e) border-box;
    -webkit-mask:linear-gradient(white,white) padding-box, linear-gradient(white,white);
    -webkit-mask-composite:destination-out; mask-composite:exclude;
    animation:spinRing 6s linear infinite;
  }
  .logo-ring::after { inset:-12px;border-width:1px;opacity:0.35;animation-duration:10s;animation-direction:reverse; }
  @keyframes spinRing { from{transform:rotate(0deg);}to{transform:rotate(360deg);} }

  .brand-name { font-size:26px;font-weight:800;color:white;letter-spacing:-0.5px;margin-bottom:4px; }
  .brand-name span { background:linear-gradient(135deg,#fbbf24,#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent; }
  .brand-sub  { font-size:13px;color:rgba(255,255,255,0.4);font-weight:500; }

  .divider { display:flex;align-items:center;gap:10px;margin-bottom:18px; }
  .divider-line { flex:1;height:1px;background:rgba(251,191,36,0.08); }
  .divider-text { font-size:11px;color:rgba(255,255,255,0.2);font-weight:600;letter-spacing:0.5px; }

  .form-group  { margin-bottom:14px;position:relative; }
  .form-label  { display:block;font-size:11px;font-weight:600;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:6px; }
  .input-wrap  { position:relative; }
  .input-icon  { position:absolute;left:14px;top:50%;transform:translateY(-50%);color:rgba(255,255,255,0.25);pointer-events:none;transition:color 0.2s;display:flex; }

  .form-input, .form-select {
    width:100%;padding:13px 15px 13px 42px;
    background:rgba(255,255,255,0.05);
    border:1.5px solid rgba(251,191,36,0.10);
    border-radius:12px;color:white;font-size:14px;font-family:inherit;outline:none;transition:all 0.25s;
    appearance:none;
  }
  .form-input::placeholder { color:rgba(255,255,255,0.2); }
  .form-input:focus, .form-select:focus { background:rgba(255,255,255,0.08);border-color:rgba(217,119,6,0.55);box-shadow:0 0 0 3px rgba(180,83,9,0.18); }
  .form-group:focus-within .input-icon { color:rgba(217,119,6,0.8); }

  .form-select { padding-right:38px; cursor:pointer; }
  .form-select option { background:#1a1008; color:white; }
  .select-arrow {
    position:absolute; right:14px; top:50%; transform:translateY(-50%);
    color:rgba(255,255,255,0.3); pointer-events:none; display:flex;
  }

  .form-row { display:flex; gap:14px; }
  .form-row .form-group { flex:1; min-width:0; }

  .toggle-pw { position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:rgba(255,255,255,0.25);cursor:pointer;padding:0;display:flex;transition:color 0.2s; }
  .toggle-pw:hover { color:rgba(255,255,255,0.65); }

  .error-msg, .success-msg { display:none;align-items:center;gap:8px;border-radius:12px;padding:9px 14px;font-size:13px;margin-bottom:12px; }
  .error-msg   { background:rgba(239,68,68,0.14);border:1px solid rgba(239,68,68,0.28);color:#fca5a5; }
  .success-msg { background:rgba(34,197,94,0.14);border:1px solid rgba(34,197,94,0.28);color:#86efac; }

  .form-input::-ms-reveal, .form-input::-ms-clear { display:none; }
  .form-input::-webkit-credentials-auto-fill-button,
  .form-input::-webkit-strong-password-auto-fill-button {
    display:none !important; visibility:hidden; pointer-events:none;
  }

  .id-hint { font-size:11.5px; margin-top:-4px; margin-bottom:14px; line-height:1.3; color:rgba(255,255,255,0.3); display:flex; align-items:center; gap:6px; }
  .id-hint.ok    { color:#86efac; }
  .id-hint.warn  { color:#fcd34d; }
  .id-hint svg   { flex-shrink:0; }

  .btn-submit {
    width:100%;padding:14px;border:none;border-radius:13px;
    font-size:15px;font-weight:700;color:white;cursor:pointer;font-family:inherit;
    background:linear-gradient(135deg,#b45309,#a05a0b,#3a240b);
    position:relative;overflow:hidden;transition:all 0.25s;
    box-shadow:0 8px 28px rgba(180,83,9,0.45);
    display:flex;align-items:center;justify-content:center;gap:8px;margin-top:8px;
  }
  .btn-submit::before { content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.14),transparent);opacity:0;transition:opacity 0.2s; }
  .btn-submit:hover { transform:translateY(-2px);box-shadow:0 14px 36px rgba(180,83,9,0.55); }
  .btn-submit:hover::before { opacity:1; }
  .btn-submit:active { transform:translateY(0); }
  .btn-submit.loading { pointer-events:none;opacity:0.8; }

  .spinner { width:18px;height:18px;border:2.5px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;animation:spin 0.7s linear infinite;display:none; }
  .btn-text { transition:opacity 0.2s; }
  @keyframes spin { to{transform:rotate(360deg);} }

  .login-prompt {
    text-align:center; margin-top:16px; font-size:13px; color:rgba(255,255,255,0.35);
  }
  .login-prompt a {
    color:#fbbf24; font-weight:700; text-decoration:none; margin-left:5px;
    position:relative; transition:color 0.2s;
  }
  .login-prompt a::after {
    content:''; position:absolute; left:0; bottom:-2px; width:100%; height:1px;
    background:linear-gradient(90deg,#fbbf24,#f59e0b);
    transform:scaleX(0); transform-origin:left; transition:transform 0.25s;
  }
  .login-prompt a:hover { color:#f59e0b; }
  .login-prompt a:hover::after { transform:scaleX(1); }

  .card-footer { margin-top:16px;text-align:center; }
  .footer-notice { display:inline-flex;align-items:center;gap:7px;font-size:11.5px;color:rgba(255,255,255,0.25);line-height:1.5; }

  .modal-overlay {
    position:fixed; inset:0; z-index:100;
    background:rgba(8,5,2,0.72);
    backdrop-filter:blur(6px); -webkit-backdrop-filter:blur(6px);
    display:none; align-items:center; justify-content:center; padding:20px;
    animation:fadeIn 0.2s ease;
  }
  .modal-overlay.show { display:flex; }
  @keyframes fadeIn { from{opacity:0;} to{opacity:1;} }

  .modal-box {
    width:100%; max-width:370px;
    background:rgba(26,16,8,0.96);
    border:1px solid rgba(251,191,36,0.18);
    border-radius:20px; padding:30px 26px 26px; text-align:center;
    box-shadow:0 30px 70px rgba(0,0,0,0.6), 0 0 60px rgba(180,83,9,0.15);
    animation:popIn 0.28s cubic-bezier(.22,1,.36,1);
  }
  @keyframes popIn { from{opacity:0;transform:scale(0.92) translateY(10px);} to{opacity:1;transform:scale(1) translateY(0);} }

  .modal-icon {
    width:62px;height:62px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;margin:0 auto 16px;
    background:linear-gradient(135deg,rgba(217,119,6,0.28),rgba(180,83,9,0.15));
    border:1px solid rgba(251,191,36,0.3); color:#fbbf24;
  }
  .modal-title { font-size:19px;font-weight:800;color:white;margin-bottom:8px; }
  .modal-text  { font-size:14px;color:rgba(255,255,255,0.6);line-height:1.55;margin-bottom:22px; }
  .modal-text strong { color:#fbbf24;font-weight:700; }
  .modal-actions { display:flex; gap:10px; }
  .modal-btn-cancel, .modal-btn-confirm {
    flex:1; padding:13px; border-radius:12px; font-size:14px; font-weight:700;
    font-family:inherit; cursor:pointer; transition:all 0.2s;
  }
  .modal-btn-cancel {
    background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12);
    color:rgba(255,255,255,0.6);
  }
  .modal-btn-cancel:hover { background:rgba(255,255,255,0.1); color:white; }
  .modal-btn-confirm {
    background:linear-gradient(135deg,#b45309,#a05a0b); border:none; color:white;
    box-shadow:0 8px 24px rgba(180,83,9,0.4);
  }
  .modal-btn-confirm:hover { transform:translateY(-1px); box-shadow:0 12px 30px rgba(180,83,9,0.5); }

  @media(max-width:480px) {
    .card{padding:26px 22px 22px;border-radius:22px;}
    .brand-name{font-size:22px;}
    .form-row{flex-direction:column;gap:0;}
  }
  </style>
</head>

<body>

<div class="bg-mesh"></div>
<div class="blob blob-1"></div>
<div class="blob blob-2"></div>
<div class="blob blob-3"></div>
<div class="stars" id="stars"></div>

<div class="wrapper">
  <div class="card">

    <div class="card-header">
      <div class="logo-wrap">
        <div class="logo-ring">
          <img src="/LOGO.jpg" alt="Logo ARSIPRO"/>
        </div>
      </div>
      <div class="brand-name">ARSIPRO <span>ISB</span></div>
      <div class="brand-sub">Sistem Informasi Arsip Digital</div>
    </div>

    <div class="divider">
      <div class="divider-line"></div>
      <div class="divider-text">BUAT AKUN BARU</div>
      <div class="divider-line"></div>
    </div>

    <div class="error-msg" id="errorMsg">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <span id="errorText">Terjadi kesalahan. Coba lagi.</span>
    </div>

    <div class="success-msg" id="successMsg">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
      <span id="successText">Pendaftaran berhasil! Mengalihkan ke halaman login...</span>
    </div>

    <form id="registerForm" autocomplete="off">

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Nama Lengkap</label>
          <div class="input-wrap">
            <span class="input-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </span>
            <input type="text" id="namaLengkap" class="form-input" placeholder="Nama lengkap" required autocomplete="off"/>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Username</label>
          <div class="input-wrap">
            <span class="input-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
              </svg>
            </span>
            <input type="text" id="username" class="form-input" placeholder="Cth: mahasiswa.23" required autocomplete="off"/>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Email</label>
        <div class="input-wrap">
          <span class="input-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </span>
          <input type="email" id="email" class="form-input" placeholder="nama@isb.ac.id" required autocomplete="off"/>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" id="idLabel">NIM / NUPTK</label>
        <div class="input-wrap">
          <span class="input-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="16" rx="2"/>
              <line x1="7" y1="9" x2="17" y2="9"/>
              <line x1="7" y1="13" x2="13" y2="13"/>
            </svg>
          </span>
          <input type="text" inputmode="numeric" id="nomorId" class="form-input" placeholder="Silahkan Masukkan NIM atau NUPTK" required maxlength="16" autocomplete="off"/>
        </div>
      </div>
      <div class="id-hint" id="idHint">
      <span id="idHintText">Masukkan NIM atau NUPTK sesuai data resmi Anda.</span>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Password</label>
          <div class="input-wrap">
            <span class="input-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <input type="password" id="password" class="form-input" placeholder="Min. 8 karakter" required minlength="8" autocomplete="new-password"/>
            <button type="button" class="toggle-pw" data-target="password">
              <svg class="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Konfirmasi</label>
          <div class="input-wrap">
            <span class="input-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <input type="password" id="confirmPassword" class="form-input" placeholder="Ulangi password" required minlength="8" autocomplete="new-password"/>
            <button type="button" class="toggle-pw" data-target="confirmPassword">
              <svg class="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <button type="submit" class="btn-submit" id="btnRegister">
        <div class="spinner" id="spinner"></div>
        <span class="btn-text" id="btnText">
          <span style="display:flex;align-items:center;gap:8px;">
            Daftar Sekarang
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </span>
        </span>
      </button>

      <div class="login-prompt">
        Sudah punya akun?
        <a href="/login">Masuk di sini</a>
      </div>

    </form>

    <div class="card-footer">
      <div class="footer-notice">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        Data Anda terlindungi — jaga kerahasiaan akun Anda
      </div>
    </div>

  </div>
</div>

<div class="modal-overlay" id="roleModal">
  <div class="modal-box">
    <div class="modal-icon" id="modalIcon">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
    </div>
    <div class="modal-title">Konfirmasi Role</div>
    <div class="modal-text" id="modalText">Anda akan terdaftar di role <strong>Mahasiswa</strong>.</div>
    <div class="modal-actions">
      <button type="button" class="modal-btn-cancel" id="modalCancel">Batal</button>
      <button type="button" class="modal-btn-confirm" id="modalConfirm">Ya, Daftar</button>
    </div>
  </div>
</div>

<script is:inline>

const API_BASE = window.__API_URL__;

const starsEl = document.getElementById("stars");
for (let i = 0; i < 80; i++) {
  const s = document.createElement("div");
  s.className = "star";
  s.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*100}%;--d:${3+Math.random()*5}s;--delay:-${Math.random()*8}s;--op:${0.2+Math.random()*0.4};width:${Math.random()>0.7?3:2}px;height:${Math.random()>0.7?3:2}px;`;
  starsEl.appendChild(s);
}

document.querySelectorAll(".toggle-pw").forEach((btnEl) => {
  btnEl.addEventListener("click", () => {
    const targetId = btnEl.getAttribute("data-target");
    const input    = document.getElementById(targetId);
    const eyeIcon  = btnEl.querySelector(".eyeIcon");
    const isHidden = input.type === "password";
    input.type = isHidden ? "text" : "password";
    eyeIcon.innerHTML = isHidden
      ? `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>`
      : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
  });
});

const NIM_LEN   = 10; // Mahasiswa
const NUPTK_LEN = 16; // Dosen

const idLabel    = document.getElementById("idLabel");
const idInput    = document.getElementById("nomorId");
const idHint     = document.getElementById("idHint");
const idHintText = document.getElementById("idHintText");

function roleLabel(r) { return r === "dosen" ? "Dosen" : "Mahasiswa"; }

function detectRole(digits) {
  if (digits.length === NIM_LEN)   return "mahasiswa";
  if (digits.length === NUPTK_LEN) return "dosen";
  return null;
}

function updateIdHint() {
  const len = idInput.value.length;
  const det = detectRole(idInput.value);
  idHint.classList.remove("ok", "warn");

  idLabel.textContent = "NIM / NUPTK";

  if (det) {
    idHint.classList.add("ok");
    idHintText.textContent = "Nomor valid.";
  } else if (len === 0) {
    idHintText.textContent = "Masukkan NIM atau NUPTK sesuai data resmi Anda.";
  } else {
    idHint.classList.add("warn");
    idHintText.textContent = "Nomor belum sesuai format yang berlaku.";
  }
}

idInput.addEventListener("input", () => {
  idInput.value = idInput.value.replace(/\D/g, "");
  updateIdHint();
});
updateIdHint();

const form    = document.getElementById("registerForm");
const btn     = document.getElementById("btnRegister");
const spinner = document.getElementById("spinner");
const btnText = document.getElementById("btnText");
const errMsg  = document.getElementById("errorMsg");
const errText = document.getElementById("errorText");
const sucMsg  = document.getElementById("successMsg");

const roleModal    = document.getElementById("roleModal");
const modalText    = document.getElementById("modalText");
const modalCancel  = document.getElementById("modalCancel");
const modalConfirm = document.getElementById("modalConfirm");
let pendingRole = null;

function openRoleModal(role, digits) {
  pendingRole = role;
  modalText.innerHTML =
    `Nomor <strong>${digits.length} digit</strong> terdeteksi. ` +
    `Anda akan terdaftar di role <strong>${roleLabel(role)}</strong>.`;
  roleModal.classList.add("show");
}
function closeRoleModal() {
  roleModal.classList.remove("show");
  pendingRole = null;
}
modalCancel.addEventListener("click", closeRoleModal);
roleModal.addEventListener("click", (e) => { if (e.target === roleModal) closeRoleModal(); });
modalConfirm.addEventListener("click", () => {
  if (!pendingRole) return;
  const role = pendingRole;
  closeRoleModal();
  doRegister(role);
});

/* ---------- helper UI ---------- */
function setLoading(v) {
  btn.classList.toggle("loading", v);
  spinner.style.display  = v ? "block" : "none";
  btnText.style.opacity  = v ? "0" : "1";
  btnText.style.position = v ? "absolute" : "";
}
function showError(msg) { sucMsg.style.display = "none"; errText.textContent = msg; errMsg.style.display = "flex"; }
function hideMessages() { errMsg.style.display = "none"; sucMsg.style.display = "none"; }

/* ---------- submit: validasi lalu tampilkan popup ---------- */
if (form) {
  form.addEventListener("submit", (e) => {
    e.preventDefault();
    hideMessages();

    const namaLengkap     = document.getElementById("namaLengkap").value.trim();
    const username        = document.getElementById("username").value.trim();
    const email           = document.getElementById("email").value.trim();
    const nomorId         = document.getElementById("nomorId").value.trim();
    const password        = document.getElementById("password").value;
    const confirmPassword = document.getElementById("confirmPassword").value;

    if (!namaLengkap || !username || !email || !nomorId || !password || !confirmPassword) {
      showError("Semua field wajib diisi."); return;
    }
    if (password.length < 8) { showError("Password minimal 8 karakter."); return; }
    if (password !== confirmPassword) { showError("Konfirmasi password tidak cocok."); return; }

    const digits = nomorId.replace(/\D/g, "");
    const detected = detectRole(digits);

    if (!detected) {
      showError("Nomor harus 10 digit (NIM/Mahasiswa) atau 16 digit (NUPTK/Dosen).");
      return;
    }

    openRoleModal(detected, digits);
  });
}

/* ---------- proses pendaftaran ke server ---------- */
async function doRegister(role) {
  const namaLengkap = document.getElementById("namaLengkap").value.trim();
  const username    = document.getElementById("username").value.trim();
  const email       = document.getElementById("email").value.trim();
  const nomorId     = document.getElementById("nomorId").value.trim().replace(/\D/g, "");
  const password    = document.getElementById("password").value;

  setLoading(true);
  try {
    const res = await fetch(`${API_BASE}/api/auth/register`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        nama: namaLengkap,
        username,
        email,
        role,
        nomor_id: nomorId,
        password
      })
    });

    let data = {};
    try { data = await res.json(); } catch (_) { /* respons bukan JSON */ }

    if (res.ok) {
      sucMsg.style.display = "flex";
      setTimeout(() => { window.location.href = "/login"; }, 1500);
    } else {
      showError(data.message || `Pendaftaran gagal (status ${res.status}). Periksa kembali data Anda.`);
      setLoading(false);
    }
  } catch (err) {
    console.error(err);
    showError("Tidak dapat terhubung ke server. Pastikan backend sedang berjalan.");
    setLoading(false);
  }
}
</script>

