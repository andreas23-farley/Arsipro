---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>

<section class="hero">
  <div class="overlay"></div>

  <div class="hero-text">

    <h1>
      ARSIPRO <span>SHANTI BHUANA</span>
    </h1>

    <p style="font-weight:700;">
      Kelola surat masuk dan keluar secara cepat, aman, dan terorganisir dalam satu sistem modern
    </p>

    <div class="hero-btn">
      <a href="/login" class="btn primary">Mulai Sekarang</a>
    </div>
  </div>
</section>

<section id="fitur" class="features">

  <div class="card">
    <div class="icon" style="color:#4f46e5;">
      <!-- inbox / surat masuk -->
      <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
        <path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
      </svg>
    </div>
    <h3>Surat Masuk</h3>
    <p>Kelola surat masuk dengan upload file dan kategori otomatis</p>
  </div>

  <div class="card">
    <div class="icon" style="color:#06b6d4;">
      <!-- send / surat keluar -->
      <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </div>
    <h3>Surat Keluar</h3>
    <p>Buat dan kirim surat keluar dengan sistem terstruktur</p>
  </div>

  <div class="card">
    <div class="icon" style="color:#8b5cf6;">
      <!-- archive / arsip -->
      <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="21 8 21 21 3 21 3 8"/>
        <rect x="1" y="3" width="22" height="5"/>
        <line x1="10" y1="12" x2="14" y2="12"/>
      </svg>
    </div>
    <h3>Arsip Surat</h3>
    <p>Simpan dokumen dengan aman dan mudah dicari kapan saja</p>
  </div>

  <div class="card">
    <div class="icon" style="color:#f59e0b;">
      <!-- file-text / template -->
      <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <polyline points="10 9 9 9 8 9"/>
      </svg>
    </div>
    <h3>Template Surat</h3>
    <p>Gunakan template surat yang tersedia untuk mempercepat pembuatan surat</p>
  </div>

</section>

</MainLayout>

<style>

/* ===== HERO ===== */
.hero {
  position: relative;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: url("/isb.jpg") center/cover no-repeat;
}

.overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(245, 245, 248, 0.55),
    rgba(210, 214, 214, 0.4),
    rgba(253, 253, 255, 0.6)
  );
}

/* ===== HERO TEXT ===== */
.hero-text {
  position: relative;
  color: rgb(8, 7, 7);
  max-width: 700px;
  padding: 0 20px;
  animation: fadeUp 1.2s ease;
}

.hero-text h1 {
  font-size: 48px;
  font-weight: 700;
  line-height: 1.2;
  color: rgb(7, 6, 6);
}

.hero-text h1 span {
  color: #0c0d0e;
}

.hero-text p {
  margin-top: 16px;
  font-size: 16px;
  opacity: 0.9;
  line-height: 1.7;
}

/* ===== LOGO ===== */
.hero-logo-wrap {
  margin-bottom: 20px;
  display: flex;
  justify-content: center;
}

.hero-logo-wrap img {
  width: 80px;
  height: 80px;
  object-fit: cover;
  border-radius: 50%;
  border: 3px solid rgba(255,255,255,0.6);
  box-shadow: 0 8px 24px rgba(0,0,0,0.25);
  transition: transform 0.3s;
}

.hero-logo-wrap img:hover {
  transform: scale(1.08);
}

/* ===== BUTTON ===== */
.hero-btn {
  margin-top: 30px;
  display: flex;
  gap: 15px;
  justify-content: center;
}

.btn {
  padding: 13px 28px;
  border-radius: 12px;
  text-decoration: none;
  font-weight: 600;
  font-size: 15px;
  transition: 0.3s;
}

.btn.primary {
  background: white;
  color: #1a1a1d;
  box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}

.btn.primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 28px rgba(0,0,0,0.25);
}

/* ===== FEATURES ===== */
.features {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 25px;
  padding: 80px 60px;
  background: #f8fafc;
}

/* CARD */
.card {
  background: rgb(204, 196, 196);
  padding: 32px 24px;
  border-radius: 20px;
  text-align: center;
  border: 0.5px solid #e2e8f0;
  box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  transition: transform 0.3s, box-shadow 0.3s;
}

.card:hover {
  transform: translateY(-8px);
  box-shadow: 0 16px 32px rgba(0,0,0,0.1);
}

.icon {
  margin-bottom: 16px;
  display: flex;
  justify-content: center;
}

.card h3 {
  font-size: 17px;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 10px;
}

.card p {
  font-size: 14px;
  color: #64748b;
  line-height: 1.6;
}

/* ===== ANIMATION ===== */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
  .features {
    grid-template-columns: repeat(2, 1fr);
    padding: 60px 30px;
  }

  .hero-text h1 {
    font-size: 32px;
  }
}

@media (max-width: 500px) {
  .features {
    grid-template-columns: 1fr;
    padding: 40px 20px;
  }

  .hero-text h1 {
    font-size: 26px;
  }

  .hero-btn {
    flex-direction: column;
    align-items: center;
  }
}

</style>